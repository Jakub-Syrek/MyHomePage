{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",

  "VideoStorage": {
    "VideosFolder": "videos",
    "MaxFileSizeBytes": 5368709120,
    "AllowedExtensions": [".mp4", ".webm", ".mkv", ".avi", ".mov", ".m4v"],

    "//": "── H.264 quality (tuned for 1080p smooth playback) ──",
    "CompressionCrf": 23,
    "MaxWidthPixels": 1920,
    "MaxHeightPixels": 1080,
    "MaxFrameRate": 30,
    "MaxBitrateKbps": 6000,
    "AudioBitrateKbps": 160,
    "Preset": "slow",
    "Tune": "film",
    "KeyframeIntervalSeconds": 2
  }
}
