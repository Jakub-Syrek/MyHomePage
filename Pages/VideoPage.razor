@page "/video/{VideoId:int}"
@layout MainLayout
@inject VideoService VideoService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>@(video?.Title ?? "Video") - My Mountain Adventures</PageTitle>

<HeadContent>
    @if (video != null)
    {
        <meta property="og:title" content="@video.Title" />
        <meta property="og:description" content="@(string.IsNullOrEmpty(video.Description) ? video.Title : video.Description)" />
        <meta property="og:type" content="video.other" />
        <meta property="og:url" content="@directLink" />
        <meta property="og:site_name" content="My Mountain Adventures" />
        <meta property="og:image" content="@thumbnailUrl" />
        <meta property="og:image:secure_url" content="@thumbnailUrl" />
        <meta property="og:image:width" content="1280" />
        <meta property="og:image:height" content="720" />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:video" content="@videoFileUrl" />
        <meta property="og:video:secure_url" content="@videoFileUrl" />
        <meta property="og:video:type" content="video/mp4" />
        <meta property="og:video:width" content="1280" />
        <meta property="og:video:height" content="720" />
        <meta name="twitter:card" content="player" />
        <meta name="twitter:title" content="@video.Title" />
        <meta name="twitter:description" content="@(string.IsNullOrEmpty(video.Description) ? video.Title : video.Description)" />
        <meta name="twitter:image" content="@thumbnailUrl" />
        <meta name="twitter:player" content="@($"{baseUrl}/embed/{video.Id}")" />
        <meta name="twitter:player:width" content="1280" />
        <meta name="twitter:player:height" content="720" />
    }
</HeadContent>

<div class="video-page-container" style="background-image: url('/images/mountains-bg.jpg');">
    <div class="video-page-content">
        @if (video == null && !notFound)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Loading...</p>
            </div>
        }
        else if (notFound)
        {
            <div class="empty-state">
                <h2>Video not found</h2>
                <button class="btn-back" @onclick="GoHome">← Home</button>
            </div>
        }
        else if (video != null)
        {
            <div class="video-page-header">
                <button class="btn-back" @onclick="GoBack">← Back</button>
            </div>

            <div class="video-player-wrapper">
                <video controls preload="metadata" playsinline autoplay>
                    <source src="/videos/@video.Id/@video.FileName" type="video/mp4" />
                </video>
            </div>

            <div class="video-info">
                <h1>@video.Title</h1>
                @if (!string.IsNullOrEmpty(video.Description))
                {
                    <p class="description">@video.Description</p>
                }
                <div class="meta">
                    @if (!string.IsNullOrEmpty(video.Location))
                    {
                        <span>📍 @video.Location</span>
                    }
                    <span>📅 @video.UploadedAt.ToString("MMM dd, yyyy")</span>
                    @if (!string.IsNullOrEmpty(video.Category))
                    {
                        <span>🏷️ @video.Category</span>
                    }
                </div>

                <div class="share-section">
                    <h3>Share this video</h3>

                    <div class="share-row">
                        <label>Direct link:</label>
                        <input type="text" readonly value="@directLink" id="directLink" />
                        <button @onclick='() => CopyToClipboard("directLink")'>Copy</button>
                    </div>

                    <div class="share-row">
                        <label>Embed code:</label>
                        <textarea readonly id="embedCode" rows="3">@embedCode</textarea>
                        <button @onclick='() => CopyToClipboard("embedCode")'>Copy</button>
                    </div>

                    <p class="hint">💡 Use the embed code to put this video on any website.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .video-page-container {
        min-height: 90vh;
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        padding: 30px 20px;
    }

    .video-page-content {
        max-width: 1100px;
        margin: 0 auto;
    }

    .video-page-header {
        margin-bottom: 20px;
    }

    .video-player-wrapper {
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
        aspect-ratio: 16 / 9;
    }

    .video-player-wrapper video {
        width: 100%;
        height: 100%;
        display: block;
    }

    .video-info {
        margin-top: 30px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 30px;
    }

    .video-info h1 {
        margin: 0 0 15px 0;
        color: #2c3e50;
    }

    .video-info .description {
        color: #34495e;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .video-info .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        color: #7f8c8d;
        font-size: 0.95rem;
        padding-bottom: 20px;
        border-bottom: 1px solid #ecf0f1;
    }

    .share-section {
        margin-top: 25px;
    }

    .share-section h3 {
        color: #2c3e50;
        margin-bottom: 15px;
    }

    .share-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .share-row label {
        font-weight: 600;
        color: #2c3e50;
        min-width: 110px;
        padding-top: 8px;
    }

    .share-row input,
    .share-row textarea {
        flex: 1;
        min-width: 200px;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-family: monospace;
        font-size: 0.85rem;
    }

    .share-row textarea {
        resize: vertical;
    }

    .share-row button {
        padding: 8px 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    .share-row button:hover {
        opacity: 0.9;
    }

    .hint {
        color: #95a5a6;
        font-size: 0.85rem;
        margin-top: 10px;
    }
</style>

@code {
    [Parameter]
    public int VideoId { get; set; }

    private Video? video;
    private bool notFound = false;
    private string baseUrl = "";
    private string directLink = "";
    private string embedCode = "";
    private string thumbnailUrl = "";
    private string videoFileUrl = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        baseUrl = $"{uri.Scheme}://{uri.Authority}";

        video = await VideoService.GetVideoByIdAsync(VideoId);
        notFound = video == null;

        if (video != null)
        {
            // Auto-generate thumbnail for older videos that don't have one
            await VideoService.EnsureThumbnailExistsAsync(video.Id);

            directLink = $"{baseUrl}/video/{video.Id}";
            embedCode = $"<iframe src=\"{baseUrl}/embed/{video.Id}\" width=\"800\" height=\"450\" frameborder=\"0\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>";
            thumbnailUrl = $"{baseUrl}/videos/{video.Id}/thumbnail.jpg";
            videoFileUrl = $"{baseUrl}/videos/{video.Id}/{video.FileName}";
        }
    }

    private async Task CopyToClipboard(string elementId)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText",
            elementId == "directLink" ? directLink : embedCode);
    }

    private void GoBack()
    {
        var categoryUrl = video?.Category switch
        {
            VideoCategories.Gory => "/gory",
            VideoCategories.WspinaczkaSkalowa => "/wspinaczka-skalowa",
            VideoCategories.Bouldering => "/bouldering",
            VideoCategories.ProwadzieniHala => "/prowadzeni-hala",
            _ => "/"
        };
        Navigation.NavigateTo(categoryUrl);
    }

    private void GoHome() => Navigation.NavigateTo("/");
}
