@page "/admin/hash-password"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Hash password - Admin</PageTitle>

<div class="hash-tool">
    <h1>🔒 BCrypt password hasher</h1>
    <p class="hint">
        Paste a plaintext password below to get a BCrypt hash (work factor 12)
        suitable for the <code>ADMIN_PASSWORD</code> env var or
        <code>credentials.json</code>.
        The plaintext is hashed entirely inside the browser session — nothing
        is logged or persisted.
    </p>

    <label>
        Plaintext
        <input type="password"
               autocomplete="new-password"
               @bind="_plaintext"
               @bind:event="oninput"
               placeholder="At least 12 characters — mix letters, digits, symbols" />
    </label>

    <button type="button"
            class="btn primary"
            disabled="@string.IsNullOrEmpty(_plaintext)"
            @onclick="GenerateHash">
        Generate BCrypt hash
    </button>

    @if (!string.IsNullOrEmpty(_hash))
    {
        <label class="result">
            BCrypt hash (cost 12)
            <textarea readonly rows="2">@_hash</textarea>
        </label>
        <p class="hint small">
            Set this as the value of <code>ADMIN_PASSWORD</code> (or the
            <code>password</code> field in your <code>credentials.json</code>
            entry). The login flow detects the <code>$2…</code> prefix and
            verifies via <code>BCrypt.Verify</code>; existing plaintext values
            keep working but log a deprecation warning.
        </p>
    }

    @if (!string.IsNullOrEmpty(_strengthHint))
    {
        <p class="hint warn">@_strengthHint</p>
    }
</div>

<style>
    .hash-tool {
        max-width: 720px;
        margin: 60px auto;
        padding: 28px;
        background: rgba(255,255,255,0.94);
        border-radius: 14px;
        box-shadow: 0 14px 36px rgba(20,30,60,0.10);
    }
    .hash-tool h1 { margin: 0 0 8px; font-size: 1.6rem; color: #1f2937; }
    .hash-tool .hint { color: #4a5568; font-size: 0.92rem; margin: 0 0 18px; }
    .hash-tool .hint.small { font-size: 0.85rem; }
    .hash-tool .hint.warn { color: #92400e; }
    .hash-tool label {
        display: block;
        font-weight: 600;
        color: #374151;
        margin-top: 14px;
    }
    .hash-tool input,
    .hash-tool textarea {
        display: block;
        width: 100%;
        margin-top: 6px;
        padding: 10px 12px;
        border: 1px solid #cbd5e0;
        border-radius: 8px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.95rem;
    }
    .hash-tool textarea {
        resize: vertical;
        background: #f8fafc;
    }
    .hash-tool .btn {
        margin-top: 14px;
        padding: 10px 18px;
        border-radius: 10px;
        border: 0;
        cursor: pointer;
        font-weight: 600;
        font-family: inherit;
    }
    .hash-tool .btn.primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    .hash-tool .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .hash-tool .result { margin-top: 22px; }
</style>

@code {
    private string _plaintext = "";
    private string _hash = "";
    private string _strengthHint = "";

    /// <summary>
    /// Generates a BCrypt hash from the current <see cref="_plaintext"/>
    /// using work factor 12 (≈ 250 ms / verification on commodity
    /// hardware) and surfaces a strength reminder when the input is
    /// shorter than 12 characters.
    /// </summary>
    private void GenerateHash()
    {
        var pw = _plaintext.Trim();
        if (string.IsNullOrEmpty(pw))
        {
            _hash = "";
            _strengthHint = "";
            return;
        }

        _strengthHint = pw.Length < 12
            ? "⚠ Password is shorter than 12 characters. Consider a longer phrase."
            : "";
        _hash = BCrypt.Net.BCrypt.HashPassword(pw, workFactor: 12);
    }
}
