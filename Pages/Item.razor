@page "/item/{Id:int}"
@layout MainLayout
@inject IVideoService VideoService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_item?.Title ?? "Item") — My Mountain Adventures</PageTitle>

@if (_item is not null)
{
    var pageUrl = _pageUrl;
    var firstImage = _item.GetAllMedia().FirstOrDefault(m => m.Type == MediaType.Image);
    var firstVideo = _item.GetAllMedia().FirstOrDefault(m => m.Type == MediaType.Video);
    var ogImageUrl = firstImage is not null
        ? Nav.ToAbsoluteUri($"/videos/{Id}/{firstImage.FileName}").ToString()
        : Nav.ToAbsoluteUri("/images/mountains-bg.jpg").ToString();
    var ogVideoUrl = firstVideo is not null
        ? Nav.ToAbsoluteUri($"/videos/{Id}/{firstVideo.FileName}").ToString()
        : null;
    var descShort = (_item.Description ?? "")
        .Replace("\n", " ").Replace("\r", " ").Trim();
    if (descShort.Length > 200) descShort = descShort.Substring(0, 200) + "…";
    if (string.IsNullOrWhiteSpace(descShort))
        descShort = $"{_item.Category} — {_item.Location}".Trim(' ', '—');

    <HeadContent>
        <meta property="og:type" content="article" />
        <meta property="og:title" content="@_item.Title" />
        <meta property="og:description" content="@descShort" />
        <meta property="og:url" content="@pageUrl" />
        <meta property="og:image" content="@ogImageUrl" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        @if (ogVideoUrl is not null)
        {
            <meta property="og:video" content="@ogVideoUrl" />
            <meta property="og:video:secure_url" content="@ogVideoUrl" />
            <meta property="og:video:type" content="video/mp4" />
            <meta property="og:video:width" content="1280" />
            <meta property="og:video:height" content="720" />
        }
        <meta property="article:published_time" content="@_item.UploadedAt.ToString("o")" />
        @if (_item.HasCoordinates)
        {
            <meta property="og:latitude" content="@_item.Latitude" />
            <meta property="og:longitude" content="@_item.Longitude" />
            <meta property="place:location:latitude" content="@_item.Latitude" />
            <meta property="place:location:longitude" content="@_item.Longitude" />
        }
        <meta name="twitter:card" content="@(firstImage is not null ? "summary_large_image" : "player")" />
        <meta name="twitter:title" content="@_item.Title" />
        <meta name="twitter:description" content="@descShort" />
        <meta name="twitter:image" content="@ogImageUrl" />
        @if (ogVideoUrl is not null && firstImage is null)
        {
            <meta name="twitter:player:stream" content="@ogVideoUrl" />
            <meta name="twitter:player:stream:content_type" content="video/mp4" />
        }
        <meta name="description" content="@descShort" />
        <link rel="canonical" href="@pageUrl" />
    </HeadContent>
}

@if (_item is null)
{
    <div class="loading-page">
        <div class="spinner"></div>
        <p>@_loadMessage</p>
    </div>
}
else
{
    <article class="item-page">
        <header class="item-hero">
            <div class="item-hero-inner">
                <a href="@_backUrl" class="back-link">← @_backLabel</a>
                <h1 class="item-title">@_item.Title</h1>
                <div class="item-meta">
                    @if (!string.IsNullOrEmpty(_item.Category))
                    {
                        <a class="badge category" href="@VideoCategories.GetUrl(_item.Category)">@_item.Category</a>
                    }
                    @if (!string.IsNullOrEmpty(_item.Location))
                    {
                        <span class="badge location">📍 @_item.Location</span>
                    }
                    @if (_item.HasCoordinates)
                    {
                        <a class="badge map" href="/map">🗺️ Show on map</a>
                    }
                    <span class="badge date">@_item.UploadedAt.ToString("MMM dd, yyyy")</span>
                    <span class="badge files">@_media.Count item(s)</span>
                </div>
            </div>
        </header>

        <div class="item-body">
            <section class="item-grid">
                @for (int i = 0; i < _media.Count; i++)
                {
                    var idx = i;
                    var m = _media[i];
                    var url = $"/videos/{Id}/{m.FileName}";
                    <div class="grid-tile @(m.Type == MediaType.Image ? "is-image" : "is-video")"
                         @onclick="() => OpenLightbox(idx)"
                         id="m-@idx">
                        @if (m.Type == MediaType.Image)
                        {
                            <img src="@url" alt="@_item.Title" loading="lazy" />
                        }
                        else
                        {
                            <video preload="metadata" muted playsinline>
                                <source src="@(url + "#t=0.5")" type="video/mp4" />
                            </video>
                            <div class="grid-play">▶</div>
                        }
                        <div class="grid-tag">@(m.Type == MediaType.Image ? "PHOTO" : "VIDEO") @(idx + 1)</div>
                    </div>
                }
            </section>

            @if (!string.IsNullOrWhiteSpace(_item.Description))
            {
                <aside class="item-description">
                    <h2>About this trip</h2>
                    <p>@_item.Description</p>
                    @if (_item.HasCoordinates)
                    {
                        <div class="coords">
                            <strong>GPS:</strong>
                            <code>@_item.Latitude?.ToString("F6"), @_item.Longitude?.ToString("F6")</code>
                        </div>
                    }
                </aside>
            }

            <TrainingPanel Training="@_item.Training" />

            <div class="share-bar">
                <button type="button" class="link-btn primary" @onclick="CopyPageLink">
                    @if (_pageCopied) { <span>✓ Page link copied</span> } else { <span>🔗 Copy page link</span> }
                </button>
                <a href="@($"https://www.facebook.com/sharer/sharer.php?u={Uri.EscapeDataString(_pageUrl)}")"
                   target="_blank" rel="noopener noreferrer"
                   class="link-btn share-fb"
                   title="Share on Facebook">
                    <span class="share-icon">f</span> Share on Facebook
                </a>
                <a href="@($"https://wa.me/?text={Uri.EscapeDataString($"{_item.Title} — {_pageUrl}")}")"
                   target="_blank" rel="noopener noreferrer"
                   class="link-btn share-wa"
                   title="Share on WhatsApp">
                    <span class="share-icon">📱</span> WhatsApp
                </a>
                <a href="@($"https://twitter.com/intent/tweet?text={Uri.EscapeDataString(_item.Title)}&url={Uri.EscapeDataString(_pageUrl)}")"
                   target="_blank" rel="noopener noreferrer"
                   class="link-btn share-x"
                   title="Share on X / Twitter">
                    <span class="share-icon">𝕏</span> Share on X
                </a>
                @if (_nativeShareSupported)
                {
                    <button type="button" class="link-btn share-native" @onclick="NativeShare" title="Open device share menu">
                        <span class="share-icon">↗</span> Share…
                    </button>
                }
                @{
                    var primary = _media.FirstOrDefault();
                }
                @if (primary is not null)
                {
                    var dlUrl = $"/videos/{Id}/{primary.FileName}";
                    var dlLabel = primary.Type == MediaType.Video ? "Download video" : "Download photo";
                    <a href="@dlUrl"
                       download="@primary.FileName"
                       class="link-btn share-dl"
                       title="Download the media file so you can upload it as a native photo/video post on Facebook">
                        <span class="share-icon">⬇</span> @dlLabel
                    </a>
                }
                <AdminItemActions Item="@_item"
                                  Variant="labeled"
                                  ExtraClass="item-actions"
                                  RedirectOnDelete="true" />
            </div>
        </div>
    </article>

    <Lightbox @ref="_lightbox" ItemId="Id" Items="_media" OnClose="OnLightboxClosed" />
}

<style>
    .loading-page { text-align:center; padding:80px 20px; color:#7f8c8d; }
    .loading-page .spinner {
        width: 48px; height: 48px;
        border: 4px solid rgba(102,126,234,0.2);
        border-top-color: #667eea;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 20px;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .item-page { padding-bottom: 60px; }

    .item-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 24px 50px;
    }
    .item-hero-inner { max-width: 1200px; margin: 0 auto; }
    .back-link {
        color: rgba(255,255,255,0.85);
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 16px;
        display: inline-block;
    }
    .back-link:hover { color: white; }
    .item-title {
        margin: 6px 0 18px;
        font-size: 2.6rem;
        font-weight: 800;
        line-height: 1.1;
        text-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .item-meta { display:flex; flex-wrap:wrap; gap:10px; }
    .badge {
        display: inline-flex; align-items: center; gap: 4px;
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(4px);
        color: white;
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.18s;
    }
    .badge:hover { background: rgba(255,255,255,0.32); }

    .item-body {
        max-width: 1200px;
        margin: -28px auto 0;
        padding: 0 20px;
        position: relative;
        z-index: 2;
    }

    .item-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 14px;
        margin-bottom: 28px;
    }
    .grid-tile {
        position: relative;
        aspect-ratio: 4 / 3;
        border-radius: 16px;
        overflow: hidden;
        background: rgba(20, 20, 30, 0.6);
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow:
            0 8px 24px rgba(20, 30, 60, 0.18),
            0 1px 3px rgba(20, 30, 60, 0.1),
            inset 0 1px 0 rgba(255, 255, 255, 0.4);
        transition: transform 0.28s cubic-bezier(.2,.7,.2,1),
                    box-shadow 0.28s,
                    border-color 0.28s;
    }
    .grid-tile:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.7);
        box-shadow:
            0 18px 40px rgba(20, 30, 60, 0.28),
            0 4px 12px rgba(20, 30, 60, 0.14),
            inset 0 1px 0 rgba(255, 255, 255, 0.6);
    }
    .grid-tile::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(
            135deg,
            rgba(255,255,255,0.30) 0%,
            rgba(255,255,255,0.08) 32%,
            rgba(255,255,255,0) 60%
        );
        pointer-events: none;
        z-index: 2;
        mix-blend-mode: overlay;
    }
    .grid-tile img, .grid-tile video {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
    }
    .grid-play {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 2.6rem;
        text-shadow: 0 4px 14px rgba(0,0,0,0.6);
        pointer-events: none;
    }
    .grid-tag {
        position: absolute; top: 10px; left: 10px;
        background: rgba(0,0,0,0.65); color: white;
        font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em;
        padding: 4px 10px; border-radius: 999px;
        backdrop-filter: blur(4px);
        pointer-events: none;
    }

    .item-description {
        position: relative;
        background: linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.78) 100%);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 20px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow:
            0 14px 40px rgba(20, 30, 60, 0.12),
            0 2px 6px rgba(20, 30, 60, 0.05),
            inset 0 1px 0 rgba(255, 255, 255, 0.8);
        overflow: hidden;
    }
    .item-description::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 50%;
        background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0) 100%);
        pointer-events: none;
        border-radius: 20px 20px 0 0;
    }
    .item-description > * { position: relative; z-index: 1; }
    .item-description h2 {
        margin: 0 0 14px;
        color: #2c3e50;
        font-size: 1.35rem;
    }
    .item-description p {
        color: #4a5568;
        line-height: 1.7;
        white-space: pre-wrap;
        margin: 0 0 14px;
    }
    .coords {
        background: #f7fafc;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        color: #4a5568;
    }
    .coords code { color: #667eea; }

    .share-bar {
        display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
        padding: 16px;
    }
    .link-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: white;
        color: #4a5568;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.18s ease;
        font-family: inherit;
    }
    .link-btn:hover {
        background: #f7fafc;
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(0,0,0,0.06);
    }
    .link-btn.primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
    }
    .link-btn.primary:hover { filter: brightness(1.08); color: white; }

    .share-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 18px; height: 18px;
        border-radius: 4px;
        font-weight: 800;
        font-size: 0.85rem;
        line-height: 1;
    }
    .link-btn.share-fb       { background:#1877F2; color:#fff; border-color:transparent; }
    .link-btn.share-fb:hover { background:#0e63d3; color:#fff; }
    .link-btn.share-wa       { background:#25D366; color:#fff; border-color:transparent; }
    .link-btn.share-wa:hover { background:#1ebe5a; color:#fff; }
    .link-btn.share-x        { background:#000;    color:#fff; border-color:transparent; }
    .link-btn.share-x:hover  { background:#222;    color:#fff; }
    .link-btn.share-native       { background:#4a5568; color:#fff; border-color:transparent; }
    .link-btn.share-native:hover { background:#2d3748; color:#fff; }
    .link-btn.share-dl           { background:#0ea371; color:#fff; border-color:transparent; }
    .link-btn.share-dl:hover     { background:#08825a; color:#fff; }
</style>

@code {
    [Parameter] public int Id { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "m")]
    public string? MediaQuery { get; set; }

    private Video? _item;
    private IReadOnlyList<MediaItem> _media = Array.Empty<MediaItem>();
    private string _pageUrl = "";
    private string _backUrl = "/";
    private string _backLabel = "Home";
    private string _loadMessage = "Loading…";
    private bool _pageCopied;
    private bool _nativeShareSupported;
    private Lightbox? _lightbox;
    private string? _autoOpened;

    protected override async Task OnParametersSetAsync()
    {
        _pageUrl = Nav.ToAbsoluteUri($"/item/{Id}").ToString();
        _item = await VideoService.GetVideoByIdAsync(Id);
        if (_item is null)
        {
            _loadMessage = $"Item #{Id} was not found.";
            return;
        }
        _media = _item.GetAllMedia();
        if (!string.IsNullOrEmpty(_item.Category))
        {
            _backUrl = VideoCategories.GetUrl(_item.Category);
            _backLabel = $"Back to {_item.Category}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _nativeShareSupported = await JS.InvokeAsync<bool>("appShareSupported");
                if (_nativeShareSupported) StateHasChanged();
            }
            catch { /* JS not ready — ignore */ }

            if (!string.IsNullOrEmpty(MediaQuery) && _lightbox is not null && _autoOpened != MediaQuery)
            {
                _autoOpened = MediaQuery;
                await _lightbox.OpenByFileNameAsync(MediaQuery);
            }
        }
    }

    private async Task NativeShare()
    {
        if (_item is null) return;
        var descShort = (_item.Description ?? "").Replace("\n", " ").Replace("\r", " ").Trim();
        if (descShort.Length > 200) descShort = descShort.Substring(0, 200) + "…";
        await JS.InvokeAsync<bool>("appShare", _item.Title, descShort, _pageUrl);
    }

    private async Task OpenLightbox(int idx)
    {
        if (_lightbox is not null) await _lightbox.OpenAtAsync(idx);
    }

    private void OnLightboxClosed()
    {
        // strip ?m= from URL without reloading
        _autoOpened = null;
        Nav.NavigateTo($"/item/{Id}", forceLoad: false, replace: true);
    }

    private async Task CopyPageLink()
    {
        var absolute = Nav.ToAbsoluteUri($"/item/{Id}").ToString();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", absolute);
        _pageCopied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _pageCopied = false;
        StateHasChanged();
    }
}
