@page "/og/{id:int}"
@model MyHomePage.Pages.OgModel
@{
    Layout = null;
    Response.Headers["Cache-Control"] = "public, max-age=600"; // 10 min — friendly to scrapers
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title</title>

    @* ── Open Graph (Facebook, LinkedIn, iMessage, Discord, Slack, etc.) ── *@
    <meta property="og:site_name" content="My Mountain Adventures" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@Model.Description" />
    <meta property="og:url" content="@Model.CanonicalUrl" />
    <meta property="og:image" content="@Model.ImageUrl" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="@Model.Title" />
    <meta property="og:locale" content="en_US" />
    @if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        <meta property="og:video" content="@Model.VideoUrl" />
        <meta property="og:video:secure_url" content="@Model.VideoUrl" />
        <meta property="og:video:type" content="video/mp4" />
        <meta property="og:video:width" content="1280" />
        <meta property="og:video:height" content="720" />
    }
    <meta property="article:published_time" content="@Model.PublishedAt" />
    @if (Model.HasGps)
    {
        <meta property="og:latitude" content="@Model.Latitude" />
        <meta property="og:longitude" content="@Model.Longitude" />
        <meta property="place:location:latitude" content="@Model.Latitude" />
        <meta property="place:location:longitude" content="@Model.Longitude" />
    }

    @* ── Twitter Card ── *@
    <meta name="twitter:card" content="@(Model.HasVideo && !Model.HasImage ? "player" : "summary_large_image")" />
    <meta name="twitter:title" content="@Model.Title" />
    <meta name="twitter:description" content="@Model.Description" />
    <meta name="twitter:image" content="@Model.ImageUrl" />
    @if (Model.HasVideo && !Model.HasImage)
    {
        <meta name="twitter:player:stream" content="@Model.VideoUrl" />
        <meta name="twitter:player:stream:content_type" content="video/mp4" />
    }

    @* ── Standard ── *@
    <meta name="description" content="@Model.Description" />
    <link rel="canonical" href="@Model.CanonicalUrl" />

    @* Human visitors: JS redirect (scrapers don't execute JS, so they won't follow it) *@
    <style>
        body{margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
             background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff;
             min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:20px}
        .card{max-width:520px}
        img{max-width:100%;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.3)}
        h1{margin:18px 0 6px;font-size:1.6rem}
        p{margin:0 0 14px;opacity:.92;line-height:1.5}
        a{color:#fff;font-weight:600;background:rgba(255,255,255,.18);padding:10px 22px;
          border-radius:10px;text-decoration:none;display:inline-block;transition:background .2s}
        a:hover{background:rgba(255,255,255,.32)}
        small{display:block;margin-top:18px;opacity:.65;font-size:.85rem}
    </style>
</head>
<body>
    <div class="card">
        @if (Model.HasImage)
        {
            <img src="@Model.ImageUrl" alt="@Model.Title" />
        }
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
        <a href="@Model.CanonicalUrl" id="continue">Open full gallery →</a>
        <small>Redirecting…</small>
    </div>
    <script>
        // JS-only redirect — Facebook / WhatsApp / Twitter scrapers won't run this,
        // so they stay on the static OG page. Humans get bounced to the full app.
        setTimeout(function(){ window.location.replace(document.getElementById('continue').href); }, 200);
    </script>
</body>
</html>
