@page "/"
@layout MainLayout
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation

<PageTitle>My Home Page - Mountain Adventures</PageTitle>

<div style="background-image: url('/images/mountains-bg.jpg'); background-size: cover; background-attachment: fixed; background-position: center; padding: 40px 20px; min-height: 90vh;">
    <div style="max-width: 1200px; margin: 0 auto;">
        @if (showSuccessMessage)
        {
            <div style="background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 8px; margin-bottom: 30px; border-left: 4px solid #28a745;">
                <strong>✓ Success!</strong> Welcome back! You have successfully logged in.
            </div>
        }

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px;">
            <a href="/gory" class="category-card">
                <img src="/images/icons/mountains.svg" alt="Mountains" class="category-card-icon" />
                <div class="category-card-title">Mountains</div>
                <div class="category-card-description">Mountain hikes and adventures</div>
            </a>

            <a href="/wspinaczka-skalowa" class="category-card">
                <img src="/images/icons/rock-climbing.svg" alt="Rock Climbing" class="category-card-icon" />
                <div class="category-card-title">Rock Climbing</div>
                <div class="category-card-description">Climbing on rocks and walls</div>
            </a>

            <a href="/bouldering" class="category-card">
                <img src="/images/icons/bouldering.svg" alt="Bouldering" class="category-card-icon" />
                <div class="category-card-title">Bouldering</div>
                <div class="category-card-description">Bouldering and climbing problems</div>
            </a>

            <a href="/prowadzeni-hala" class="category-card">
                <img src="/images/icons/indoor-climbing.svg" alt="Indoor Climbing" class="category-card-icon" />
                <div class="category-card-title">Indoor Climbing</div>
                <div class="category-card-description">Sport climbing in the gym</div>
            </a>

            <a href="/calisthenics" class="category-card">
                <img src="/images/icons/calisthenics.svg" alt="Calisthenics" class="category-card-icon" />
                <div class="category-card-title">Calisthenics</div>
                <div class="category-card-description">Bodyweight strength training</div>
            </a>

            <a href="/running" class="category-card">
                <img src="/images/icons/running.svg" alt="Running" class="category-card-icon" />
                <div class="category-card-title">Running</div>
                <div class="category-card-description">Trail and road runs</div>
            </a>

            <a href="/bicycle" class="category-card">
                <img src="/images/icons/bicycle.svg" alt="Bicycle" class="category-card-icon" />
                <div class="category-card-title">Bicycle</div>
                <div class="category-card-description">Road, gravel and trail rides</div>
            </a>
        </div>
    </div>
</div>

<style>
    .category-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 12px;
        padding: 30px 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
        text-align: center;
    }

    .category-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.25);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.25);
    }

    .category-card-icon {
        width: 96px;
        height: 96px;
        margin: 0 auto 15px auto;
        display: block;
        filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.25));
        transition: transform 0.3s ease;
    }

    .category-card:hover .category-card-icon {
        transform: scale(1.08);
    }

    .category-card-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
        text-shadow: 0 1px 3px rgba(255, 255, 255, 0.6);
    }

    .category-card-description {
        font-size: 0.95rem;
        color: #34495e;
        line-height: 1.5;
        text-shadow: 0 1px 2px rgba(255, 255, 255, 0.5);
    }
</style>

@code {
    private bool showSuccessMessage = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("loginSuccess", out var message))
        {
            showSuccessMessage = true;
        }
    }
}
