@page "/"
@layout MainLayout
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation

<PageTitle>My Home Page - Mountain Adventures</PageTitle>

<div class="home-hero">
    <canvas id="snow-tunnel-canvas" class="home-hero-canvas" aria-hidden="true"></canvas>
    <div class="home-hero-content">
        @if (showSuccessMessage)
        {
            <div style="background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 8px; margin-bottom: 30px; border-left: 4px solid #28a745;">
                <strong>✓ Success!</strong> Welcome back! You have successfully logged in.
            </div>
        }

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px;">
            <a href="/gory" class="category-card">
                <img src="/images/icons/mountains.svg" alt="Mountains" class="category-card-icon" />
                <div class="category-card-title">Mountains</div>
                <div class="category-card-description">Mountain hikes and adventures</div>
            </a>

            <a href="/wspinaczka-skalowa" class="category-card">
                <img src="/images/icons/rock-climbing.svg" alt="Rock Climbing" class="category-card-icon" />
                <div class="category-card-title">Rock Climbing</div>
                <div class="category-card-description">Climbing on rocks and walls</div>
            </a>

            <a href="/bouldering" class="category-card">
                <img src="/images/icons/bouldering.svg" alt="Bouldering" class="category-card-icon" />
                <div class="category-card-title">Bouldering</div>
                <div class="category-card-description">Bouldering and climbing problems</div>
            </a>

            <a href="/prowadzeni-hala" class="category-card">
                <img src="/images/icons/indoor-climbing.svg" alt="Indoor Climbing" class="category-card-icon" />
                <div class="category-card-title">Indoor Climbing</div>
                <div class="category-card-description">Sport climbing in the gym</div>
            </a>

            <a href="/calisthenics" class="category-card">
                <img src="/images/icons/calisthenics.svg" alt="Calisthenics" class="category-card-icon" />
                <div class="category-card-title">Calisthenics</div>
                <div class="category-card-description">Bodyweight strength training</div>
            </a>

            <a href="/running" class="category-card">
                <img src="/images/icons/running.svg" alt="Running" class="category-card-icon" />
                <div class="category-card-title">Running</div>
                <div class="category-card-description">Trail and road runs</div>
            </a>

            <a href="/bicycle" class="category-card">
                <img src="/images/icons/bicycle.svg" alt="Bicycle" class="category-card-icon" />
                <div class="category-card-title">Bicycle</div>
                <div class="category-card-description">Road, gravel and trail rides</div>
            </a>

            <a href="/multisport" class="category-card">
                <img src="/images/icons/multisport.svg" alt="Multi-sport" class="category-card-icon" />
                <div class="category-card-title">Multi-sport</div>
                <div class="category-card-description">Mixed-discipline training days</div>
            </a>
        </div>
    </div>
</div>

<script src="/js/liquid-ripple.js"></script>
<script src="/js/snow-tunnel.js"></script>
<script src="/js/card-tilt.js"></script>
<script src="/js/cursor-trail.js"></script>

<style>
    /* Hero block — owns the mountain backdrop and hosts the snow
       tunnel canvas behind everything else. `position: relative` so
       the canvas can absolute-position itself against this container,
       and `isolation: isolate` keeps the canvas's stacking context
       from competing with the layout shell. */
    .home-hero {
        position: relative;
        isolation: isolate;
        padding: 40px 20px;
        min-height: 90vh;
        background:
            linear-gradient(135deg, rgba(15, 24, 56, 0.55) 0%, rgba(40, 60, 110, 0.35) 50%, rgba(20, 30, 70, 0.55) 100%),
            url('/images/mountains-bg.jpg') center/cover fixed;
        overflow: hidden;
    }
    /* Layer stack inside .home-hero (bottom → top):
         z-index: 0  liquid-ripple-canvas  (injected by JS, distorts mountain bg)
         z-index: 1  #snow-tunnel-canvas   (existing snow tunnel)
         z-index: 2  .home-hero-content    (cards, must stay clickable)
       The fixed cursor-trail canvas sits outside this stacking
       context at z-index 9999 so it always rides on top. */
    .home-hero-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: none; /* clicks fall through to the cards */
        display: block;
    }
    .home-hero-content {
        position: relative;
        z-index: 2;
        max-width: 1200px;
        margin: 0 auto;
    }

    .category-card {
        /* Slightly more opaque than the previous 0.15 — the snow
           tunnel sits behind a darker gradient now, so the cards
           need a brighter backdrop to keep titles legible. */
        background: rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 12px;
        padding: 30px 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
        text-align: center;
    }

    .category-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.44);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.35);
    }

    .category-card-icon {
        width: 96px;
        height: 96px;
        margin: 0 auto 15px auto;
        display: block;
        filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.25));
        transition: transform 0.3s ease;
    }

    .category-card:hover .category-card-icon {
        transform: scale(1.08);
    }

    .category-card-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
        text-shadow: 0 1px 3px rgba(255, 255, 255, 0.6);
    }

    .category-card-description {
        font-size: 0.95rem;
        color: #34495e;
        line-height: 1.5;
        text-shadow: 0 1px 2px rgba(255, 255, 255, 0.5);
    }
</style>

@code {
    private bool showSuccessMessage = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("loginSuccess", out var message))
        {
            showSuccessMessage = true;
        }
    }
}
