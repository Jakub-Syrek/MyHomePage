@page "/embed/{VideoId:int}"
@layout EmbedLayout
@inject VideoService VideoService

<PageTitle>@(video?.Title ?? "Video")</PageTitle>

@if (video != null)
{
    <video controls preload="metadata" playsinline autoplay style="width: 100%; height: 100%; background: #000; object-fit: contain;">
        <source src="/videos/@video.Id/@video.FileName" type="video/mp4" />
    </video>
}
else if (notFound)
{
    <div style="display: flex; align-items: center; justify-content: center; height: 100vh; color: white; font-family: sans-serif;">
        Video not found
    </div>
}

@code {
    [Parameter]
    public int VideoId { get; set; }

    private Video? video;
    private bool notFound = false;

    protected override async Task OnInitializedAsync()
    {
        video = await VideoService.GetVideoByIdAsync(VideoId);
        notFound = video == null;
    }
}
