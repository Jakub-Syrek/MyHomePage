@page "/admin/strava"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MyHomePage.Abstractions
@using MyHomePage.Models
@inject IStravaTokenStore TokenStore
@inject IStravaSyncService Sync
@inject ICollectionMergeService MergeService
@inject IJSRuntime Js
@inject NavigationManager Nav
@inject ILogger<AdminStrava> Logger

<PageTitle>Strava - Admin</PageTitle>

<div class="strava-admin">
    <h1>Strava integration</h1>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_tokens is null)
    {
        <section class="card">
            <h2>Not connected</h2>
            <p>Connect a Strava account so new activities can be imported into the gallery.</p>
            <a class="btn primary" href="/auth/strava/login">Connect Strava</a>
        </section>
    }
    else
    {
        <section class="card">
            <h2>Connected</h2>
            <p>
                <strong>Athlete id:</strong> @_tokens.AthleteId<br />
                <strong>Token expires:</strong> @_tokens.ExpiresAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")<br />
                <strong>Scope:</strong> <code>@_tokens.Scope</code>
            </p>
            <button class="btn secondary" @onclick="DisconnectAsync">Disconnect</button>
        </section>

        <section class="card">
            <h2>Recent Strava activities</h2>
            <p class="hint">
                Visiting this page automatically imports the 30 most-recent
                activities as <strong>stumps</strong> — gallery items that
                carry the training metrics and a category-cover placeholder
                but no real photos or videos yet. Open an item and use
                <em>Add media</em> in the editor to attach files later.
            </p>
            @if (_activitiesError is not null)
            {
                <p class="error">@_activitiesError</p>
            }
            else if (_activities.Count == 0)
            {
                <p>No activities loaded yet.</p>
            }
            else
            {
                <ul class="activity-list">
                    @foreach (var activity in _activities)
                    {
                        var activityId = activity.Id;
                        var localStart = activity.StartDate.ToLocalTime();
                        var isSelected = _selectedActivityIds.Contains(activityId);
                        <li class="@(isSelected ? "selected" : "")">
                            <label class="merge-tick" title="Tick to merge this activity with others">
                                <input type="checkbox"
                                       checked="@isSelected"
                                       @onchange="@(e => ToggleActivitySelection(activityId, (bool?)e.Value ?? false))" />
                                <span class="merge-tick-box" aria-hidden="true">
                                    @if (isSelected) { <span>✓</span> }
                                </span>
                            </label>
                            <div class="activity-main">
                                <strong>@activity.Name</strong>
                                <span class="muted"> · @activity.Type · @localStart.ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <div class="actions">
                                <button class="btn small primary"
                                        @onclick="() => ImportAsync(activityId)"
                                        disabled="@_busy">Import as gallery item</button>
                            </div>
                        </li>
                    }
                </ul>
            }
            <div class="actions-row">
                <button class="btn secondary" @onclick="LoadActivitiesAsync" disabled="@_busy">
                    Refresh list
                </button>
                <button class="btn primary" @onclick="SyncRecentAsync" disabled="@_busy">
                    @if (_isSyncing) { <span>Syncing…</span> }
                    else { <span>📥 Re-import recent (last 30)</span> }
                </button>
                <button class="btn secondary" @onclick="RefreshCoversAsync" disabled="@_busy">
                    @if (_isRefreshingCovers) { <span>Refreshing…</span> }
                    else { <span>🖼️ Refresh stump covers</span> }
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_syncSummary))
            {
                <p class="sync-summary @(_syncError ? "err" : "ok")">@_syncSummary</p>
            }
        </section>

        @if (!string.IsNullOrEmpty(_status))
        {
            <p class="status">@_status</p>
        }
    }

    @if (_selectedActivityIds.Count > 0)
    {
        <div class="merge-bar" role="status" aria-live="polite">
            <div class="merge-bar-info">
                <strong>@_selectedActivityIds.Count</strong> Strava activities selected — pick at least 2 to combine.
            </div>
            <div class="merge-bar-buttons">
                <button class="btn secondary" @onclick="ClearSelection" disabled="@_mergeRunning">Clear</button>
                <button class="btn primary"
                        @onclick="OpenMergeDialog"
                        disabled="@(_selectedActivityIds.Count < 2 || _mergeRunning || _busy)">
                    ⇄ Merge @_selectedActivityIds.Count into one
                </button>
            </div>
        </div>
    }

    @if (_mergeDialogOpen)
    {
        <div class="merge-modal-backdrop" @onclick="CloseMergeDialog">
            <div class="merge-modal" @onclick:stopPropagation>
                <h2>Merge @_selectedActivityIds.Count Strava activities</h2>
                <p class="hint">
                    Each selected activity is first imported into the gallery (or
                    matched to an existing stump), then everything is rolled up
                    into one multi-sport collection. Original per-activity entries
                    are removed; the new one keeps a clickable Strava link for
                    every source and a generated <code>summary.md</code>.
                </p>
                <label class="merge-field">
                    <span>Title</span>
                    <input type="text" @bind="_mergeTitle" maxlength="120"
                           placeholder="Multi-sport day" />
                </label>
                <label class="merge-field">
                    <span>Description (optional)</span>
                    <textarea rows="3" maxlength="600" @bind="_mergeDescription"
                              placeholder="What ties these sessions together?"></textarea>
                </label>
                @if (!string.IsNullOrEmpty(_mergeError))
                {
                    <div class="merge-modal-error">@_mergeError</div>
                }
                @if (!string.IsNullOrEmpty(_mergeProgress))
                {
                    <div class="merge-progress">@_mergeProgress</div>
                }
                <div class="merge-modal-actions">
                    <button class="btn secondary" @onclick="CloseMergeDialog" disabled="@_mergeRunning">Cancel</button>
                    <button class="btn primary"
                            @onclick="ConfirmMergeAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_mergeTitle) || _mergeRunning)">
                        @(_mergeRunning ? "Merging…" : "Merge")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .strava-admin { max-width: 920px; margin: 60px auto; padding: 0 24px; }
    .strava-admin h1 { font-size: 1.8rem; margin-bottom: 24px; color: #1f2937; }
    .strava-admin .card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 24px 28px;
        margin-bottom: 18px;
        box-shadow: 0 6px 18px rgba(20, 30, 60, 0.06);
    }
    .strava-admin .card h2 { margin-top: 0; color: #2c3e50; font-size: 1.15rem; }
