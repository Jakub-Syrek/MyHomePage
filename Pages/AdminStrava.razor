        font-variant-numeric: tabular-nums;
    }
    .strava-admin .merge-modal-actions {
        display: flex; justify-content: flex-end; gap: 8px;
    }
</style>

@code {
    private StravaTokenSet? _tokens;
    private IReadOnlyList<StravaActivity> _activities = Array.Empty<StravaActivity>();
    private string? _activitiesError;
    private string? _status;
    private bool _loading = true;
    private bool _busy;

    private bool _isSyncing;
    private bool _isRefreshingCovers;
    private string? _syncSummary;
    private bool _syncError;
    private bool _autoSyncFired;

    protected override async Task OnInitializedAsync()
    {
        // Token load is light + idempotent — safe to run during the
        // prerender pass. The heavy auto-sync is deferred to
        // OnAfterRenderAsync(firstRender=true) so it fires exactly once
        // per page lifetime instead of twice (prerender + client init).
        _tokens = await TokenStore.LoadAsync();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_autoSyncFired) return;
        if (_tokens is null) return;

        _autoSyncFired = true;

        // Auto-import on entry: every visit to /admin/strava sweeps the
        // 30 most-recent activities into the gallery as stumps. New
        // ones get a category-cover placeholder; the operator adds
        // real photos / videos later via the editor. Dedup happens
        // inside StravaSyncService under an ImportLock so concurrent
        // callers (webhook, fast re-render) can never duplicate an
        // activity even if their snapshots overlap.
        await SyncRecentAsync(autoTriggered: true);

        // Heal any stump whose cover.jpg got out of sync with its
        // current category (typically when an activity was imported
        // before a new category mapping shipped). Cheap idempotent
        // file copy per stump — no-op when the cover already matches.
        try
        {
            await Sync.RefreshStumpCoversAsync();
        }
        catch (Exception ex)
        {
            _status = $"Cover refresh failed: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task RefreshCoversAsync()
    {
        if (_isRefreshingCovers) return;
        _isRefreshingCovers = true;
        _busy = true;
        _status = "Refreshing stump covers…";
        StateHasChanged();
        try
        {
            var refreshed = await Sync.RefreshStumpCoversAsync();
            _status = $"✅ Re-seeded covers for {refreshed} stump(s).";
        }
        catch (Exception ex)
        {
            _status = $"Cover refresh failed: {ex.Message}";
        }
        finally
        {
            _isRefreshingCovers = false;
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task LoadActivitiesAsync()
    {
        _busy = true;
        _activitiesError = null;
        StateHasChanged();

        var result = await Sync.ListRecentActivitiesAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _activities = result.Value;
        }
        else
        {
            _activitiesError = result.Message;
            _activities = Array.Empty<StravaActivity>();
        }
        _busy = false;
        StateHasChanged();
    }

    private Task SyncRecentAsync() => SyncRecentAsync(autoTriggered: false);

    private async Task SyncRecentAsync(bool autoTriggered)
    {
        if (_isSyncing) return;

        _isSyncing = true;
        _busy = true;
        _syncSummary = autoTriggered
            ? "Auto-importing recent activities as stumps…"
            : "Syncing recent activities…";
        _syncError = false;
        StateHasChanged();

        try
        {
            var result = await Sync.SyncRecentAsync(perPage: 30, enforcePrivacyFilter: false);
            _syncError = !result.IsSuccess;
            if (result.IsSuccess && result.Value is not null)
            {
                var summary = result.Value;
                var verb = autoTriggered ? "Auto-imported" : "Imported";
                _syncSummary = summary.Imported > 0
                    ? $"✅ {verb} {summary.Imported} new stump(s). " +
                      $"Inspected {summary.Inspected}, skipped {summary.Skipped} already in gallery, " +
                      $"failed {summary.Failed}. Open one and use \"Add media\" to attach photos / videos."
                    : $"Nothing new — inspected {summary.Inspected}, " +
                      $"all {summary.Skipped} already in gallery.";

                // Refresh the activity list so the imported ones are visible
                await LoadActivitiesAsync();
            }
            else
            {
                _syncSummary = $"Sync failed: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _syncError = true;
            _syncSummary = $"Sync threw: {ex.Message}";
        }
        finally
        {
            _isSyncing = false;
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task ImportAsync(long activityId)
    {
        _busy = true;
        _status = $"Importing activity {activityId}…";
        StateHasChanged();

        try
        {
            var result = await Sync.ImportActivityAsync(activityId, enforcePrivacyFilter: false);
            if (result.IsSuccess && result.Value is not null)
            {
                _status = $"Imported activity {activityId} as gallery item #{result.Value.Id}. Opening editor…";
                StateHasChanged();
                Nav.NavigateTo($"/edit-video/{result.Value.Id}", forceLoad: false);
                return;
            }

            _status = $"Import failed: {result.Message}";
        }
        catch (Exception ex)
        {
            _status = $"Import threw: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task DisconnectAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Disconnect Strava? Tokens will be removed."))
            return;
        await TokenStore.DeleteAsync();
        _tokens = null;
        _activities = Array.Empty<StravaActivity>();
        _status = "Strava disconnected.";
    }

    // ── Merge-from-Strava-list feature ──────────────────────────────────────

    /// <summary>
    /// Strava activity ids ticked for the multi-sport merge, in selection
    /// order. Order matters — the first entry's cover is used as the
    /// fallback placeholder for the new master collection when no source
    /// carries user-added media.
    /// </summary>
    private readonly List<long> _selectedActivityIds = new();

    private bool _mergeDialogOpen;
    private bool _mergeRunning;
    private string _mergeTitle = string.Empty;
    private string _mergeDescription = string.Empty;
    private string? _mergeError;
    private string? _mergeProgress;

    private void ToggleActivitySelection(long activityId, bool checkedNow)
    {
        if (checkedNow)
        {
            if (!_selectedActivityIds.Contains(activityId))
            {
                _selectedActivityIds.Add(activityId);
            }
        }
        else
        {
            _selectedActivityIds.Remove(activityId);
        }
    }

    private void ClearSelection() => _selectedActivityIds.Clear();

    private void OpenMergeDialog()
    {
        if (_selectedActivityIds.Count < 2) return;
        var startDates = _activities
            .Where(a => _selectedActivityIds.Contains(a.Id))
            .Select(a => a.StartDate.ToLocalTime())
            .OrderBy(d => d)
            .ToList();
        _mergeTitle = startDates.Count > 0
            ? $"Multi-sport — {startDates.First():MMM d, yyyy}"
            : "Multi-sport";
        _mergeDescription = string.Empty;
        _mergeError = null;
        _mergeProgress = null;
        _mergeDialogOpen = true;
    }

    private void CloseMergeDialog()
    {
        if (_mergeRunning) return;
        _mergeDialogOpen = false;
    }

    /// <summary>
    /// Imports every selected Strava activity (the import service is idempotent
    /// and returns the existing stump if one is already in the gallery), then
    /// merges all of them into a single new collection via
    /// <see cref="ICollectionMergeService"/>. Redirects to the merged item's
    /// editor on success so the operator can attach media right away.
    /// </summary>
    private async Task ConfirmMergeAsync()
    {
        if (_selectedActivityIds.Count < 2 || string.IsNullOrWhiteSpace(_mergeTitle)) return;

        _mergeRunning = true;
        _mergeError = null;
        _mergeProgress = "Importing Strava activities…";
        StateHasChanged();

        var importedVideoIds = new List<int>();
        var failures = new List<string>();
        var activityIdsInOrder = _selectedActivityIds.ToList();

        try
        {
            for (var i = 0; i < activityIdsInOrder.Count; i++)
            {
                var activityId = activityIdsInOrder[i];
                _mergeProgress = $"Importing activity {i + 1} of {activityIdsInOrder.Count} (id {activityId})…";
                StateHasChanged();

                var imported = await Sync.ImportActivityAsync(activityId, enforcePrivacyFilter: false);
                if (imported.IsSuccess && imported.Value is not null)
                {
                    importedVideoIds.Add(imported.Value.Id);
                }
                else
                {
                    failures.Add($"#{activityId}: {imported.Message}");
                    Logger.LogWarning(
                        "Strava merge: could not import activity {ActivityId}: {Error}",
                        activityId, imported.Message);
                }
            }

            if (importedVideoIds.Count < 2)
            {
                _mergeError = "Need at least two activities to merge. " +
                              (failures.Count > 0 ? $"Errors: {string.Join("; ", failures)}" : "");
                return;
            }

            _mergeProgress = $"Combining {importedVideoIds.Count} collections into one…";
            StateHasChanged();

            var merge = await MergeService.MergeAsync(
                importedVideoIds, _mergeTitle.Trim(), _mergeDescription?.Trim() ?? string.Empty);

            if (!merge.IsSuccess)
            {
                _mergeError = $"Merge failed: {merge.Message}";
                return;
            }

            _mergeDialogOpen = false;
            _mergeRunning = false;
            _selectedActivityIds.Clear();
            StateHasChanged();
            Nav.NavigateTo($"/edit-video/{merge.Value}", forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while merging Strava activities");
            _mergeError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _mergeRunning = false;
            _mergeProgress = null;
            StateHasChanged();
        }
    }
}
