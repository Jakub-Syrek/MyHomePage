@page "/admin/strava"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MyHomePage.Abstractions
@using MyHomePage.Models
@inject IStravaTokenStore TokenStore
@inject IStravaSyncService Sync
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Strava - Admin</PageTitle>

<div class="strava-admin">
    <h1>Strava integration</h1>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_tokens is null)
    {
        <section class="card">
            <h2>Not connected</h2>
            <p>Connect a Strava account so new activities can be imported into the gallery.</p>
            <a class="btn primary" href="/auth/strava/login">Connect Strava</a>
        </section>
    }
    else
    {
        <section class="card">
            <h2>Connected</h2>
            <p>
                <strong>Athlete id:</strong> @_tokens.AthleteId<br />
                <strong>Token expires:</strong> @_tokens.ExpiresAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")<br />
                <strong>Scope:</strong> <code>@_tokens.Scope</code>
            </p>
            <button class="btn secondary" @onclick="DisconnectAsync">Disconnect</button>
        </section>

        <section class="card">
            <h2>Recent Strava activities</h2>
            <p class="hint">
                Visiting this page automatically imports the 30 most-recent
                activities as <strong>stumps</strong> — gallery items that
                carry the training metrics and a category-cover placeholder
                but no real photos or videos yet. Open an item and use
                <em>Add media</em> in the editor to attach files later.
            </p>
            @if (_activitiesError is not null)
            {
                <p class="error">@_activitiesError</p>
            }
            else if (_activities.Count == 0)
            {
                <p>No activities loaded yet.</p>
            }
            else
            {
                <ul class="activity-list">
                    @foreach (var activity in _activities)
                    {
                        var activityId = activity.Id;
                        var localStart = activity.StartDate.ToLocalTime();
                        <li>
                            <div>
                                <strong>@activity.Name</strong>
                                <span class="muted"> · @activity.Type · @localStart.ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <div class="actions">
                                <button class="btn small primary"
                                        @onclick="() => ImportAsync(activityId)"
                                        disabled="@_busy">Import as gallery item</button>
                            </div>
                        </li>
                    }
                </ul>
            }
            <div class="actions-row">
                <button class="btn secondary" @onclick="LoadActivitiesAsync" disabled="@_busy">
                    Refresh list
                </button>
                <button class="btn primary" @onclick="SyncRecentAsync" disabled="@_busy">
                    @if (_isSyncing) { <span>Syncing…</span> }
                    else { <span>📥 Re-import recent (last 30)</span> }
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_syncSummary))
            {
                <p class="sync-summary @(_syncError ? "err" : "ok")">@_syncSummary</p>
            }
        </section>

        @if (!string.IsNullOrEmpty(_status))
        {
            <p class="status">@_status</p>
        }
    }
</div>

<style>
    .strava-admin { max-width: 920px; margin: 60px auto; padding: 0 24px; }
    .strava-admin h1 { font-size: 1.8rem; margin-bottom: 24px; color: #1f2937; }
    .strava-admin .card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 24px 28px;
        margin-bottom: 18px;
        box-shadow: 0 6px 18px rgba(20, 30, 60, 0.06);
    }
    .strava-admin .card h2 { margin-top: 0; color: #2c3e50; font-size: 1.15rem; }
    .strava-admin .btn {
        display: inline-block;
        padding: 9px 18px;
        border-radius: 8px;
        border: 1px solid transparent;
        cursor: pointer;
        font-weight: 600;
        font-family: inherit;
        font-size: 0.95rem;
        text-decoration: none;
    }
    .strava-admin .btn.primary { background: #FC4C02; color: #fff; }
    .strava-admin .btn.primary:hover { filter: brightness(1.08); }
    .strava-admin .btn.secondary { background: #fff; color: #4a5568; border-color: #e2e8f0; }
    .strava-admin .btn.small { padding: 6px 12px; font-size: 0.85rem; }
    .strava-admin .activity-list { list-style: none; padding: 0; }
    .strava-admin .activity-list li {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
        flex-wrap: wrap;
    }
    .strava-admin .activity-list .muted { color: #6b7280; font-weight: 400; }
    .strava-admin .status { color: #4a5568; margin-top: 12px; }
    .strava-admin .error { color: #b91c1c; }
    .strava-admin .hint {
        background: rgba(59, 130, 246, 0.08);
        border-left: 3px solid #3b82f6;
        padding: 10px 14px;
        border-radius: 0 8px 8px 0;
        color: #1e3a8a;
        font-size: 0.92rem;
        margin: 4px 0 14px;
    }
    .strava-admin .hint strong { color: #1d4ed8; }
    .strava-admin .hint em { color: #4338ca; font-style: normal; font-weight: 500; }

    .strava-admin .actions-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
    }
    .strava-admin .sync-summary {
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 0.92rem;
        font-variant-numeric: tabular-nums;
    }
    .strava-admin .sync-summary.ok {
        background: rgba(34, 197, 94, 0.10);
        color: #166534;
        border: 1px solid rgba(34, 197, 94, 0.25);
    }
    .strava-admin .sync-summary.err {
        background: rgba(239, 68, 68, 0.10);
        color: #991b1b;
        border: 1px solid rgba(239, 68, 68, 0.25);
    }
</style>

@code {
    private StravaTokenSet? _tokens;
    private IReadOnlyList<StravaActivity> _activities = Array.Empty<StravaActivity>();
    private string? _activitiesError;
    private string? _status;
    private bool _loading = true;
    private bool _busy;

    private bool _isSyncing;
    private string? _syncSummary;
    private bool _syncError;
    private bool _autoSyncFired;

    protected override async Task OnInitializedAsync()
    {
        // Token load is light + idempotent — safe to run during the
        // prerender pass. The heavy auto-sync is deferred to
        // OnAfterRenderAsync(firstRender=true) so it fires exactly once
        // per page lifetime instead of twice (prerender + client init).
        _tokens = await TokenStore.LoadAsync();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_autoSyncFired) return;
        if (_tokens is null) return;

        _autoSyncFired = true;

        // Auto-import on entry: every visit to /admin/strava sweeps the
        // 30 most-recent activities into the gallery as stumps. New
        // ones get a category-cover placeholder; the operator adds
        // real photos / videos later via the editor. Dedup happens
        // inside StravaSyncService under an ImportLock so concurrent
        // callers (webhook, fast re-render) can never duplicate an
        // activity even if their snapshots overlap.
        await SyncRecentAsync(autoTriggered: true);
    }

    private async Task LoadActivitiesAsync()
    {
        _busy = true;
        _activitiesError = null;
        StateHasChanged();

        var result = await Sync.ListRecentActivitiesAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _activities = result.Value;
        }
        else
        {
            _activitiesError = result.Message;
            _activities = Array.Empty<StravaActivity>();
        }
        _busy = false;
        StateHasChanged();
    }

    private Task SyncRecentAsync() => SyncRecentAsync(autoTriggered: false);

    private async Task SyncRecentAsync(bool autoTriggered)
    {
        if (_isSyncing) return;

        _isSyncing = true;
        _busy = true;
        _syncSummary = autoTriggered
            ? "Auto-importing recent activities as stumps…"
            : "Syncing recent activities…";
        _syncError = false;
        StateHasChanged();

        try
        {
            var result = await Sync.SyncRecentAsync(perPage: 30, enforcePrivacyFilter: false);
            _syncError = !result.IsSuccess;
            if (result.IsSuccess && result.Value is not null)
            {
                var summary = result.Value;
                var verb = autoTriggered ? "Auto-imported" : "Imported";
                _syncSummary = summary.Imported > 0
                    ? $"✅ {verb} {summary.Imported} new stump(s). " +
                      $"Inspected {summary.Inspected}, skipped {summary.Skipped} already in gallery, " +
                      $"failed {summary.Failed}. Open one and use \"Add media\" to attach photos / videos."
                    : $"Nothing new — inspected {summary.Inspected}, " +
                      $"all {summary.Skipped} already in gallery.";

                // Refresh the activity list so the imported ones are visible
                await LoadActivitiesAsync();
            }
            else
            {
                _syncSummary = $"Sync failed: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _syncError = true;
            _syncSummary = $"Sync threw: {ex.Message}";
        }
        finally
        {
            _isSyncing = false;
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task ImportAsync(long activityId)
    {
        _busy = true;
        _status = $"Importing activity {activityId}…";
        StateHasChanged();

        try
        {
            var result = await Sync.ImportActivityAsync(activityId, enforcePrivacyFilter: false);
            if (result.IsSuccess && result.Value is not null)
            {
                _status = $"Imported activity {activityId} as gallery item #{result.Value.Id}. Opening editor…";
                StateHasChanged();
                Nav.NavigateTo($"/edit-video/{result.Value.Id}", forceLoad: false);
                return;
            }

            _status = $"Import failed: {result.Message}";
        }
        catch (Exception ex)
        {
            _status = $"Import threw: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task DisconnectAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Disconnect Strava? Tokens will be removed."))
            return;
        await TokenStore.DeleteAsync();
        _tokens = null;
        _activities = Array.Empty<StravaActivity>();
        _status = "Strava disconnected.";
    }
}
