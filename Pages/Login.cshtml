@page
@using MyHomePage.Pages
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - My Home Page</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<style>
    html, body { margin: 0; padding: 0; }
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        display: flex;
        justify-content: center;
        align-items: flex-start; /* top-aligned so card stays above on-screen keyboard */
        padding: 6vh 16px 24px; /* breathing room from the very top */
        min-height: 100vh;
        min-height: 100dvh; /* dynamic viewport — shrinks when mobile keyboard appears */
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .login-card {
        max-width: 400px;
        width: 100%;
        padding: 24px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }
    .login-card h2 { text-align: center; color: #2c3e50; margin: 0 0 24px; }
    .login-card label { display: block; margin-bottom: 6px; font-weight: 600; color: #2d3748; font-size: 0.92rem; }
    .login-card input {
        width: 100%; padding: 12px; border: 2px solid #ecf0f1;
        border-radius: 8px; font-size: 1rem; box-sizing: border-box;
        transition: border-color 0.18s, box-shadow 0.18s;
        font-family: inherit;
    }
    .login-card input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102,126,234,0.18);
    }
    .login-card .field { margin-bottom: 16px; }
    .login-card .submit {
        width: 100%; padding: 13px; border: 0; border-radius: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white; font-weight: 600; cursor: pointer; font-size: 1rem;
        font-family: inherit;
        margin-top: 4px;
    }
    .login-card .submit:hover { filter: brightness(1.08); }
    .divider {
        display: flex; align-items: center; gap: 10px;
        margin: 18px 0 12px; color: #94a3b8; font-size: 0.85rem;
    }
    .divider::before, .divider::after {
        content: ""; flex: 1; height: 1px; background: #e2e8f0;
    }
    .passkey-btn {
        width: 100%; padding: 12px; border: 2px solid #667eea; border-radius: 8px;
        background: white; color: #4338ca; font-weight: 600; font-size: 0.98rem;
        cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        font-family: inherit; transition: background 0.18s, box-shadow 0.18s;
    }
    .passkey-btn:hover:not([disabled]) {
        background: #eef2ff; box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
    }
    .passkey-btn[disabled] { opacity: 0.6; cursor: not-allowed; }
    .passkey-error {
        margin-top: 10px; color: #b91c1c; font-size: 0.9rem; text-align: center;
    }
    @@media (max-width: 600px) {
        body { padding-top: 3vh; }
        .login-card { padding: 18px; }
    }
</style>
<body>
    <div class="login-card">
        <h2>Login</h2>

        <form method="post" action="/login">
            @Html.AntiForgeryToken()
            <div class="field">
                <label for="email">Email</label>
                <input id="email" name="Input.Email" type="email"
                       autocomplete="email"
                       inputmode="email"
                       autocapitalize="none"
                       autocorrect="off"
                       spellcheck="false"
                       autofocus
                       required />
            </div>

            <div class="field">
                <label for="password">Password</label>
                <input id="password" name="Input.Password" type="password"
                       autocomplete="current-password"
                       required />
            </div>

            <button type="submit" class="submit">Sign in</button>
        </form>

        <div style="text-align:center; margin-top:12px; font-size:0.9rem;">
            <a href="/forgotpassword" style="color:#4338ca; text-decoration:none;">Forgot your password?</a>
        </div>

        <div class="divider" role="separator" aria-hidden="true">
            <span>or</span>
        </div>

        <button type="button" id="passkey-login-btn" class="passkey-btn" hidden>
            <span aria-hidden="true">🔑</span>
            <span>Sign in with passkey / fingerprint</span>
        </button>
        <p id="passkey-error" class="passkey-error" role="alert" hidden></p>
    </div>

    <script src="/js/webauthn.js"></script>
    <script>
        (function () {
            const button = document.getElementById("passkey-login-btn");
            const error = document.getElementById("passkey-error");
            const emailInput = document.getElementById("email");
            if (!button || !window.aisgWebAuthn || !window.aisgWebAuthn.isSupported()) {
                return;
            }
            button.hidden = false;
            button.addEventListener("click", async () => {
                error.hidden = true;
                error.textContent = "";
                button.disabled = true;
                try {
                    await window.aisgWebAuthn.loginWithPasskey(emailInput?.value || null);
                    window.location.assign("/?loginSuccess=true");
                } catch (ex) {
                    error.textContent = ex?.message || "Passkey sign-in failed.";
                    error.hidden = false;
                    button.disabled = false;
                }
            });
        })();
    </script>
</body>
</html>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
