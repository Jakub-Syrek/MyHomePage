    .stats-effort-note {
        font-size: 0.85rem !important;
        color: #6b7280 !important;
        margin-top: 8px !important;
    }

    .stats-streaks {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 22px;
    }
    .stats-streak {
        flex: 1 1 200px;
        padding: 16px 22px;
        background: linear-gradient(135deg, rgba(102,126,234,0.95) 0%, rgba(118,75,162,0.95) 100%);
        color: white;
        border-radius: 14px;
        text-align: center;
        box-shadow: 0 12px 28px rgba(102, 126, 234, 0.32);
    }
    .stats-streak strong {
        display: block;
        font-size: 2.2rem;
        font-weight: 800;
    }
    .stats-streak span { opacity: 0.9; font-size: 0.9rem; }

    .stats-section {
        background: rgba(255,255,255,0.92);
        border-radius: 16px;
        padding: 22px 24px;
        margin-bottom: 22px;
        box-shadow: 0 10px 26px rgba(20,30,60,0.08);
    }
    .stats-section h2 {
        margin: 0 0 14px;
        font-size: 1.15rem;
        color: #1f2937;
    }

    .stats-chart {
        display: flex;
        align-items: flex-end;
        gap: 6px;
        height: 220px;
        padding-top: 8px;
        overflow-x: auto;
        scrollbar-width: thin;
    }
    .stats-bar-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        min-width: 28px;
        height: 100%;
    }
    .stats-bar {
        width: 100%;
        background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
        border-radius: 6px 6px 0 0;
        min-height: 2px;
        transition: height 0.3s ease;
    }
    .stats-bar-value {
        font-size: 0.7rem;
        font-weight: 600;
        color: #1f2937;
        margin-top: 2px;
        font-variant-numeric: tabular-nums;
    }
    .stats-bar-label {
        font-size: 0.65rem;
        color: #6b7280;
        margin-top: 2px;
        white-space: nowrap;
        transform: rotate(-30deg);
        transform-origin: top left;
    }

    .stats-category-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
    .stats-cat-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
    .stats-cat-name {
        font-weight: 700;
        color: #2c3e50;
        text-decoration: none;
    }
    .stats-cat-name:hover { text-decoration: underline; }
    .stats-cat-meta { color: #6b7280; font-size: 0.88rem; font-variant-numeric: tabular-nums; }
    .stats-cat-bar {
        height: 8px;
        background: rgba(0,0,0,0.05);
        border-radius: 999px;
        margin-top: 4px;
        overflow: hidden;
    }
    .stats-cat-fill {
        height: 100%;
        background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        transition: width 0.3s ease;
    }

    .stats-records {
        width: 100%;
        border-collapse: collapse;
        font-variant-numeric: tabular-nums;
    }
    .stats-records th, .stats-records td {
        padding: 8px 10px;
        text-align: left;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        font-size: 0.92rem;
    }
    .stats-records th {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
    }
    .stats-records-time { font-weight: 700; color: #1f2937; }
    .stats-records a { color: #4338ca; text-decoration: none; }
    .stats-records a:hover { text-decoration: underline; }

    .stats-sessions {
        width: 100%;
        border-collapse: collapse;
        font-variant-numeric: tabular-nums;
    }
    .stats-sessions th, .stats-sessions td {
        padding: 8px 10px;
        text-align: left;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        font-size: 0.9rem;
    }
    .stats-sessions th {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        position: sticky;
        top: 0;
        background: rgba(255,255,255,0.96);
    }
    .stats-sessions tr:hover td { background: rgba(102,126,234,0.06); }
    .stats-sessions .num { text-align: right; white-space: nowrap; }
    .stats-sessions th.num { text-align: right; }
    .stats-sessions .muted { color: #6b7280; }
    .stats-sessions a {
        color: #4338ca;
        text-decoration: none;
        font-weight: 600;
    }
    .stats-sessions a:hover { text-decoration: underline; }
    .stats-sessions-cat {
        font-weight: 500 !important;
        color: #4a5568 !important;
        font-size: 0.85rem;
    }

    @@media (max-width: 700px) {
        .stats-sessions th:nth-child(4),
        .stats-sessions td:nth-child(4),
        .stats-sessions th:nth-child(7),
        .stats-sessions td:nth-child(7),
        .stats-sessions th:nth-child(8),
        .stats-sessions td:nth-child(8) {
            display: none;
        }
    }
</style>

@code {
    private TrainingStats? _stats;
    private IReadOnlyList<Video>? _videos;
    private string _selectedPreset = "all";

    private readonly Dictionary<string, string> _periodPresets = new()
    {
        ["7d"] = "Last 7 days",
        ["30d"] = "Last 30 days",
        ["90d"] = "Last 90 days",
        ["365d"] = "Last 12 months",
        ["all"] = "All time"
    };

    protected override async Task OnInitializedAsync()
    {
        _videos = await VideoService.GetAllVideosAsync();
        RecomputeStats();
    }

    private void SelectPreset(string key)
    {
        if (!_periodPresets.ContainsKey(key)) return;
        if (_selectedPreset == key) return;
        _selectedPreset = key;
        RecomputeStats();
        // Force a re-render explicitly — defensive belt-and-braces in case
        // the @onclick auto-rerender drops the update on a slow connection.
        StateHasChanged();
    }

    private void RecomputeStats()
    {
        if (_videos is null) return;
        var (from, to) = ResolveWindow(_selectedPreset);
        _stats = StatsService.Compute(_videos, from, to);
    }

    private static (DateTime From, DateTime To) ResolveWindow(string preset)
    {
        var now = DateTime.UtcNow;
        return preset switch
        {
            "7d" => (now.AddDays(-7), now),
            "30d" => (now.AddDays(-30), now),
            "90d" => (now.AddDays(-90), now),
            "365d" => (now.AddDays(-365), now),
            _ => (DateTime.SpecifyKind(DateTime.MinValue.AddDays(1), DateTimeKind.Utc), now)
        };
    }

    private static string FormatDistance(double meters) =>
        meters >= 1000
            ? $"{meters / 1000:F1} km"
            : $"{meters:F0} m";

    private static string FormatDistanceOrDash(double? meters) =>
        meters is null || meters <= 0 ? "—" : FormatDistance(meters.Value);

    /// <summary>
    /// Buckets an average per-session Strava Relative Effort value into
    /// the same bands Strava uses on its training-log heat-map. Returns
    /// a short label and a hex colour for the inline hint pill.
    /// </summary>
    private static (string Band, string Colour) ClassifyEffort(double avgEffort) => avgEffort switch
    {
        < 50 => ("easy", "#10b981"),
        < 100 => ("moderate", "#3b82f6"),
        < 150 => ("hard", "#f59e0b"),
        < 250 => ("very hard", "#ef4444"),
        _ => ("extreme", "#7c3aed")
    };

    private static string EffortTooltip(double avgEffort, int sessionsWithEffort)
    {
        if (sessionsWithEffort == 0) return "Strava Relative Effort score";
        return $"Sum of Strava Relative Effort across {sessionsWithEffort} session(s). " +
               $"Average per session: {avgEffort:F0}. Click \"What's an effort score?\" below for the scale.";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 24)
            return $"{(int)duration.TotalDays}d {duration.Hours:00}h";
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes:00}m";
        return $"{duration.Minutes}m {duration.Seconds:00}s";
    }
}
