@page "/stats"
@layout MainLayout
@using MyHomePage.Abstractions
@using MyHomePage.Models
@inject IVideoService VideoService
@inject ITrainingStatsService StatsService

<PageTitle>Training stats - My Mountain Adventures</PageTitle>

<div class="stats-page">
    <header class="stats-hero">
        <h1>📊 Training stats</h1>
        <p>Aggregated metrics from every Strava-imported session in the gallery.</p>
        <div class="stats-period-bar">
            @foreach (var preset in _periodPresets)
            {
                <button type="button"
                        class="stats-period @(preset.Key == _selectedPreset ? "active" : "")"
                        @onclick="() => SelectPreset(preset.Key)"
                        @onclick:preventDefault
                        @onclick:stopPropagation>
                    @preset.Value
                </button>
            }
        </div>
        @if (_stats is not null && _videos is not null)
        {
            var allWithTraining = _videos.Count(v => v.Training is not null);
            var outsideWindow = allWithTraining - _stats.SessionCount;
            <p class="stats-range">
                <strong>@_periodPresets[_selectedPreset]</strong> ·
                window <strong>@_stats.FromUtc.ToString("yyyy-MM-dd")</strong> →
                <strong>@_stats.ToUtc.ToString("yyyy-MM-dd")</strong> ·
                <strong>@_stats.SessionCount</strong> session@(_stats.SessionCount == 1 ? "" : "s") in window
                <span class="stats-range-meta">
                    @if (outsideWindow > 0)
                    {
                        <span>(@outsideWindow excluded, @allWithTraining total)</span>
                    }
                    else
                    {
                        <span>(@allWithTraining total with training data)</span>
                    }
                </span>
            </p>
        }
    </header>

    @if (_stats is null)
    {
        <div class="stats-loading">
            <div class="stats-spinner"></div>
            <p>Crunching numbers…</p>
        </div>
    }
    else if (_stats.SessionCount == 0)
    {
        <div class="stats-empty">
            <p>No training sessions in this window. Try a longer period or import a Strava activity from <a href="/admin/strava">the admin page</a>.</p>
        </div>
    }
    else
    {
        <section class="stats-cards">
            <article class="stats-card">
                <span class="stats-card-icon">🏃</span>
                <div>
                    <strong>@_stats.SessionCount</strong>
                    <span>session@(_stats.SessionCount == 1 ? "" : "s")</span>
                </div>
            </article>
            <article class="stats-card">
                <span class="stats-card-icon">📏</span>
                <div>
                    <strong>@FormatDistance(_stats.TotalDistanceMeters)</strong>
                    <span>distance</span>
                </div>
            </article>
            <article class="stats-card">
                <span class="stats-card-icon">⏱</span>
                <div>
                    <strong>@FormatDuration(_stats.TotalDuration)</strong>
                    <span>moving time</span>
                </div>
            </article>
            <article class="stats-card">
                <span class="stats-card-icon">↑</span>
                <div>
                    <strong>@($"{_stats.TotalElevationGainMeters:F0}") m</strong>
                    <span>elevation gain</span>
                </div>
            </article>
            @if (_stats.TotalCalories > 0)
            {
                <article class="stats-card">
                    <span class="stats-card-icon">🔥</span>
                    <div>
                        <strong>@_stats.TotalCalories</strong>
                        <span>kcal</span>
                    </div>
                </article>
            }
            @if (_stats.TotalSufferScore > 0)
            {
                var sessionsWithEffort = (_videos ?? Array.Empty<Video>())
                    .Count(v => v.Training is not null
                                && v.Training.StartTimeUtc >= _stats.FromUtc
                                && v.Training.StartTimeUtc <= _stats.ToUtc
                                && v.Training.SufferScore is > 0);
                var avgEffort = sessionsWithEffort > 0
                    ? _stats.TotalSufferScore / (double)sessionsWithEffort
                    : 0;
                var (effortBand, effortColour) = ClassifyEffort(avgEffort);
                <article class="stats-card stats-card-effort"
                         title="@EffortTooltip(avgEffort, sessionsWithEffort)">
                    <span class="stats-card-icon">💪</span>
                    <div>
                        <strong>@_stats.TotalSufferScore</strong>
                        <span>effort score</span>
                        <small class="stats-card-hint" style="color: @effortColour">
                            @($"~ {avgEffort:F0}/session — {effortBand}")
                        </small>
                    </div>
                </article>
            }
            @if (_stats.TotalPersonalRecords > 0)
            {
                <article class="stats-card">
                    <span class="stats-card-icon">🏆</span>
                    <div>
                        <strong>@_stats.TotalPersonalRecords</strong>
                        <span>personal records</span>
                    </div>
                </article>
            }
        </section>

        @if (_stats.TotalSufferScore > 0)
        {
            <details class="stats-effort-key">
                <summary>
                    <span>What's an <strong>effort score</strong>?</span>
                </summary>
                <p>
                    Strava's <strong>Relative Effort</strong> (historically Suffer Score) — a heart-rate-driven
                    measure of how hard a session was for <em>your</em> body, calibrated to your max HR.
                    The number above sums the score across every session in the selected window.
                </p>
                <ul class="stats-effort-bands">
                    <li><span class="stats-band-dot" style="background:#10b981"></span>
                        <strong>&lt; 50</strong> per session — easy / recovery
                    </li>
                    <li><span class="stats-band-dot" style="background:#3b82f6"></span>
                        <strong>50 – 100</strong> — moderate (typical Z2 run, easy ride)
                    </li>
                    <li><span class="stats-band-dot" style="background:#f59e0b"></span>
                        <strong>100 – 150</strong> — hard (tempo, long run, threshold)
                    </li>
                    <li><span class="stats-band-dot" style="background:#ef4444"></span>
                        <strong>150 – 250</strong> — very hard (race effort, intervals)
                    </li>
                    <li><span class="stats-band-dot" style="background:#7c3aed"></span>
                        <strong>&gt; 250</strong> — extreme (long race / ultra)
                    </li>
                </ul>
                <p class="stats-effort-note">
                    For a weekly load reference: most amateurs sit around <strong>200 – 400</strong>
                    summed per week; competitive athletes <strong>500 – 800+</strong>.
                </p>
            </details>
        }

        <section class="stats-streaks">
            <div class="stats-streak">
                <strong>@_stats.CurrentStreakDays</strong>
                <span>day streak (current)</span>
            </div>
            <div class="stats-streak">
                <strong>@_stats.LongestStreakDays</strong>
                <span>day streak (longest)</span>
            </div>
        </section>

        @if (_stats.WeeklyBuckets.Count > 0)
        {
            <section class="stats-section">
                <h2>Weekly mileage</h2>
                @{
                    var maxDistanceKm = Math.Max(1.0, _stats.WeeklyBuckets.Max(b => b.DistanceMeters) / 1000.0);
                    var barWidth = 100.0 / _stats.WeeklyBuckets.Count;
                }
                <div class="stats-chart">
                    @foreach (var bucket in _stats.WeeklyBuckets)
                    {
                        var km = bucket.DistanceMeters / 1000.0;
                        var heightPct = (km / maxDistanceKm) * 100.0;
                        <div class="stats-bar-wrap"
                             style="width: @($"calc({barWidth:F2}% - 6px)")"
                             title="@($"{bucket.Label}: {km:F1} km · {bucket.SessionCount} session(s)")">
                            <div class="stats-bar" style="height: @($"{heightPct:F1}%")"></div>
                            <span class="stats-bar-value">@($"{km:F0}")</span>
                            <span class="stats-bar-label">@bucket.WeekStartUtc.ToString("dd MMM")</span>
                        </div>
                    }
                </div>
            </section>
        }

        @if (_stats.SessionsByCategory.Count > 0)
        {
            <section class="stats-section">
                <h2>Category breakdown</h2>
                @{
                    var totalSessions = _stats.SessionsByCategory.Values.Sum();
                }
                <ul class="stats-category-list">
                    @foreach (var entry in _stats.SessionsByCategory.OrderByDescending(e => e.Value))
                    {
                        var count = entry.Value;
                        var distance = _stats.DistanceByCategory.TryGetValue(entry.Key, out var d) ? d : 0;
                        var sessionPct = totalSessions == 0 ? 0 : (count * 100.0 / totalSessions);
                        <li>
                            <div class="stats-cat-head">
                                <a class="stats-cat-name" href="@VideoCategories.GetUrl(entry.Key)">
                                    @entry.Key
                                </a>
                                <span class="stats-cat-meta">
                                    @count session@(count == 1 ? "" : "s") ·
                                    @FormatDistance(distance)
                                </span>
                            </div>
                            <div class="stats-cat-bar">
                                <div class="stats-cat-fill" style="width: @($"{sessionPct:F1}%")"></div>
                            </div>
                        </li>
                    }
                </ul>
            </section>
        }

        @if (_stats.RecentRecords.Count > 0)
        {
            <section class="stats-section">
                <h2>🏆 Recent personal records</h2>
                <table class="stats-records">
                    <thead>
                        <tr>
                            <th>Distance</th>
                            <th>Time</th>
                            <th>Date</th>
                            <th>Session</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in _stats.RecentRecords)
                        {
                            <tr>
                                <td><strong>@record.Name</strong></td>
                                <td class="stats-records-time">@FormatDuration(record.Duration)</td>
                                <td>@record.AchievedAtUtc.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <a href="/item/@record.VideoId">@record.SessionTitle</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_videos is not null)
        {
            var sessionsInWindow = _videos
                .Where(v => v.Training is not null
                            && v.Training.StartTimeUtc >= _stats.FromUtc
                            && v.Training.StartTimeUtc <= _stats.ToUtc)
                .OrderByDescending(v => v.Training!.StartTimeUtc)
                .ToList();
            if (sessionsInWindow.Count > 0)
            {
            <section class="stats-section">
                <h2>📋 Sessions in this window (@sessionsInWindow.Count)</h2>
                <table class="stats-sessions">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th class="num">Distance</th>
                            <th class="num">Time</th>
                            <th class="num">HR</th>
                            <th class="num">kcal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in sessionsInWindow)
                        {
                            var training = session.Training!;
                            <tr>
                                <td class="num">@training.StartTimeUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td><a href="/item/@session.Id">@session.Title</a></td>
                                <td>
                                    <a class="stats-sessions-cat"
                                       href="@VideoCategories.GetUrl(session.Category)">
                                        @session.Category
                                    </a>
                                </td>
                                <td class="muted">@training.ActivityType</td>
                                <td class="num">@FormatDistanceOrDash(training.DistanceMeters)</td>
                                <td class="num">@FormatDuration(training.Duration)</td>
                                <td class="num">@(training.AverageHeartRate?.ToString() ?? "—")</td>
                                <td class="num">@(training.Calories is > 0 ? training.Calories.ToString() : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
            }
        }
    }
</div>

<style>
    .stats-page { max-width: 1200px; margin: 30px auto; padding: 0 24px 60px; }
    .stats-hero h1 { margin: 0 0 6px; color: #1f2937; font-size: 2rem; }
    .stats-hero p { margin: 0 0 16px; color: #6b7280; }
    .stats-period-bar {
        display: flex; flex-wrap: wrap; gap: 8px;
        padding: 10px 12px;
        background: rgba(255,255,255,0.65);
        border: 1px solid rgba(255,255,255,0.5);
        backdrop-filter: blur(16px);
        border-radius: 12px;
        margin-bottom: 24px;
    }
    .stats-period {
        padding: 8px 14px;
        border-radius: 999px;
        border: 1px solid rgba(102,126,234,0.25);
        background: white;
        color: #4a5568;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.18s, color 0.18s, transform 0.18s;
        font-family: inherit;
    }
    .stats-period:hover { transform: translateY(-1px); }
    .stats-period.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
    }
    .stats-range {
        margin: 8px 0 22px;
        color: #4a5568;
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
    }
    .stats-range strong { color: #1f2937; }
    .stats-range-meta { color: #9ca3af; }

    .stats-loading, .stats-empty {
        background: rgba(255,255,255,0.85);
        border-radius: 14px;
        padding: 40px;
        text-align: center;
        color: #4a5568;
    }
    .stats-spinner {
        width: 36px; height: 36px;
        margin: 0 auto 12px;
        border: 4px solid rgba(102,126,234,0.2);
        border-top-color: #667eea;
        border-radius: 50%;
        animation: stats-spin 0.8s linear infinite;
    }
    @@keyframes stats-spin { to { transform: rotate(360deg); } }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
        margin-bottom: 18px;
    }
    .stats-card {
        display: flex;
        align-items: center;
        gap: 14px;
        background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,255,255,0.84) 100%);
        border: 1px solid rgba(255,255,255,0.6);
        border-radius: 14px;
        padding: 16px 18px;
        box-shadow: 0 10px 30px rgba(20,30,60,0.10);
    }
    .stats-card-icon {
        font-size: 1.6rem;
        line-height: 1;
    }
    .stats-card strong {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
        color: #1f2937;
    }
    .stats-card span { color: #6b7280; font-size: 0.85rem; }
    .stats-card-hint {
        display: block;
        font-size: 0.72rem;
        font-weight: 600;
        margin-top: 2px;
        letter-spacing: 0.01em;
    }
    .stats-card-effort { cursor: help; }

    .stats-effort-key {
        background: linear-gradient(135deg, rgba(102,126,234,0.06) 0%, rgba(118,75,162,0.06) 100%);
        border: 1px solid rgba(102,126,234,0.18);
        border-radius: 14px;
        padding: 12px 18px;
        margin-bottom: 18px;
        font-size: 0.9rem;
        color: #374151;
    }
    .stats-effort-key > summary {
        cursor: pointer;
        list-style: none;
        font-weight: 600;
        color: #4338ca;
        padding: 4px 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .stats-effort-key > summary::before {
        content: 'ℹ';
        font-size: 1.05rem;
        margin-right: 2px;
    }
    .stats-effort-key > summary::-webkit-details-marker { display: none; }
    .stats-effort-key[open] > summary { margin-bottom: 8px; }
    .stats-effort-key p { margin: 6px 0; line-height: 1.45; }
    .stats-effort-key strong { color: #1f2937; }
    .stats-effort-key em { font-style: italic; color: #4338ca; }
    .stats-effort-bands {
        list-style: none;
        padding: 0;
        margin: 8px 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 6px 18px;
    }
    .stats-effort-bands li {
        display: flex;
        align-items: center;
