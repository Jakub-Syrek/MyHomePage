@page
@using MyHomePage.Pages
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset password - My Home Page</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<style>
    html, body { margin: 0; padding: 0; }
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        display: flex; justify-content: center; align-items: flex-start;
        padding: 6vh 16px 24px;
        min-height: 100vh; min-height: 100dvh;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .card {
        max-width: 460px; width: 100%; padding: 26px;
        background: white; border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }
    .card h2 { text-align: center; color: #2c3e50; margin: 0 0 14px; }
    .card p.intro { color: #4a5568; font-size: 0.93rem; margin: 0 0 16px; }
    .card label { display: block; margin: 10px 0 6px; font-weight: 600; color: #2d3748; font-size: 0.92rem; }
    .card input {
        width: 100%; padding: 12px; border: 2px solid #ecf0f1;
        border-radius: 8px; font-size: 1rem; box-sizing: border-box;
        font-family: inherit;
    }
    .card input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.18); }
    .card .submit {
        width: 100%; padding: 13px; margin-top: 16px; border: 0; border-radius: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white; font-weight: 600; cursor: pointer; font-size: 1rem;
        font-family: inherit;
    }
    .card .submit:hover { filter: brightness(1.08); }
    .card .links { text-align: center; margin-top: 14px; font-size: 0.9rem; }
    .card .links a { color: #4338ca; text-decoration: none; }
    .notice {
        background: #ecfdf5; border: 1px solid #a7f3d0;
        color: #065f46; padding: 12px 14px; border-radius: 8px;
        font-size: 0.93rem; margin-bottom: 14px;
    }
    .err {
        background: #fef2f2; border: 1px solid #fecaca;
        color: #991b1b; padding: 10px 12px; border-radius: 8px;
        font-size: 0.9rem; margin-bottom: 12px;
    }
    .manual {
        background: #fffbeb; border: 1px solid #fde68a;
        color: #92400e; padding: 12px 14px; border-radius: 8px;
        font-size: 0.92rem; margin-bottom: 14px;
    }
    .manual textarea {
        width: 100%; margin-top: 8px; padding: 8px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.85rem; border: 1px solid #fcd34d; border-radius: 6px;
        background: #fef3c7; resize: vertical;
    }
</style>
<body>
    <div class="card">
        <h2>Set a new password</h2>

        @if (Model.IsCompleted && !Model.ManualUpdateRequired)
        {
            <p class="notice">Your password has been updated. You can now sign in with the new password.</p>
            <div class="links"><a href="/login">Continue to sign in →</a></div>
        }
        else if (Model.ManualUpdateRequired)
        {
            <div class="manual">
                <strong>Manual update required.</strong> Your credentials are managed
                through environment variables, which the app can't rewrite at runtime.
                Copy the BCrypt hash below into your hosting platform's
                <code>ADMIN_PASSWORD</code> (or the matching <code>password</code>
                field in <code>ADMIN_USERS</code>) and restart the app.
                <label for="hash">New BCrypt hash (cost 12)</label>
                <textarea id="hash" readonly rows="2">@Model.NewHash</textarea>
            </div>
            <div class="links"><a href="/login">Back to sign in</a></div>
        }
        else
        {
            <p class="intro">
                Pick a strong password — at least 12 characters mixing letters, digits
                and symbols. The new value is stored as a BCrypt hash; the plaintext
                is never written to disk.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="err">@err.ErrorMessage</div>
                }
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Input.Token" value="@Model.Input.Token" />

                <label for="password">New password</label>
                <input id="password" name="Input.Password" type="password"
                       autocomplete="new-password" required minlength="8" />

                <label for="confirm">Confirm new password</label>
                <input id="confirm" name="Input.ConfirmPassword" type="password"
                       autocomplete="new-password" required minlength="8" />

                <button type="submit" class="submit">Update password</button>
            </form>

            <div class="links"><a href="/login">← Back to sign in</a></div>
        }
    </div>
</body>
</html>
