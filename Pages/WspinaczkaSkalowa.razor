@page "/wspinaczka-skalowa"
@layout MainLayout
@using Microsoft.AspNetCore.Components.Authorization
@inject VideoService VideoService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Rock Climbing - My Mountain Adventures</PageTitle>

<div class="gallery-container" style="background-image: url('/images/rock-climbing-bg.jpg'); background-size: 100% 100%;">
    <div class="gallery-header">
        <div>
            <button class="btn-back" @onclick="GoHome">← Back</button>
        </div>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary btn-upload" @onclick="() => showUpload = !showUpload">
                    + Upload New Video
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (showUpload)
    {
        <VideoUploadCategory Category="@VideoCategories.WspinaczkaSkalowa" OnUploadSuccess="RefreshVideos" />
    }

    @if (videos == null)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Loading videos...</p>
        </div>
    }
    else if (videos.Count == 0)
    {
        <div class="empty-state">
            <p>No rock climbing videos yet. Share your climbing moments!</p>
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var video in videos)
            {
                <div class="video-card" @key="video.Id">
                    <div class="card-image">
                        <video controls preload="metadata" playsinline>
                            <source src="/videos/@video.Id/@video.FileName" type="video/mp4" />
                        </video>
                    </div>
                    <div class="card-content">
                        <h3><a href="/video/@video.Id" class="video-title-link">@video.Title</a></h3>
                        <p class="description">@video.Description</p>
                        <div class="meta">
                            @if (!string.IsNullOrEmpty(video.Location))
                            {
                                <span class="location">📍 @video.Location</span>
                            }
                            <span class="date">@video.UploadedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="card-actions">
                            <a href="/video/@video.Id" class="btn-small open">🔗 Open</a>
                            <AuthorizeView>
                                <Authorized>
                                    <button class="btn-small edit" @onclick="() => EditVideo(video.Id)">Edit</button>
                                    <button class="btn-small delete" @onclick="() => DeleteVideo(video.Id)">Delete</button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Video>? videos;
    private bool showUpload = false;

    protected override async Task OnInitializedAsync()
    {
        videos = await VideoService.GetVideosByCategoryAsync(VideoCategories.WspinaczkaSkalowa);
    }

    private async Task RefreshVideos()
    {
        videos = await VideoService.GetVideosByCategoryAsync(VideoCategories.WspinaczkaSkalowa);
        showUpload = false;
    }

    private void EditVideo(int id)
    {
        Navigation.NavigateTo($"/edit-video/{id}");
    }

    private async Task DeleteVideo(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this video? This cannot be undone.");
        if (!confirmed) return;

        await VideoService.DeleteVideoAsync(id);
        await RefreshVideos();
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }
}
