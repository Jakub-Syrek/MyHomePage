@namespace MyHomePage.Components
@using MyHomePage.Models

@*
    Single media tile in a collection row.
    Click → triggers OnOpen callback (parent opens lightbox).
*@

<button type="button" class="tile @(Type == MediaType.Image ? "tile-image" : "tile-video")"
        @onclick="HandleClick"
        title="@FileName">
    @if (Type == MediaType.Image)
    {
        <img src="@Url" alt="" loading="lazy" />
    }
    else
    {
        <video preload="metadata" muted playsinline>
            <source src="@(Url + "#t=0.5")" type="video/mp4" />
        </video>
        <div class="tile-play">▶</div>
    }
    <div class="tile-overlay"></div>
</button>

<style>
    .tile {
        position: relative;
        flex: 0 0 280px;
        height: 200px;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        padding: 0; border: 0;
        background: #1a1a1a;
        box-shadow: 0 4px 14px rgba(0,0,0,0.12);
        transition: transform 0.25s cubic-bezier(.2,.7,.2,1), box-shadow 0.25s;
    }
    .tile:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 28px rgba(0,0,0,0.22);
    }
    .tile img, .tile video {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
    }
    .tile-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.25) 100%);
        opacity: 0; transition: opacity 0.25s;
        pointer-events: none;
    }
    .tile:hover .tile-overlay { opacity: 1; }
    .tile-play {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        color: rgba(255,255,255,0.95);
        font-size: 2.4rem;
        text-shadow: 0 3px 12px rgba(0,0,0,0.5);
        pointer-events: none;
    }

    @@media (max-width: 600px) {
        .tile { flex: 0 0 220px; height: 160px; }
        .tile-play { font-size: 2rem; }
    }
</style>

@code {
    [Parameter, EditorRequired] public string Url { get; set; } = "";
    [Parameter, EditorRequired] public string FileName { get; set; } = "";
    [Parameter, EditorRequired] public MediaType Type { get; set; }
    [Parameter] public EventCallback OnOpen { get; set; }

    private async Task HandleClick()
    {
        if (OnOpen.HasDelegate) await OnOpen.InvokeAsync();
    }
}
