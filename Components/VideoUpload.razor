@namespace MyHomePage.Components
@inject IVideoService VideoService
@inject IAiAssistantService Ai

<div class="upload-panel">
    <div class="upload-card">
        <h2>Upload New Gallery Item</h2>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert" style="background: @(isSuccess ? "#d4edda" : "#f8d7da");
                 color: @(isSuccess ? "#155724" : "#721c24"); border-radius: 8px; padding: 12px; margin-bottom: 20px;">
                @message
            </div>
        }

        @if (Ai.IsEnabled)
        {
            <div class="ai-block">
                <label class="ai-label">✨ Keywords (let AI fill the form)</label>
                <div class="ai-input-row">
                    <input type="text" class="ai-input" @bind="keywords"
                           placeholder="e.g., snowy ridge, sunrise, scrambling" />
                    <button type="button" class="ai-btn"
                            @onclick="GenerateWithAi"
                            disabled="@(isGenerating || string.IsNullOrWhiteSpace(keywords))">
                        @if (isGenerating)
                        {
                            <span class="spinner-small"></span> <span>Generating…</span>
                        }
                        else
                        {
                            <span>✨ AI Generate</span>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(aiMessage))
                {
                    <p class="ai-msg">@aiMessage</p>
                }
            </div>
        }

        <div class="form-group">
            <label>Title *</label>
            <input type="text" @bind="title" placeholder="e.g., Summer Hike to Mountain Peak" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea @bind="description" placeholder="Share your experience..." rows="4"></textarea>
        </div>

        <div class="form-group">
            <label>Location (free-text)</label>
            <input type="text" @bind="location" placeholder="e.g., Tatra Mountains" />
        </div>

        <div class="form-group" style="display:flex; gap:12px;">
            <div style="flex:1;">
                <label>Latitude (optional)</label>
                <input type="number" step="0.000001" @bind="latitude" placeholder="auto from photo/video EXIF" />
            </div>
            <div style="flex:1;">
                <label>Longitude (optional)</label>
                <input type="number" step="0.000001" @bind="longitude" placeholder="auto from photo/video EXIF" />
            </div>
        </div>

        <div class="form-group">
            <label>Media files * (videos + photos, up to 5 GB each)</label>
            <div class="file-input-wrapper">
                <InputFile OnChange="HandleFilesSelected" multiple
                           accept=".mp4,.webm,.mkv,.avi,.mov,.m4v,.jpg,.jpeg,.png,.webp,.heic" />
            </div>
            @if (selectedFiles.Count > 0)
            {
                <ul class="file-list" style="margin-top:10px; padding-left:18px;">
                    @foreach (var f in selectedFiles)
                    {
                        <li>
                            @(IsImage(f.Name) ? "🖼️" : "🎬")
                            @f.Name <span style="color:#7f8c8d">(@(f.Size / (1024 * 1024)) MB)</span>
                        </li>
                    }
                </ul>
                <p style="color:#7f8c8d; font-size:0.85rem; margin-top:8px;">
                    ℹ️ Videos are auto-compressed; photos resized to max 2560px.
                    GPS coordinates are read from the first file that has them.
                </p>
            }
        </div>

        <button class="btn-submit" @onclick="Upload"
                disabled="@(isUploading || selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(title))">
            @if (isUploading)
            {
                <span class="spinner-small"></span> <span>Uploading...</span>
            }
            else
            {
                <span>Upload (@selectedFiles.Count file(s))</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnUploadSuccess { get; set; }

    private List<IBrowserFile> selectedFiles = new();
    private string title = "";
    private string description = "";
    private string location = "";
    private double? latitude;
    private double? longitude;
    private string message = "";
    private bool isSuccess = false;
    private bool isUploading = false;

    // AI assistant
    private string keywords = "";
    private string aiMessage = "";
    private bool isGenerating = false;

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(maximumFileCount: 50).ToList();
    }

    private async Task GenerateWithAi()
    {
        if (string.IsNullOrWhiteSpace(keywords)) return;
        isGenerating = true;
        aiMessage = "";
        try
        {
            var suggestion = await Ai.SuggestForUploadAsync("", keywords);
            if (suggestion is null)
            {
                aiMessage = "Could not generate suggestions. Check API key or try again.";
                return;
            }
            if (string.IsNullOrWhiteSpace(title)) title = suggestion.Title;
            if (string.IsNullOrWhiteSpace(description)) description = suggestion.Description;
            if (string.IsNullOrWhiteSpace(location) && !string.IsNullOrWhiteSpace(suggestion.Location))
                location = suggestion.Location;
            if (latitude is null && suggestion.Latitude.HasValue) latitude = suggestion.Latitude;
            if (longitude is null && suggestion.Longitude.HasValue) longitude = suggestion.Longitude;

            aiMessage = "✓ Suggestions filled — review and edit as needed.";
        }
        catch (Exception ex)
        {
            aiMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task Upload()
    {
        if (selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(title))
            return;

        isUploading = true;
        message = "";

        try
        {
            var request = new VideoUploadRequest(
                Files: selectedFiles,
                Title: title,
                Description: description,
                Location: string.IsNullOrWhiteSpace(location) ? null : location,
                Category: "",
                Latitude: latitude,
                Longitude: longitude);

            var result = await VideoService.UploadVideoAsync(request);
            isSuccess = result.IsSuccess;
            message = result.IsSuccess ? $"✓ {result.Message}" : result.Message;

            if (result.IsSuccess)
            {
                ResetForm();
                await OnUploadSuccess.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private bool IsImage(string n) =>
        Models.MediaItem.DetectType(n) == Models.MediaType.Image;

    private void ResetForm()
    {
        selectedFiles = new List<IBrowserFile>();
        title = "";
        description = "";
        location = "";
        latitude = null;
        longitude = null;
        keywords = "";
        aiMessage = "";
    }
}

<style>
    .ai-block {
        background: linear-gradient(135deg, rgba(102,126,234,0.10) 0%, rgba(118,75,162,0.10) 100%);
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 20px;
    }
    .ai-label {
        display: block; font-weight: 700; font-size: 0.9rem;
        color: #5a4fb8; margin-bottom: 8px;
    }
    .ai-input-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .ai-input {
        flex: 1; min-width: 220px;
        padding: 10px 12px;
        border: 2px solid rgba(102, 126, 234, 0.3); border-radius: 8px;
        font-size: 0.95rem; font-family: inherit;
        background: rgba(255,255,255,0.85);
    }
    .ai-input:focus {
        outline: none; border-color: #667eea; background: white;
        box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
    }
    .ai-btn {
        padding: 10px 18px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white; border: 0; border-radius: 8px;
        font-weight: 600; font-size: 0.92rem; cursor: pointer;
        font-family: inherit;
        display: inline-flex; align-items: center; gap: 6px;
        white-space: nowrap;
    }
    .ai-btn:hover:not(:disabled) { filter: brightness(1.08); }
    .ai-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .ai-msg { margin: 8px 0 0; font-size: 0.85rem; color: #4a5568; }
</style>
