@using MyHomePage.Models

@if (Training is not null)
{
    <aside class="training-panel">
        <header class="training-panel-header">
            <h2>
                <span class="training-panel-icon">@GetActivityIcon(Training.ActivityType)</span>
                @Training.ActivityType
            </h2>
            @if (!string.IsNullOrEmpty(Training.ExternalUrl))
            {
                <a class="training-panel-source"
                   href="@Training.ExternalUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   title="Open in @SourceLabel">
                    Open in @SourceLabel ↗
                </a>
            }
        </header>

        <dl class="training-panel-grid">
            @if (Training.DistanceMeters is double dist)
            {
                <div><dt>Distance</dt><dd>@FormatDistance(dist)</dd></div>
            }
            <div><dt>Duration</dt><dd>@FormatDuration(Training.Duration)</dd></div>
            @if (Training.AveragePaceSecondsPerKm is double pace)
            {
                <div><dt>Pace</dt><dd>@FormatPace(pace)</dd></div>
            }
            @if (Training.AverageHeartRate is int hr)
            {
                <div><dt>Avg HR</dt><dd>@hr bpm</dd></div>
            }
            @if (Training.MaxHeartRate is int hrMax)
            {
                <div><dt>Max HR</dt><dd>@hrMax bpm</dd></div>
            }
            @if (Training.ElevationGainMeters is double elev && elev > 0)
            {
                <div><dt>Elevation</dt><dd>↑ @($"{elev:F0} m")</dd></div>
            }
            @if (Training.Calories is int kcal)
            {
                <div><dt>Calories</dt><dd>@kcal kcal</dd></div>
            }
            @if (Training.AverageCadence is double cadence && cadence > 0)
            {
                <div><dt>Cadence</dt><dd>@($"{cadence:F0}") spm</dd></div>
            }
            @if (Training.SufferScore is int suffer)
            {
                <div><dt>Effort</dt><dd>@suffer / 300</dd></div>
            }
            @if (Training.AverageTempCelsius is double temp)
            {
                <div><dt>Temp</dt><dd>@($"{temp:F0} °C")</dd></div>
            }
            @if (Training.MaxSpeedMetersPerSecond is double maxSpeed && maxSpeed > 0)
            {
                <div><dt>Max speed</dt><dd>@($"{maxSpeed * 3.6:F1}") km/h</dd></div>
            }
            @if (Training.AverageWatts is double watts && watts > 0)
            {
                <div><dt>Avg power</dt><dd>@($"{watts:F0}") W</dd></div>
            }
            @if (Training.MaxWatts is double wattsMax && wattsMax > 0)
            {
                <div><dt>Max power</dt><dd>@($"{wattsMax:F0}") W</dd></div>
            }
            @if (!string.IsNullOrWhiteSpace(Training.GearName))
            {
                <div><dt>Gear</dt><dd>@Training.GearName</dd></div>
            }
            @if (!string.IsNullOrWhiteSpace(Training.DeviceName))
            {
                <div><dt>Device</dt><dd>@Training.DeviceName</dd></div>
            }
            @if (Training.PersonalRecordCount is int prs && prs > 0)
            {
                <div><dt>Records</dt><dd>🏆 @prs PR@(prs == 1 ? "" : "s")</dd></div>
            }
            @if (Training.AchievementCount is int achievements && achievements > 0)
            {
                <div><dt>Achievements</dt><dd>⭐ @achievements</dd></div>
            }
        </dl>

        @if (Training.BestEfforts.Any(b => b.PersonalRecordRank.HasValue))
        {
            <section class="training-best">
                <h3>🏆 Best efforts</h3>
                <ul>
                    @foreach (var effort in Training.BestEfforts.Where(b => b.PersonalRecordRank.HasValue))
                    {
                        <li>
                            <strong>@effort.Name</strong>
                            <span class="training-best-time">@FormatDuration(effort.Duration)</span>
                            @if (effort.PersonalRecordRank == 1)
                            {
                                <span class="training-best-rank gold">PR</span>
                            }
                            else
                            {
                                <span class="training-best-rank">#@effort.PersonalRecordRank</span>
                            }
                        </li>
                    }
                </ul>
            </section>
        }

        @if (Training.Splits.Count > 0)
        {
            <details class="training-splits">
                <summary>📊 @Training.Splits.Count km splits</summary>
                <table>
                    <thead>
                        <tr><th>Km</th><th>Pace</th><th>HR</th><th>Δ Elev</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var split in Training.Splits)
                        {
                            <tr class="training-split-zone-@(split.PaceZone ?? 0)">
                                <td>@split.Index</td>
                                <td>@(split.PaceSecondsPerKm is double p ? FormatPace(p) : "—")</td>
                                <td>@(split.AverageHeartRate is int h ? $"{h}" : "—")</td>
                                <td>@(split.ElevationChangeMeters is double e ? $"{e:F0} m" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </details>
        }
    </aside>
}

<style>
    .training-panel {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 255, 255, 0.82) 100%);
        backdrop-filter: blur(20px) saturate(160%);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 20px;
        padding: 28px 32px;
        margin-bottom: 24px;
        box-shadow:
            0 14px 40px rgba(20, 30, 60, 0.12),
            inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }
    .training-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }
    .training-panel-header h2 {
        margin: 0;
        color: #2c3e50;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .training-panel-icon { font-size: 1.35rem; }
    .training-panel-source {
        color: #FC4C02;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.92rem;
    }
    .training-panel-source:hover { text-decoration: underline; }
    .training-panel-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 14px 22px;
        margin: 0;
    }
    .training-panel-grid > div { margin: 0; }
    .training-panel-grid dt {
        font-size: 0.75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }
    .training-panel-grid dd {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 700;
        color: #1f2937;
    }

    .training-best {
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }
    .training-best h3 {
        margin: 0 0 8px;
        font-size: 0.92rem;
        font-weight: 700;
        color: #2c3e50;
    }
    .training-best ul {
        list-style: none; margin: 0; padding: 0;
        display: flex; flex-wrap: wrap; gap: 8px;
    }
    .training-best li {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 12px;
        background: rgba(102, 126, 234, 0.08);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 999px;
        font-size: 0.88rem;
    }
    .training-best-time {
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        color: #1f2937;
    }
    .training-best-rank {
        padding: 1px 8px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        background: rgba(0, 0, 0, 0.08);
        color: #4a5568;
    }
    .training-best-rank.gold {
        background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        color: #78350f;
    }

    .training-splits {
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }
    .training-splits summary {
        cursor: pointer;
        font-weight: 600;
        font-size: 0.92rem;
        color: #2c3e50;
        list-style: none;
        padding: 4px 0;
    }
    .training-splits summary::-webkit-details-marker { display: none; }
    .training-splits summary::after {
        content: ' ▾';
        color: #6b7280;
        font-size: 0.8rem;
    }
    .training-splits[open] summary::after { content: ' ▴'; }
    .training-splits table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        font-size: 0.88rem;
        font-variant-numeric: tabular-nums;
    }
    .training-splits th, .training-splits td {
        padding: 6px 10px;
        text-align: left;
        border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    }
    .training-splits th {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        font-weight: 600;
    }
    .training-split-zone-1 { background: rgba(34, 197, 94, 0.06); }
    .training-split-zone-2 { background: rgba(59, 130, 246, 0.06); }
    .training-split-zone-3 { background: rgba(250, 204, 21, 0.08); }
    .training-split-zone-4 { background: rgba(239, 68, 68, 0.08); }
</style>

@code {
    /// <summary>The training payload to render. Component renders nothing when null.</summary>
    [Parameter] public TrainingData? Training { get; set; }

    private string SourceLabel => Training?.Source switch
    {
        TrainingSource.Strava => "Strava",
        TrainingSource.Garmin => "Garmin Connect",
        _ => "source"
    };

    private static string GetActivityIcon(string activityType) => activityType.ToLowerInvariant() switch
    {
        var t when t.Contains("run") => "🏃",
        var t when t.Contains("hike") => "🥾",
        var t when t.Contains("climb") || t.Contains("bouldering") => "🧗",
        var t when t.Contains("ride") || t.Contains("cycle") => "🚴",
        var t when t.Contains("swim") => "🏊",
        var t when t.Contains("weight") || t.Contains("crossfit") || t.Contains("workout") => "💪",
        _ => "📊"
    };

    private static string FormatDistance(double meters) =>
        meters >= 1000 ? $"{meters / 1000:F2} km" : $"{meters:F0} m";

    private static string FormatDuration(TimeSpan duration) =>
        duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}h {duration.Minutes:00}m"
            : $"{duration.Minutes}m {duration.Seconds:00}s";

    private static string FormatPace(double secondsPerKm)
    {
        var minutes = (int)(secondsPerKm / 60);
        var seconds = (int)Math.Round(secondsPerKm - (minutes * 60));
        return $"{minutes}:{seconds:00} /km";
    }
}
