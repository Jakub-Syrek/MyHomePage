@namespace MyHomePage.Components
@inject IVideoService VideoService

<div class="upload-panel">
    <div class="upload-card">
        <h2>Upload New Video</h2>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert" style="background: @(isSuccess ? "#d4edda" : "#f8d7da");
                 color: @(isSuccess ? "#155724" : "#721c24"); border-radius: 8px; padding: 12px; margin-bottom: 20px;">
                @message
            </div>
        }

        <div class="form-group">
            <label>Video Title *</label>
            <input type="text" @bind="videoTitle" placeholder="e.g., Amazing climb..." />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea @bind="videoDescription" placeholder="Share your experience..." rows="4"></textarea>
        </div>

        <div class="form-group">
            <label>Location</label>
            <input type="text" @bind="videoLocation" placeholder="e.g., Tatra Mountains" />
        </div>

        <div class="form-group">
            <label>Video File * (MP4, WebM, MKV, AVI - max 2GB)</label>
            <div class="file-input-wrapper">
                <InputFile OnChange="HandleFileSelected" accept=".mp4,.webm,.mkv,.avi" />
            </div>
            @if (selectedFile != null)
            {
                <p class="file-info">✓ Selected: @selectedFile.Name (@(selectedFile.Size / (1024 * 1024))MB)</p>
            }
            <p style="color: #7f8c8d; font-size: 0.85rem; margin-top: 8px;">
                ℹ️ Videos are automatically compressed (~20x smaller). Large files may take a few minutes.
            </p>
        </div>

        <button class="btn-submit" @onclick="UploadVideo"
                disabled="@(isUploading || selectedFile == null || string.IsNullOrWhiteSpace(videoTitle))">
            @if (isUploading)
            {
                <span class="spinner-small"></span> <span>Uploading & compressing...</span>
            }
            else
            {
                <span>Upload Video</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Category { get; set; } = "";
    [Parameter] public EventCallback OnUploadSuccess { get; set; }

    private IBrowserFile? selectedFile;
    private string videoTitle = "";
    private string videoDescription = "";
    private string videoLocation = "";
    private string message = "";
    private bool isSuccess = false;
    private bool isUploading = false;

    private void HandleFileSelected(InputFileChangeEventArgs e) => selectedFile = e.File;

    private async Task UploadVideo()
    {
        if (selectedFile == null || string.IsNullOrWhiteSpace(videoTitle))
            return;

        isUploading = true;
        message = "";

        try
        {
            var request = new VideoUploadRequest(
                selectedFile, videoTitle, videoDescription,
                string.IsNullOrWhiteSpace(videoLocation) ? null : videoLocation,
                Category);

            var result = await VideoService.UploadVideoAsync(request);

            isSuccess = result.IsSuccess;
            message = result.IsSuccess ? "Video uploaded successfully! 🎉" : result.Message;

            if (result.IsSuccess)
            {
                ResetForm();
                await OnUploadSuccess.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private void ResetForm()
    {
        selectedFile = null;
        videoTitle = "";
        videoDescription = "";
        videoLocation = "";
    }
}
