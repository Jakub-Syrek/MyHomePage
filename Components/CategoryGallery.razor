@code {
    [Parameter, EditorRequired] public string Category { get; set; } = "";
    [Parameter, EditorRequired] public string BackgroundImage { get; set; } = "";
    /// <summary>CSS background-position value (e.g. "center", "right center", "75% center").</summary>
    [Parameter] public string BackgroundPosition { get; set; } = "center";
    [Parameter] public string EmptyMessage { get; set; } = "No media yet. Be the first to upload!";

    private IReadOnlyList<Video>? videos;
    private bool showUpload = false;

    // Default date range: yesterday → today (last 24-48h)
    private DateTime? _dateFrom = DateTime.Today.AddDays(-1);
    private DateTime? _dateTo = DateTime.Today;
    private bool _sortDescending = true; // newest first by default

    /// <summary>Currently open tab ("details", "filter", or null = none).</summary>
    private string? _openTab = null;

    private void ToggleTab(string name) =>
        _openTab = (_openTab == name) ? null : name;

    private Lightbox? _lightbox;
    private int _currentItemId;
    private IReadOnlyList<MediaItem> _currentMedia = Array.Empty<MediaItem>();

    /// <summary>
    /// Id of the collection row most recently jumped-to from the rail.
    /// Used to render a highlighted "active" border on the matching
    /// thumbnail.
    /// </summary>
    private int? _activeRailId;

    /// <summary>
    /// Scrolls the matching <c>#col-{id}</c> anchor into the centre of
    /// the viewport via JS interop and marks the corresponding rail
    /// thumbnail as active. The smooth-scroll behaviour is handled by
    /// the inline helper registered in <see cref="OnAfterRenderAsync"/>.
    /// </summary>
    private async Task ScrollToCollectionAsync(int id)
    {
        _activeRailId = id;
        try
        {
            await JSRuntime.InvokeVoidAsync("myHomePage.scrollToCollection", $"col-{id}");
        }
        catch
        {
            // JS interop can fail during prerender — the click handler
            // only fires post-render so this is best-effort defensive.
        }
    }

    private bool _scrollHelperRegistered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _scrollHelperRegistered) return;
        _scrollHelperRegistered = true;
        // Register a tiny window-scoped helper once per page lifetime.
        // Using InvokeVoidAsync("eval", ...) keeps the JS co-located
        // with the component instead of forcing a separate file.
        try
        {
            await JSRuntime.InvokeVoidAsync("eval",
                "window.myHomePage = window.myHomePage || {};" +
                "window.myHomePage.scrollToCollection = function(anchorId) {" +
                "  const el = document.getElementById(anchorId);" +
                "  if (!el) return;" +
                "  el.scrollIntoView({ behavior: 'smooth', block: 'center' });" +
                "};");
        }
        catch { /* best-effort during teardown */ }
    }

    private bool HasFilter => _dateFrom.HasValue || _dateTo.HasValue;

    private IReadOnlyList<Video> FilteredVideos
    {
        get
        {
            if (videos is null) return Array.Empty<Video>();
            IEnumerable<Video> q = videos;

            if (_dateFrom.HasValue)
                q = q.Where(v => v.UploadedAt.Date >= _dateFrom.Value.Date);
            if (_dateTo.HasValue)
                q = q.Where(v => v.UploadedAt.Date <= _dateTo.Value.Date);

            q = _sortDescending
                ? q.OrderByDescending(v => v.UploadedAt)
                : q.OrderBy(v => v.UploadedAt);

            return q.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        videos = await LoadVideosAsync();
    }

    private async Task RefreshVideos()
    {
        videos = await LoadVideosAsync();
        showUpload = false;
    }

    /// <summary>
    /// Loads the list of collections to render. For the regular per-sport
    /// galleries this is a straight category-string match. For the synthetic
    /// /multisport subview we surface both the aggregate masters AND the
    /// per-activity source collections referenced by any master, so the page
    /// shows the whole "multi-sport context" in one feed.
    /// </summary>
    private async Task<IReadOnlyList<Video>> LoadVideosAsync()
    {
        if (Category == VideoCategories.MultiSport)
        {
            return await LoadMultisportFeedAsync();
        }

        _multisportSourcesByMasterId = null;
        var byCategory = await VideoService.GetVideosByCategoryAsync(Category);
        return byCategory.ToList().AsReadOnly();
    }

    /// <summary>
    /// Returns the source stumps that should render nested beneath the
    /// supplied master card on /multisport. Empty list outside of the
    /// multi-sport view or when the master has no resolvable sources.
    /// </summary>
    /// <param name="master">Video being rendered in the feed.</param>
    /// <returns>Ordered list of source stumps; possibly empty.</returns>
    private IReadOnlyList<Video> ResolveNestedSources(Video master)
    {
        if (_multisportSourcesByMasterId is null) return Array.Empty<Video>();
        return _multisportSourcesByMasterId.TryGetValue(master.Id, out var sources)
            ? sources
            : Array.Empty<Video>();
    }

    /// <summary>
    /// Per-master lookup of the source stumps referenced through
    /// <see cref="SubActivityLink.ExternalId"/>. Populated only while
    /// <c>Category == VideoCategories.MultiSport</c>; consumers render the
    /// entries nested beneath each master card so the feed itself stays
    /// "one row per master".
    /// </summary>
    private IReadOnlyDictionary<int, IReadOnlyList<Video>>? _multisportSourcesByMasterId;

    /// <summary>
    /// Builds the multi-sport feed: the visible list is just the masters
    /// (so the thumbnail rail on the left lists only merges, not the
    /// individual source workouts). The matching source stumps for every
    /// master are stashed in <see cref="_multisportSourcesByMasterId"/> so
    /// the rendering layer can expand them inline as a nested panel.
    /// </summary>
    private async Task<IReadOnlyList<Video>> LoadMultisportFeedAsync()
    {
        var all = await VideoService.GetAllVideosAsync();
        var masters = all
            .Where(v => v.Training?.IsMultiSport == true
                        || v.Category == VideoCategories.MultiSport)
            .OrderByDescending(v => v.UploadedAt)
            .ToList();

        var stumpsByExternalId = all
            .Where(v => v.Training is not null
                        && v.Training.IsMultiSport != true
                        && !string.IsNullOrWhiteSpace(v.Training.ExternalId))
            .GroupBy(v => v.Training!.ExternalId, StringComparer.Ordinal)
            .ToDictionary(g => g.Key, g => g.First(), StringComparer.Ordinal);

        var map = new Dictionary<int, IReadOnlyList<Video>>();
        foreach (var master in masters)
        {
            var subActivities = master.Training?.SubActivities
                ?? (IReadOnlyList<SubActivityLink>)Array.Empty<SubActivityLink>();
            var sources = subActivities
                .Where(s => !string.IsNullOrWhiteSpace(s.ExternalId))
                .Select(s => stumpsByExternalId.TryGetValue(s.ExternalId, out var stump) ? stump : null)
                .Where(v => v is not null)
                .Cast<Video>()
                .ToList();
            map[master.Id] = sources;
        }
        _multisportSourcesByMasterId = map;

        return masters.AsReadOnly();
    }

    private void ToggleUpload() => showUpload = !showUpload;
    private void ToggleSort() => _sortDescending = !_sortDescending;
    private void ClearFilter()
    {
        _dateFrom = null;
        _dateTo = null;
    }

    // ── Merge-collections feature ───────────────────────────────────────────

    /// <summary>Whether the gallery is currently in multi-select merge mode.</summary>
    private bool _mergeMode;

    /// <summary>
    /// Ids of the collections currently checked for merge, in selection
    /// order. The order matters: the merge service uses the first entry
    /// as the source of the fallback cover when no user media exists
    /// across all sources.
    /// </summary>
    private readonly List<int> _selection = new();

    private bool _mergeDialogOpen;
    private bool _mergeRunning;
    private string _mergeTitle = string.Empty;
    private string _mergeDescription = string.Empty;
    private string? _mergeError;

    private void ToggleMergeMode()
    {
        _mergeMode = !_mergeMode;
        if (!_mergeMode)
        {
            _selection.Clear();
            CloseMergeDialog();
        }
    }

    private void ToggleSelection(int id, bool checkedNow)
    {
        if (checkedNow)
        {
            if (!_selection.Contains(id)) _selection.Add(id);
        }
        else
        {
            _selection.Remove(id);
        }
    }

    private void ClearSelection() => _selection.Clear();

    private void OpenMergeDialog()
    {
        if (_selection.Count < 2) return;
        _mergeTitle = $"Multi-sport — {DateTime.Now:MMM d, yyyy}";
        _mergeDescription = string.Empty;
        _mergeError = null;
        _mergeDialogOpen = true;
    }

    private void CloseMergeDialog()
    {
        if (_mergeRunning) return;
        _mergeDialogOpen = false;
    }

    /// <summary>
    /// Posts the merge through the application service. Refreshes the gallery
    /// list on success and surfaces a friendly error if the service refused.
    /// </summary>
    private async Task ConfirmMergeAsync()
    {
        if (_selection.Count < 2 || string.IsNullOrWhiteSpace(_mergeTitle))
        {
            return;
        }

        _mergeRunning = true;
        _mergeError = null;
        try
        {
            // Pass selection order through unchanged — the merge service
            // honours the first entry when picking a fallback placeholder
            // image (when no source carries user media).
            var ids = _selection.ToList();
            var result = await MergeService.MergeAsync(
                ids, _mergeTitle.Trim(), _mergeDescription?.Trim() ?? string.Empty);

            if (!result.IsSuccess)
            {
                _mergeError = result.Message;
                return;
            }

            Logger.LogInformation(
                "Merged {Count} collections into new id {NewId}",
                ids.Count, result.Value);

            _mergeDialogOpen = false;
            _mergeMode = false;
            _selection.Clear();
            // The new multi-sport collection lives under /multisport, not this
            // category page, so navigate there instead of refreshing in place.
            Navigation.NavigateTo("/multisport", forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error while merging collections");
            _mergeError = "Unexpected error — check server logs.";
        }
        finally
        {
            _mergeRunning = false;
        }
    }

    private async Task OpenLightbox(Video v, int index)
    {
        _currentItemId = v.Id;
        _currentMedia = v.GetAllMedia();
        StateHasChanged();
        if (_lightbox is not null)
            await _lightbox.OpenAtAsync(index);
    }

    private void GoHome() => Navigation.NavigateTo("/");
}
