@namespace MyHomePage.Components
@inject IVideoService VideoService
@inject ICollectionMergeService MergeService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<CategoryGallery> Logger

@*
    Vertical wall of CollectionRows: each gallery item is its own row with a
    horizontally scrolling strip of media tiles. Clicking any tile opens the
    shared fullscreen Lightbox.

    Includes a filter+sort bar:
      - Date range (from / to)
      - Sort direction (newest first / oldest first)
*@

<div class="category-page" style="--bg-url: url('@BackgroundImage'); --bg-position: @BackgroundPosition;">
    <div class="category-hero">
        <div class="category-hero-inner">
            <button class="btn-back" @onclick="GoHome">← Back</button>
            <h1>@Category</h1>
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-primary btn-upload" @onclick="ToggleUpload">
                        @if (showUpload) { <span>✕ Close</span> } else { <span>+ Upload Media</span> }
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    @* ── Sliding tab rail (sits just below the header, sticky) ──────
       Each tab is a slim handle hanging from the header. Tabs are
       mutually exclusive (opening one closes the other).
       Two tabs: DETAILS (mobile-only — replaces the hero on small screens)
                 FILTER (date range + sort) *@
    <div class="tabs-rail">
        <div class="tabs-strip">
            @* Details tab — shown on all sizes; replaces the old hero bar *@
            <button type="button"
                    class="tab-handle @(_openTab == "details" ? "open" : "")"
                    @onclick="@(() => ToggleTab("details"))"
                    title="Details">
                <span class="th-glyph">⌃</span>
                <span class="th-label">@Category</span>
            </button>

            <button type="button"
                    class="tab-handle @(_openTab == "filter" ? "open" : "")"
                    @onclick="@(() => ToggleTab("filter"))"
                    title="Sort &amp; Filter">
                <span class="th-glyph">⌃</span>
                <span class="th-label">Filter</span>
                @if (HasFilter || !_sortDescending)
                {
                    <span class="th-dot" title="Custom filter/sort active"></span>
                }
            </button>
        </div>

        <div class="tab-panel @(_openTab != null ? "open" : "")">
            @* Subtle video backdrop in the panel — same loop as the header *@
            <video class="tab-panel-bg" autoplay muted loop playsinline preload="auto"
                   poster="/videos/header/header-bg.jpg" aria-hidden="true">
                <source src="/videos/header/header-bg.mp4" type="video/mp4" />
            </video>

            @if (_openTab == "details")
            {
                <div class="tab-panel-inner">
                    <div class="details-bar">
                        <button class="btn-back" @onclick="GoHome">← Back</button>
                        <h2 class="details-title">@Category</h2>
                        <AuthorizeView>
                            <Authorized>
                                <button class="btn btn-primary btn-upload" @onclick="ToggleUpload">
                                    @if (showUpload) { <span>✕ Close</span> } else { <span>+ Upload Media</span> }
                                </button>
                                <button class="btn btn-merge @(_mergeMode ? "active" : "")"
                                        @onclick="ToggleMergeMode"
                                        title="Combine several collections into one multi-sport summary">
                                    @if (_mergeMode) { <span>✕ Cancel merge</span> } else { <span>⇄ Merge collections</span> }
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            }
            else if (_openTab == "filter")
            {
                <div class="tab-panel-inner">
                    <div class="filter-bar">
                        <div class="filter-group">
                            <label>From</label>
                            <input type="date" @bind="_dateFrom" @bind:event="oninput" />
                        </div>
                        <div class="filter-group">
                            <label>To</label>
                            <input type="date" @bind="_dateTo" @bind:event="oninput" />
                        </div>
                        <button type="button" class="filter-btn"
                                @onclick="ToggleSort"
                                title="Toggle sort order">
                            @if (_sortDescending) { <span>↓ Newest first</span> } else { <span>↑ Oldest first</span> }
                        </button>
                        <button type="button" class="filter-btn ghost"
                                @onclick="@(() => { _dateFrom = DateTime.Today.AddDays(-1); _dateTo = DateTime.Today; })"
                                title="Reset to yesterday → today">
                            📅 Last 24h
                        </button>
                        <button type="button" class="filter-btn ghost"
                                @onclick="@(() => { _dateFrom = DateTime.Today.AddDays(-7); _dateTo = DateTime.Today; })"
                                title="Last 7 days">
                            📆 Week
                        </button>
                        <button type="button" class="filter-btn ghost"
                                @onclick="@(() => { _dateFrom = DateTime.Today.AddDays(-30); _dateTo = DateTime.Today; })"
                                title="Last 30 days">
                            🗓️ Month
                        </button>
                        <button type="button" class="filter-btn ghost"
                                @onclick="ClearFilter"
                                disabled="@(!HasFilter)">
                            ✕ All time
                        </button>
                        <span class="filter-stats">@FilteredVideos.Count / @(videos?.Count ?? 0) shown</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="category-content">
        @if (showUpload)
        {
            <VideoUploadCategory Category="@Category" OnUploadSuccess="RefreshVideos" />
        }

        @if (videos == null)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Loading media...</p>
            </div>
        }
        else if (videos.Count == 0)
        {
            <div class="empty-state-wall">
                <p>@EmptyMessage</p>
            </div>
        }
        else if (FilteredVideos.Count == 0)
        {
            <div class="empty-state-wall">
                <p>No items match the current filter.</p>
                <button type="button" class="filter-btn" @onclick="ClearFilter">Clear filter</button>
            </div>
        }
        else
        {
            <div class="feed-layout">
                @* Desktop-only thumbnail rail: jumps to each collection *@
                <aside class="thumb-rail" aria-label="Collections quick nav">
                    @foreach (var v in FilteredVideos)
                    {
                        var first = v.GetAllMedia().FirstOrDefault();
                        var hasMedia = first is not null && !string.IsNullOrEmpty(first.FileName);
                        var thumbUrl = hasMedia
                            ? $"/videos/{v.Id}/{first!.FileName}"
                            : VideoCategories.GetPlaceholderImage(v.Category);
                        var videoId = v.Id;
                        <button type="button"
                                class="thumb-rail-item @(_activeRailId == v.Id ? "active" : "")"
                                @onclick="@(() => ScrollToCollectionAsync(videoId))"
                                title="@v.Title — @v.UploadedAt.ToString("MMM d, yyyy")">
                            @if (!hasMedia)
                            {
                                <img src="@thumbUrl" alt="" loading="lazy" class="thumb-placeholder" />
                            }
                            else if (first!.Type == MediaType.Image)
                            {
                                <img src="@thumbUrl" alt="" loading="lazy" />
                            }
                            else
                            {
                                <video preload="metadata" muted playsinline>
                                    <source src="@(thumbUrl + "#t=0.5")" type="video/mp4" />
                                </video>
                                <span class="thumb-play">▶</span>
                            }
                            <span class="thumb-date">@v.UploadedAt.ToString("MMM d")</span>
                        </button>
                    }
                </aside>

                <div class="rows-wall">
                    @foreach (var v in FilteredVideos)
                    {
                        var collectionId = v.Id;
                        var nestedSources = ResolveNestedSources(v);
                        <div id="col-@v.Id" class="rows-anchor" @key="v.Id">
                            <CollectionRow Item="v"
                                           OnTileOpen="@(idx => OpenLightbox(v, idx))"
                                           OnDeleted="RefreshVideos"
                                           MergeMode="_mergeMode"
                                           Selected="@_selection.Contains(collectionId)"
                                           SelectionChanged="@(checkedNow => ToggleSelection(collectionId, checkedNow))" />
                            @if (nestedSources.Count > 0)
                            {
                                <details class="ms-subs">
                                    <summary>
                                        🔗 @nestedSources.Count source @(nestedSources.Count == 1 ? "activity" : "activities")
                                    </summary>
                                    <div class="ms-subs-list">
                                        @foreach (var sub in nestedSources)
                                        {
                                            var subId = sub.Id;
                                            <CollectionRow Item="sub"
                                                           OnTileOpen="@(idx => OpenLightbox(sub, idx))"
                                                           OnDeleted="RefreshVideos" />
                                        }
                                    </div>
                                </details>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<Lightbox @ref="_lightbox"
          ItemId="_currentItemId"
          Items="_currentMedia" />

@* ── Floating merge action bar + confirm dialog ──────────────────────
   Only the authenticated path renders these — the toggle that activates
   _mergeMode is itself behind <AuthorizeView>, so the bar is doubly
   protected. *@
@if (_mergeMode)
{
    <div class="merge-action-bar" role="status" aria-live="polite">
        <div class="merge-action-info">
            <strong>@_selection.Count</strong> selected — pick at least 2 to combine.
        </div>
        <div class="merge-action-buttons">
            <button type="button" class="filter-btn ghost" @onclick="ClearSelection">Clear</button>
            <button type="button" class="filter-btn" disabled="@(_selection.Count < 2 || _mergeRunning)"
                    @onclick="OpenMergeDialog">
                ⇄ Merge @_selection.Count selected
            </button>
        </div>
    </div>
}

@if (_mergeDialogOpen)
{
    <div class="merge-modal-backdrop" @onclick="CloseMergeDialog">
        <div class="merge-modal" @onclick:stopPropagation>
            <h2>Merge @_selection.Count collections</h2>
            <p class="merge-modal-hint">
                Files from every selected collection will be combined into a single new one,
                the originals will be deleted, and a <code>summary.md</code> with totals
                and per-activity Strava links will be generated.
            </p>
            <label class="merge-field">
                <span>Title</span>
                <input type="text" @bind="_mergeTitle" maxlength="120" placeholder="Multi-sport day, May 17" />
            </label>
            <label class="merge-field">
                <span>Description (optional)</span>
                <textarea rows="3" maxlength="600" @bind="_mergeDescription"
                          placeholder="What ties these sessions together?"></textarea>
            </label>
            @if (!string.IsNullOrEmpty(_mergeError))
            {
                <div class="merge-modal-error">@_mergeError</div>
            }
            <div class="merge-modal-actions">
                <button type="button" class="filter-btn ghost" @onclick="CloseMergeDialog" disabled="@_mergeRunning">
                    Cancel
                </button>
                <button type="button" class="filter-btn" @onclick="ConfirmMergeAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_mergeTitle) || _mergeRunning)">
                    @(_mergeRunning ? "Merging…" : "Merge")
                </button>
            </div>
        </div>
    </div>
}

<style>
    html { scroll-behavior: smooth; }
    .category-page {
        min-height: 100vh;
        background:
            linear-gradient(180deg, rgba(60, 50, 100, 0.18) 0%, rgba(40, 30, 80, 0.32) 100%),
            var(--bg-url, none);
        background-size: cover;
        background-attachment: fixed;
        background-position: var(--bg-position, center);
    }

    .category-hero {
        padding: 60px 24px 40px;
        background: linear-gradient(135deg, rgba(102,126,234,0.92) 0%, rgba(118,75,162,0.92) 100%);
        color: white;
        box-shadow: 0 6px 30px rgba(0,0,0,0.12);
    }
    .category-hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .category-hero h1 {
        flex: 1;
        font-size: 2.4rem;
        font-weight: 700;
        margin: 0;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }
    .btn-back {
        background: rgba(255,255,255,0.18);
        color: white;
        border: 1px solid rgba(255,255,255,0.25);
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-back:hover { background: rgba(255,255,255,0.32); }

    .btn-upload {
        padding: 11px 22px;
        background: white;
        color: #667eea;
        border: none;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s;
    }
    .btn-upload:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    }

    .category-content { padding: 14px 20px 60px; }

    /* ── Tab rail (slim handles tucked under the header) ───────────── */
    .tabs-rail {
        position: sticky;
        top: 0;
        z-index: 50;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
        pointer-events: none;
    }
    .tabs-strip {
        display: flex;
        gap: 6px;
        padding-left: 24px;
    }
    .tab-handle {
        pointer-events: auto;
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 14px 6px;
        background:
            linear-gradient(180deg, rgba(255,255,255,0.85) 0%, rgba(255,255,255,0.62) 100%);
        backdrop-filter: blur(14px) saturate(160%);
        -webkit-backdrop-filter: blur(14px) saturate(160%);
        border: 1px solid rgba(255,255,255,0.6);
        border-top: 0;
        border-radius: 0 0 10px 10px;
        color: #4a5568;
        font-size: 0.74rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        box-shadow:
            0 4px 14px rgba(20, 30, 60, 0.12),
            inset 0 -1px 0 rgba(255,255,255,0.5);
        transition: transform 0.22s, box-shadow 0.22s, background 0.22s, color 0.22s, padding 0.22s;
        font-family: inherit;
        opacity: 0.85;
        min-width: 0;
    }
    .tab-handle:hover {
        transform: translateY(3px);
        padding: 6px 14px 8px;
        opacity: 1;
        color: #2d3748;
        background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,255,255,0.78) 100%);
        box-shadow: 0 8px 22px rgba(20, 30, 60, 0.18);
    }
    .tab-handle.open {
        background: linear-gradient(180deg, rgba(102,126,234,0.96) 0%, rgba(118,75,162,0.96) 100%);
        color: white;
        opacity: 1;
        padding: 6px 16px 9px;
        border-color: rgba(255,255,255,0.45);
        box-shadow: 0 10px 26px rgba(102, 126, 234, 0.4);
    }
    .th-glyph {
        display: inline-block;
        font-size: 0.85rem;
        line-height: 1;
        transition: transform 0.22s;
    }
    .tab-handle.open .th-glyph { transform: rotate(180deg); }
    .th-label {
        line-height: 1;
    }
    .th-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #f59e0b;
        box-shadow: 0 0 6px rgba(245, 158, 11, 0.65);
        animation: thPulse 1.4s ease-in-out infinite;
        flex-shrink: 0;
    }
    .tab-handle.open .th-dot { background: white; box-shadow: 0 0 6px rgba(255,255,255,0.85); }
    @@keyframes thPulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.55; transform: scale(0.8); }
    }

    /* Sliding panel */
    .tab-panel {
        position: relative;
        pointer-events: auto;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.32s cubic-bezier(.2,.7,.2,1),
                    opacity 0.22s ease,
                    margin 0.22s ease;
        opacity: 0;
        margin-top: 0;
        border-radius: 14px;
    }
    .tab-panel.open {
        max-height: 320px;
        opacity: 1;
        margin-top: 4px;
    }
    /* Video backdrop inside the open panel (same loop as header) */
    .tab-panel-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 60%;
        z-index: 0;
        opacity: 0.55;
        pointer-events: none;
        border-radius: 14px;
        filter: saturate(115%) brightness(85%);
    }
    .tab-panel-inner {
        position: relative;
        z-index: 1;
    }

    /* Details bar (inside the details tab) */
    .details-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background:
            linear-gradient(180deg, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.32) 100%);
        backdrop-filter: blur(18px) saturate(160%);
        -webkit-backdrop-filter: blur(18px) saturate(160%);
        border: 1px solid rgba(255,255,255,0.6);
        border-radius: 14px;
        box-shadow:
            0 8px 28px rgba(20, 30, 60, 0.12),
            inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .details-title {
        flex: 1;
        margin: 0;
        font-size: 1.2rem;
        font-weight: 700;
        color: #2c3e50;
        text-shadow: 0 1px 2px rgba(255,255,255,0.6);
    }

    /* Hero bar is no longer rendered — its content lives in the Details tab */
    .category-hero { display: none; }
    .category-content { padding-top: 10px; }

    @@media (max-width: 700px) {
        .filter-bar { padding: 10px 12px; gap: 8px; }
        .details-bar { padding: 10px 12px; gap: 8px; }
        .details-title { font-size: 1rem; }
        .btn-upload { padding: 8px 14px; font-size: 0.85rem; }
        .btn-back { padding: 6px 10px; font-size: 0.82rem; }
    }

    /* ── Filter bar (glossy) ────────────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 12px;
        align-items: flex-end;
        padding: 14px 18px;
        background:
            linear-gradient(180deg, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.38) 100%);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        border: 1px solid rgba(255,255,255,0.6);
        border-radius: 14px;
        box-shadow:
            0 10px 32px rgba(20, 30, 60, 0.16),
            inset 0 1px 0 rgba(255,255,255,0.75);
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .filter-group label {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #4a5568;
    }
    .filter-group input[type="date"] {
        padding: 6px 10px;
        border-radius: 8px;
        border: 1px solid rgba(102, 126, 234, 0.25);
        background: rgba(255,255,255,0.9);
        font-size: 0.9rem;
        font-family: inherit;
        color: #2d3748;
        outline: none;
        transition: border-color 0.18s, background 0.18s;
    }
    .filter-group input[type="date"]:focus {
        border-color: #667eea;
        background: white;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
    }
    .filter-btn {
        padding: 9px 14px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(102,126,234,0.95) 0%, rgba(118,75,162,0.95) 100%);
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
        font-family: inherit;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25);
    }
    .filter-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        filter: brightness(1.1);
        box-shadow: 0 6px 18px rgba(102, 126, 234, 0.35);
    }
    .filter-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .filter-btn.ghost {
        background: rgba(255,255,255,0.85);
        color: #4a5568;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
    }
    .filter-stats {
        margin-left: auto;
        font-size: 0.85rem;
        color: #4a5568;
        font-weight: 500;
        padding: 6px 10px;
        background: rgba(255,255,255,0.6);
        border-radius: 999px;
    }

    /* ── Feed layout: rail on left + centered feed ─────────────────── */
    .feed-layout {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
    }
    .rows-wall {
        display: flex; flex-direction: column;
        align-items: center;
        padding: 4px 0;
        min-width: 0; /* allow shrink */
    }
    .rows-anchor {
        width: 100%;
        display: flex;
        justify-content: center;
        scroll-margin-top: 90px;
    }

    /* ── Thumbnail rail (desktop only) ────────────────────────────── */
    .thumb-rail { display: none; }
    @@media (min-width: 1100px) {
        .feed-layout {
            grid-template-columns: 130px minmax(0, 1fr);
            align-items: start;
        }
        .thumb-rail {
            display: flex;
            flex-direction: column;
            gap: 10px;
            position: sticky;
            top: 90px; /* clears header + filter tab */
            padding: 12px 10px;
            max-height: calc(100vh - 110px);
            overflow-y: auto;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.62) 0%, rgba(255,255,255,0.35) 100%);
            backdrop-filter: blur(18px) saturate(160%);
            -webkit-backdrop-filter: blur(18px) saturate(160%);
            border: 1px solid rgba(255,255,255,0.55);
            border-radius: 16px;
            box-shadow:
                0 10px 30px rgba(20, 30, 60, 0.14),
                inset 0 1px 0 rgba(255,255,255,0.7);
            z-index: 20;
            align-self: start;
            justify-self: start;
            margin-left: 8px;
        }
        .thumb-rail::-webkit-scrollbar { width: 4px; }
        .thumb-rail::-webkit-scrollbar-thumb {
            background: rgba(102, 126, 234, 0.35); border-radius: 2px;
        }
    }
    .thumb-rail-item {
        position: relative;
        display: block;
        width: 90px; height: 90px;
        padding: 0;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        border: 2px solid rgba(255, 255, 255, 0.5);
        box-shadow:
            0 4px 14px rgba(20, 30, 60, 0.14),
            inset 0 1px 0 rgba(255,255,255,0.45);
        background: #0a0a12;
        font-family: inherit;
        color: inherit;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }
    .thumb-rail-item.active {
        border-color: #667eea;
        box-shadow:
            0 0 0 3px rgba(102, 126, 234, 0.35),
            0 8px 22px rgba(102, 126, 234, 0.4);
        transform: scale(1.04);
    }
    .thumb-rail-item:hover {
        transform: scale(1.06);
        border-color: #667eea;
        box-shadow:
            0 8px 22px rgba(102, 126, 234, 0.32),
            inset 0 1px 0 rgba(255,255,255,0.6);
    }
    .thumb-rail-item img, .thumb-rail-item video {
        width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .thumb-empty { width: 100%; height: 100%; background: #2d3748; }
    .thumb-rail-item .thumb-placeholder {
        filter: brightness(0.7) saturate(115%);
    }
    .thumb-play {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        color: white;
