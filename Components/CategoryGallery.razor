@namespace MyHomePage.Components
@inject IVideoService VideoService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@*
    Vertical wall of CollectionRows: each gallery item is its own row with a
    horizontally scrolling strip of media tiles. Clicking any tile opens the
    shared fullscreen Lightbox.

    Includes a filter+sort bar:
      - Date range (from / to)
      - Sort direction (newest first / oldest first)
*@

<div class="category-page" style="--bg-url: url('@BackgroundImage');">
    <div class="category-hero">
        <div class="category-hero-inner">
            <button class="btn-back" @onclick="GoHome">← Back</button>
            <h1>@Category</h1>
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-primary btn-upload" @onclick="ToggleUpload">
                        @if (showUpload) { <span>✕ Close</span> } else { <span>+ Upload Media</span> }
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <div class="category-content">
        @if (showUpload)
        {
            <VideoUploadCategory Category="@Category" OnUploadSuccess="RefreshVideos" />
        }

        @* ── Filter + Sort bar ────────────────────────────────────────── *@
        <div class="filter-bar">
            <div class="filter-group">
                <label>From</label>
                <input type="date" @bind="_dateFrom" @bind:event="oninput" />
            </div>
            <div class="filter-group">
                <label>To</label>
                <input type="date" @bind="_dateTo" @bind:event="oninput" />
            </div>
            <button type="button" class="filter-btn @(_sortDescending ? "active" : "")"
                    @onclick="ToggleSort"
                    title="Toggle sort order">
                @if (_sortDescending) { <span>↓ Newest first</span> } else { <span>↑ Oldest first</span> }
            </button>
            <button type="button" class="filter-btn ghost"
                    @onclick="ClearFilter"
                    disabled="@(!HasFilter)">
                ✕ Clear
            </button>
            <span class="filter-stats">@FilteredVideos.Count / @(videos?.Count ?? 0) shown</span>
        </div>

        @if (videos == null)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Loading media...</p>
            </div>
        }
        else if (videos.Count == 0)
        {
            <div class="empty-state-wall">
                <p>@EmptyMessage</p>
            </div>
        }
        else if (FilteredVideos.Count == 0)
        {
            <div class="empty-state-wall">
                <p>No items match the current filter.</p>
                <button type="button" class="filter-btn" @onclick="ClearFilter">Clear filter</button>
            </div>
        }
        else
        {
            <div class="rows-wall">
                @foreach (var v in FilteredVideos)
                {
                    <CollectionRow Item="v" OnTileOpen="@(idx => OpenLightbox(v, idx))" @key="v.Id" />
                }
            </div>
        }
    </div>
</div>

<Lightbox @ref="_lightbox"
          ItemId="_currentItemId"
          Items="_currentMedia" />

<style>
    .category-page {
        min-height: 100vh;
        background:
            linear-gradient(180deg, rgba(245, 247, 250, 0.85) 0%, rgba(195, 207, 226, 0.95) 100%),
            var(--bg-url, none);
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
    }

    .category-hero {
        padding: 60px 24px 40px;
        background: linear-gradient(135deg, rgba(102,126,234,0.92) 0%, rgba(118,75,162,0.92) 100%);
        color: white;
        box-shadow: 0 6px 30px rgba(0,0,0,0.12);
    }
    .category-hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .category-hero h1 {
        flex: 1;
        font-size: 2.4rem;
        font-weight: 700;
        margin: 0;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }
    .btn-back {
        background: rgba(255,255,255,0.18);
        color: white;
        border: 1px solid rgba(255,255,255,0.25);
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-back:hover { background: rgba(255,255,255,0.32); }

    .btn-upload {
        padding: 11px 22px;
        background: white;
        color: #667eea;
        border: none;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s;
    }
    .btn-upload:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    }

    .category-content { padding: 30px 20px 60px; }

    /* ── Filter bar (glossy) ────────────────────────────────────────── */
    .filter-bar {
        max-width: 1400px;
        margin: 0 auto 26px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        padding: 14px 18px;
        background:
            linear-gradient(180deg, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.32) 100%);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        border: 1px solid rgba(255,255,255,0.55);
        border-radius: 14px;
        box-shadow:
            0 8px 28px rgba(20, 30, 60, 0.12),
            inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .filter-group label {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #4a5568;
    }
    .filter-group input[type="date"] {
        padding: 6px 10px;
        border-radius: 8px;
        border: 1px solid rgba(102, 126, 234, 0.25);
        background: rgba(255,255,255,0.9);
        font-size: 0.9rem;
        font-family: inherit;
        color: #2d3748;
        outline: none;
        transition: border-color 0.18s, background 0.18s;
    }
    .filter-group input[type="date"]:focus {
        border-color: #667eea;
        background: white;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
    }
    .filter-btn {
        padding: 9px 14px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(102,126,234,0.95) 0%, rgba(118,75,162,0.95) 100%);
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
        font-family: inherit;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25);
    }
    .filter-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        filter: brightness(1.1);
        box-shadow: 0 6px 18px rgba(102, 126, 234, 0.35);
    }
    .filter-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .filter-btn.ghost {
        background: rgba(255,255,255,0.85);
        color: #4a5568;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
    }
    .filter-stats {
        margin-left: auto;
        font-size: 0.85rem;
        color: #4a5568;
        font-weight: 500;
        padding: 6px 10px;
        background: rgba(255,255,255,0.6);
        border-radius: 999px;
    }

    .rows-wall { display: flex; flex-direction: column; }
    .empty-state-wall {
        text-align: center; padding: 60px 20px; color: #4a5568;
        background: rgba(255,255,255,0.7);
        max-width: 720px; margin: 30px auto;
        border-radius: 16px;
        backdrop-filter: blur(8px);
    }
    .empty-state-wall .filter-btn { margin-top: 14px; }
    .loading { text-align: center; padding: 80px 20px; }

    @@media (max-width: 700px) {
        .category-hero { padding: 40px 16px 28px; }
        .category-hero h1 { font-size: 1.6rem; }
        .filter-bar { gap: 8px; padding: 12px; }
        .filter-stats { margin-left: 0; width: 100%; text-align: center; }
    }
</style>

@code {
    [Parameter, EditorRequired] public string Category { get; set; } = "";
    [Parameter, EditorRequired] public string BackgroundImage { get; set; } = "";
    [Parameter] public string EmptyMessage { get; set; } = "No media yet. Be the first to upload!";

    private IReadOnlyList<Video>? videos;
    private bool showUpload = false;

    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private bool _sortDescending = true; // newest first by default

    private Lightbox? _lightbox;
    private int _currentItemId;
    private IReadOnlyList<MediaItem> _currentMedia = Array.Empty<MediaItem>();

    private bool HasFilter => _dateFrom.HasValue || _dateTo.HasValue;

    private IReadOnlyList<Video> FilteredVideos
    {
        get
        {
            if (videos is null) return Array.Empty<Video>();
            IEnumerable<Video> q = videos;

            if (_dateFrom.HasValue)
                q = q.Where(v => v.UploadedAt.Date >= _dateFrom.Value.Date);
            if (_dateTo.HasValue)
                q = q.Where(v => v.UploadedAt.Date <= _dateTo.Value.Date);

            q = _sortDescending
                ? q.OrderByDescending(v => v.UploadedAt)
                : q.OrderBy(v => v.UploadedAt);

            return q.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        videos = await VideoService.GetVideosByCategoryAsync(Category);
    }

    private async Task RefreshVideos()
    {
        videos = await VideoService.GetVideosByCategoryAsync(Category);
        showUpload = false;
    }

    private void ToggleUpload() => showUpload = !showUpload;
    private void ToggleSort() => _sortDescending = !_sortDescending;
    private void ClearFilter()
    {
        _dateFrom = null;
        _dateTo = null;
    }

    private async Task OpenLightbox(Video v, int index)
    {
        _currentItemId = v.Id;
        _currentMedia = v.GetAllMedia();
        StateHasChanged();
        if (_lightbox is not null)
            await _lightbox.OpenAtAsync(index);
    }

    private void GoHome() => Navigation.NavigateTo("/");
}
