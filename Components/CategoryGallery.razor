@namespace MyHomePage.Components
@inject IVideoService VideoService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@*
    Generic category gallery component.
    Template Method / DRY principle: the four category pages (Gory, Bouldering, etc.)
    previously duplicated identical markup and logic. Now each page is a thin wrapper
    that passes category-specific parameters to this single reusable component.
*@

<div class="gallery-container" style="background-image: url('@BackgroundImage'); background-size: 100% 100%;">
    <div class="gallery-header">
        <div>
            <button class="btn-back" @onclick="GoHome">← Back</button>
        </div>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary btn-upload" @onclick="ToggleUpload">
                    + Upload New Video
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (showUpload)
    {
        <VideoUploadCategory Category="@Category" OnUploadSuccess="RefreshVideos" />
    }

    @if (videos == null)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Loading videos...</p>
        </div>
    }
    else if (videos.Count == 0)
    {
        <div class="empty-state">
            <p>@EmptyMessage</p>
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var video in videos)
            {
                <div class="video-card" @key="video.Id">
                    <div class="card-image">
                        <MediaCarousel Item="video" />
                        @{ var mediaCount = video.GetAllMedia().Count; }
                        @if (mediaCount > 1)
                        {
                            <span class="card-badge">@mediaCount items</span>
                        }
                    </div>
                    <div class="card-content">
                        <a href="/item/@video.Id" class="card-title-link">
                            <h3>@video.Title</h3>
                        </a>
                        <p class="description">@video.Description</p>
                        <div class="meta">
                            @if (!string.IsNullOrEmpty(video.Location))
                            {
                                <span class="location">📍 @video.Location</span>
                            }
                            @if (video.HasCoordinates)
                            {
                                <a class="gps" href="/map" title="@video.Latitude, @video.Longitude">🗺️ on map</a>
                            }
                            <span class="date">@video.UploadedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="card-actions">
                            <a class="btn-small view" href="/item/@video.Id">View detail →</a>
                            <AuthorizeView>
                                <Authorized>
                                    <button class="btn-small edit" @onclick="() => EditVideo(video.Id)">Edit</button>
                                    <button class="btn-small delete" @onclick="() => DeleteVideo(video.Id)">Delete</button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Category { get; set; } = "";
    [Parameter, EditorRequired] public string BackgroundImage { get; set; } = "";
    [Parameter] public string EmptyMessage { get; set; } = "No videos yet. Be the first to upload!";

    private IReadOnlyList<Video>? videos;
    private bool showUpload = false;

    protected override async Task OnInitializedAsync()
    {
        videos = await VideoService.GetVideosByCategoryAsync(Category);
    }

    private async Task RefreshVideos()
    {
        videos = await VideoService.GetVideosByCategoryAsync(Category);
        showUpload = false;
    }

    private void ToggleUpload() => showUpload = !showUpload;

    private void EditVideo(int id) =>
        Navigation.NavigateTo($"/edit-video/{id}");

    private async Task DeleteVideo(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm", "Are you sure you want to delete this video? This cannot be undone.");
        if (!confirmed) return;

        await VideoService.DeleteVideoAsync(id);
        await RefreshVideos();
    }

    private void GoHome() => Navigation.NavigateTo("/");
}
