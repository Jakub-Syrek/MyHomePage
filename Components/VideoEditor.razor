@namespace MyHomePage.Components
@page "/edit-video/{VideoId:int}"
@inject IVideoService VideoService
@inject NavigationManager Navigation

<div class="editor-container">
    <div class="editor-header">
        <h1>Edit Media Item</h1>
        <button class="btn-back" @onclick="GoBack">← Back</button>
    </div>

    @if (video == null)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <div class="editor-content">
            <div class="preview-panel">
                <h3>Preview</h3>
                <div class="video-preview">
                    <MediaCarousel Item="video" />
                </div>
            </div>

            <div class="edit-panel">
                <form @onsubmit="SaveVideo">
                    <div class="form-group">
                        <label>Title *</label>
                        <input type="text" @bind="editTitle" required />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea @bind="editDescription" rows="5"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Location (free-text)</label>
                        <input type="text" @bind="editLocation" />
                    </div>

                    <div class="form-group" style="display:flex; gap:12px;">
                        <div style="flex:1;">
                            <label>Latitude</label>
                            <input type="number" step="0.000001" @bind="editLatitude" placeholder="e.g. 49.2992" />
                        </div>
                        <div style="flex:1;">
                            <label>Longitude</label>
                            <input type="number" step="0.000001" @bind="editLongitude" placeholder="e.g. 19.9496" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Uploaded</label>
                        <input type="text" value="@video.UploadedAt.ToString("MMM dd, yyyy HH:mm")" readonly />
                    </div>

                    <div class="form-group">
                        <label>File Size</label>
                        <input type="text" value="@(video.FileSizeBytes / (1024 * 1024))MB" readonly />
                    </div>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert" style="background: @(isSaveSuccess ? "#d4edda" : "#f8d7da");
                             color: @(isSaveSuccess ? "#155724" : "#721c24");">
                            @message
                        </div>
                    }

                    <div class="button-group">
                        <button type="submit" class="btn-save" disabled="@isSaving">
                            @if (isSaving) { <span>Saving...</span> }
                            else { <span>💾 Save Changes</span> }
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int VideoId { get; set; }

    private Video? video;
    private string editTitle = "";
    private string editDescription = "";
    private string editLocation = "";
    private double? editLatitude;
    private double? editLongitude;
    private string message = "";
    private bool isSaveSuccess = false;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        video = await VideoService.GetVideoByIdAsync(VideoId);
        if (video != null)
        {
            editTitle = video.Title;
            editDescription = video.Description;
            editLocation = video.Location ?? "";
            editLatitude = video.Latitude;
            editLongitude = video.Longitude;
        }
    }

    private async Task SaveVideo()
    {
        isSaving = true;
        message = "";

        try
        {
            var result = await VideoService.UpdateVideoAsync(
                VideoId, editTitle, editDescription,
                string.IsNullOrWhiteSpace(editLocation) ? null : editLocation,
                editLatitude, editLongitude);

            isSaveSuccess = result.IsSuccess;
            message = result.Message;

            if (result.IsSuccess)
                video = await VideoService.GetVideoByIdAsync(VideoId);
        }
        catch (Exception ex)
        {
            isSaveSuccess = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack()
    {
        var url = video is not null
            ? VideoCategories.GetUrl(video.Category)
            : "/";
        Navigation.NavigateTo(url);
    }
}
