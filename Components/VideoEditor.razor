@namespace MyHomePage.Components
@page "/edit-video/{VideoId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject IVideoService VideoService
@inject IFileStorageService FileStorage
@inject IAiAssistantService Ai
@inject NavigationManager Navigation
@inject IJSRuntime Js

<div class="editor-container">
    <div class="editor-header">
        <h1>Edit Media Item</h1>
        <button class="btn-back" @onclick="GoBack">← Back</button>
    </div>

    @if (video == null)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <div class="editor-content">
            <div class="preview-panel">
                <h3>Preview</h3>
                <div class="video-preview">
                    <MediaCarousel Item="video" />
                </div>

                @if (video.Media.Count > 0)
                {
                    <div class="media-list">
                        <h4>Attached media (@video.Media.Count)</h4>
                        <ul class="media-rows">
                            @foreach (var entry in video.Media)
                            {
                                var fileName = entry.FileName;
                                var isPrimary = string.Equals(video.FileName, fileName, StringComparison.Ordinal);
                                <li class="media-row">
                                    <span class="media-row-icon">@(entry.Type == Models.MediaType.Image ? "🖼️" : "🎬")</span>
                                    <span class="media-row-name" title="@fileName">@fileName</span>
                                    <span class="media-row-size">@FormatSize(entry.SizeBytes)</span>
                                    @if (isPrimary)
                                    {
                                        <span class="media-row-primary">primary</span>
                                    }
                                    <button type="button" class="media-row-remove"
                                            @onclick="@(() => RemoveMediaItem(fileName))"
                                            disabled="@isRemovingMedia"
                                            title="Remove this file from the gallery item">
                                        🗑
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <div class="edit-panel">
                <form @onsubmit="SaveVideo">
                    <div class="form-group">
                        <label>Title *</label>
                        <input type="text" @bind="editTitle" required />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea @bind="editDescription" rows="5"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Location (free-text)</label>
                        <input type="text" @bind="editLocation" />
                    </div>

                    <div class="form-group" style="display:flex; gap:12px;">
                        <div style="flex:1;">
                            <label>Latitude</label>
                            <input type="number" step="0.000001" @bind="editLatitude" placeholder="e.g. 49.2992" />
                        </div>
                        <div style="flex:1;">
                            <label>Longitude</label>
                            <input type="number" step="0.000001" @bind="editLongitude" placeholder="e.g. 19.9496" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Uploaded</label>
                        <input type="text" value="@video.UploadedAt.ToString("MMM dd, yyyy HH:mm")" readonly />
                    </div>

                    <div class="form-group">
                        <label>File Size</label>
                        <input type="text" value="@FormatSize(EffectiveSizeBytes)" readonly />
                    </div>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert" style="background: @(isSaveSuccess ? "#d4edda" : "#f8d7da");
                             color: @(isSaveSuccess ? "#155724" : "#721c24");">
                            @message
                        </div>
                    }

                    <div class="button-group">
                        <button type="submit" class="btn-save" disabled="@isSaving">
                            @if (isSaving) { <span>Saving...</span> }
                            else { <span>💾 Save Changes</span> }
                        </button>
                    </div>
                </form>

                @if (Ai.IsEnabled)
                {
                    <section class="ai-section">
                        <h3>✨ AI Assistant</h3>
                        <p class="upload-hint">A few keywords → Claude suggests title, description, location.</p>
                        <div class="ai-row">
                            <input type="text" class="ai-input"
                                   @bind="aiKeywords"
                                   placeholder="e.g., Tatra, sunrise, ridge scrambling" />
                            <button type="button" class="btn-save"
                                    @onclick="GenerateWithAi"
                                    disabled="@(isGenerating || string.IsNullOrWhiteSpace(aiKeywords))">
                                @if (isGenerating) { <span>Generating…</span> }
                                else { <span>✨ Generate</span> }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(aiMessage))
                        {
                            <p class="ai-msg">@aiMessage</p>
                        }
                    </section>
                }

                <section class="upload-section">
                    <h3>📦 Add photos / videos</h3>
                    <p class="upload-hint">Drop or browse files. Videos are compressed to H.264 on upload, photos resized to 2560 px long edge. Max 5 GB per file.</p>
                    <p class="upload-hint" style="margin-top:-6px;color:#92400e;background:rgba(251,191,36,0.12);border-left:3px solid #f59e0b;padding:6px 10px;border-radius:0 6px 6px 0;font-size:0.85rem;">
                        📱 Adding from a USB-connected phone and don't see your newest photos? Windows caches the phone's gallery folder — disconnect &amp; reconnect the phone, or open this site directly in the phone's browser to pick from the mobile gallery.
                    </p>

                    <label class="dropzone @(selectedFiles.Count > 0 ? "has-files" : "")">
                        <InputFile OnChange="OnFilesSelected" multiple
                                   class="dropzone-input"
                                   accept="image/*,video/*,.mp4,.webm,.mkv,.avi,.mov,.m4v,.3gp,.3gpp,.jpg,.jpeg,.png,.webp,.heic,.heif,.gif,.bmp" />
                        <div class="dropzone-inner">
                            @if (selectedFiles.Count == 0)
                            {
                                <div class="dropzone-icon">⤓</div>
                                <p class="dropzone-title">Drop files here</p>
                                <p class="dropzone-sub">or click to browse</p>
                            }
                            else
                            {
                                <div class="dropzone-icon small">📂</div>
                                <p class="dropzone-title">@selectedFiles.Count file@(selectedFiles.Count == 1 ? "" : "s") ready</p>
                                <p class="dropzone-sub">Click to replace</p>
                            }
                        </div>
                    </label>

                    @if (selectedFiles.Count > 0)
                    {
                        <ul class="file-pill-list">
                            @foreach (var file in selectedFiles)
                            {
                                <li class="file-pill">
                                    <span class="file-pill-icon">@(IsImage(file.Name) ? "🖼️" : "🎬")</span>
                                    <span class="file-pill-name" title="@file.Name">@file.Name</span>
                                    <span class="file-pill-size">@FormatSize(file.Size)</span>
                                </li>
                            }
                        </ul>
                        <button type="button" class="btn-save"
                                @onclick="AppendMedia"
                                disabled="@isAppending">
                            @if (isAppending)
                            {
                                <span>Uploading & compressing…</span>
                            }
                            else
                            {
                                <span>📤 Upload @selectedFiles.Count file@(selectedFiles.Count == 1 ? "" : "s")</span>
                            }
                        </button>
                    }

                    @if (!string.IsNullOrEmpty(uploadMessage))
                    {
                        <div class="alert" style="margin-top: 12px;
                             background: @(isUploadSuccess ? "#d4edda" : "#f8d7da");
                             color: @(isUploadSuccess ? "#155724" : "#721c24");">
                            @uploadMessage
                        </div>
                    }
                </section>

                @{
                    var firstImage = video.GetAllMedia().FirstOrDefault(m => m.Type == MediaType.Image);
                }
                @if (firstImage is not null)
                {
                    <section class="og-section">
                        <h3>📱 Social preview crop (Facebook / LinkedIn)</h3>
                        <p class="upload-hint">
                            Click anywhere on the image to set where the Facebook preview should be centred.
                            The orange box shows the exact 1.91:1 / 1200&times;630 area Facebook will use.
                            The crop respects your focus point on every re-share — without this it falls back to a generic centre crop that often chops off heads or hands.
                        </p>
                        <div class="og-preview-wrap" @ref="_ogPreviewRef" @onclick="OnOgFocusClick">
                            <img class="og-preview-img"
                                 src="/videos/@VideoId/@firstImage.FileName?v=@_ogImageCacheBuster"
                                 alt="Source image with crop overlay" />
                            <div class="og-crop-box" style="@OgBoxStyle()"></div>
                            <div class="og-focus-dot" style="@OgDotStyle()"></div>
                        </div>
                        <div class="og-actions">
                            <button type="button" class="btn btn-primary" @onclick="SaveOgCropAsync" disabled="@_ogBusy">
                                @if (_ogBusy) { <span>Saving crop&hellip;</span> }
                                else { <span>💾 Save Facebook crop</span> }
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="ResetOgFocus" disabled="@_ogBusy">
                                Reset to centre
                            </button>
                            @if (!string.IsNullOrEmpty(_ogStatusMessage))
                            {
                                <span class="og-status @(_ogStatusError ? "err" : "ok")">@_ogStatusMessage</span>
                            }
                        </div>
                        @if (_ogJpgExists)
                        {
                            <div class="og-current">
                                <span class="og-current-label">Current Facebook preview:</span>
                                <img class="og-current-img"
                                     src="/videos/@VideoId/og.jpg?v=@_ogImageCacheBuster"
                                     alt="Current 1200x630 OG image"
                                     loading="lazy" />
                            </div>
                        }
                    </section>
                }

                <section class="danger-section">
                    <h3>⚠️ Danger zone</h3>
                    <p class="upload-hint">
                        Permanently delete this gallery item — every photo, video and the
                        attached training data goes with it. There is no undo.
                    </p>
                    @if (!string.IsNullOrEmpty(deleteMessage))
                    {
                        <div class="alert" style="margin-bottom: 12px;
                             background:#f8d7da; color:#721c24;">
                            @deleteMessage
                        </div>
                    }
                    <button type="button" class="btn-delete"
                            @onclick="DeleteEntireItem"
                            disabled="@isDeleting">
                        @if (isDeleting) { <span>Deleting…</span> }
                        else { <span>🗑 Delete gallery item #@video.Id</span> }
                    </button>
                </section>
            </div>
        </div>
    }
</div>

<style>
    .ai-section,
    .upload-section {
        margin-top: 28px;
        padding-top: 22px;
        border-top: 1px solid #e2e8f0;
    }
    .ai-section h3,
    .upload-section h3 {
        margin: 0 0 6px;
        color: #2c3e50;
        font-size: 1.05rem;
    }
    .upload-hint {
        color: #6b7280;
        margin: 0 0 14px;
        font-size: 0.9rem;
    }
    .ai-row { display: flex; gap: 10px; align-items: stretch; }
    .ai-input {
        flex: 1;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        font-size: 0.95rem;
    }
    .ai-msg { margin: 10px 0 0; color: #4a5568; font-size: 0.9rem; }

    .dropzone {
        display: block;
        position: relative;
        padding: 26px 18px;
        text-align: center;
        background: #f8fafc;
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
    }
    .dropzone:hover { background: #eef2ff; border-color: #667eea; }
    .dropzone.has-files { background: #ecfdf5; border-color: #34d399; }
    .dropzone-input {
        position: absolute; inset: 0;
        opacity: 0; cursor: pointer;
    }
    .dropzone-icon { font-size: 1.9rem; line-height: 1; }
    .dropzone-icon.small { font-size: 1.4rem; }
    .dropzone-title { margin: 8px 0 2px; font-weight: 700; color: #2c3e50; }
    .dropzone-sub   { margin: 0; color: #6b7280; font-size: 0.85rem; }

    .file-pill-list {
        list-style: none;
        margin: 14px 0 14px;
        padding: 0;
        display: flex; flex-direction: column; gap: 6px;
    }
    .file-pill {
        display: flex; align-items: center; gap: 10px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px 12px;
        font-size: 0.9rem;
    }
    .file-pill-icon { font-size: 1.1rem; }
    .file-pill-name { flex: 1; color: #1f2937; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .file-pill-size { color: #6b7280; font-variant-numeric: tabular-nums; }

    .media-list { margin-top: 22px; }
    .media-list h4 {
        margin: 0 0 10px;
        font-size: 0.95rem;
        color: #2c3e50;
        font-weight: 700;
    }
    .media-rows { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
    .media-row {
        display: flex; align-items: center; gap: 10px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px 12px;
        font-size: 0.9rem;
    }
    .media-row-icon { font-size: 1.05rem; }
    .media-row-name {
        flex: 1; min-width: 0;
        color: #1f2937;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .media-row-size { color: #6b7280; font-variant-numeric: tabular-nums; }
    .media-row-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }
    .media-row-remove {
        background: transparent;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 4px 10px;
        cursor: pointer;
        color: #b91c1c;
        font-size: 0.95rem;
        line-height: 1;
        transition: background 0.18s, border-color 0.18s;
    }
    .media-row-remove:hover { background: #fef2f2; border-color: #fecaca; }
    .media-row-remove:disabled { opacity: 0.4; cursor: not-allowed; }

    .danger-section {
        margin-top: 32px;
        padding: 18px 20px;
        background: #fef2f2;
        border: 1px solid #fca5a5;
        border-radius: 12px;
    }
    .danger-section h3 {
        margin: 0 0 6px;
        color: #991b1b;
        font-size: 1.05rem;
    }
    .btn-delete {
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.18s;
    }
    .btn-delete:hover { background: #b91c1c; }
    .btn-delete:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Facebook / OG preview crop ───────────────────────────────────── */
    .og-section {
        background: white;
        border-radius: 12px;
        padding: 22px 24px;
        margin-top: 18px;
        box-shadow: 0 10px 28px rgba(20, 30, 60, 0.08);
    }
    .og-section h3 { margin: 0 0 8px; color: #1f2937; }
    .og-preview-wrap {
        position: relative;
        max-width: 760px;
        margin-top: 12px;
        border-radius: 10px;
        overflow: hidden;
        cursor: crosshair;
        background: #0a0a12;
        user-select: none;
        line-height: 0;
    }
    .og-preview-img {
        display: block;
        width: 100%;
        height: auto;
        pointer-events: none;
    }
    .og-crop-box {
        position: absolute;
        border: 2px solid #f59e0b;
        box-shadow:
            0 0 0 9999px rgba(0, 0, 0, 0.40),
            inset 0 0 0 1px rgba(255, 255, 255, 0.65);
        pointer-events: none;
        transition: left 0.18s, top 0.18s, width 0.18s, height 0.18s;
    }
    .og-focus-dot {
        position: absolute;
        width: 14px;
        height: 14px;
        margin-left: -7px;
        margin-top: -7px;
        border-radius: 50%;
        background: #f59e0b;
        border: 2px solid white;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.45);
        pointer-events: none;
        transition: left 0.18s, top 0.18s;
    }
    .og-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        margin-top: 14px;
    }
    .og-status {
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
    }
    .og-status.ok { color: #166534; }
    .og-status.err { color: #991b1b; }
    .og-current {
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid #e5e7eb;
    }
    .og-current-label {
        display: block;
        margin-bottom: 6px;
        font-size: 0.85rem;
        color: #6b7280;
    }
    .og-current-img {
        max-width: 600px;
        width: 100%;
        height: auto;
        border-radius: 8px;
        box-shadow: 0 6px 18px rgba(20, 30, 60, 0.14);
    }
</style>

@code {
    [Parameter] public int VideoId { get; set; }

    private Video? video;
    private string editTitle = "";
    private string editDescription = "";
    private string editLocation = "";
    private double? editLatitude;
    private double? editLongitude;
    private string message = "";
    private bool isSaveSuccess = false;
    private bool isSaving = false;

    private List<IBrowserFile> selectedFiles = new();
    private bool isAppending;
    private string uploadMessage = "";
    private bool isUploadSuccess;

    private string aiKeywords = "";
    private string aiMessage = "";
    private bool isGenerating;

    // ── Facebook / OG crop state ──────────────────────────────────────────
    private ElementReference _ogPreviewRef;
    private double _ogFocusX = 0.5;
    private double _ogFocusY = 0.5;
    private bool _ogBusy;
    private string? _ogStatusMessage;
    private bool _ogStatusError;
    private bool _ogJpgExists;
    /// <summary>Bumped after every OG re-crop so the &lt;img&gt; URL changes and browsers stop serving the stale cached copy.</summary>
    private long _ogImageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    /// <summary>
    /// 1.91:1 ratio Facebook uses for og:image. Used to draw the crop
    /// overlay so the operator sees exactly what the scrape will keep.
    /// </summary>
    private const double OgAspectRatio = 1200.0 / 630.0;

    /// <summary>
    /// CSS inline style for the orange 1.91:1 crop rectangle. The box is
    /// sized as a percentage of the source image so the same fractions
    /// drive both the visual overlay and the eventual server-side
    /// ImageSharp crop window.
    /// </summary>
    private string OgBoxStyle()
    {
        // Box dimensions as a fraction of the displayed image. We pick the
        // largest 1.91:1 rectangle that fits — whichever axis is the
        // limiting one for the source image at its rendered aspect.
        // Without the source dimensions we conservatively assume the
        // displayed image fills width and let the box be the largest
        // 1.91:1 rectangle inside it (height = width / 1.91).
        const double boxWidthFraction = 1.0;
        var boxHeightFraction = boxWidthFraction / OgAspectRatio;

        // If that height overflows the displayed image, fall back to
        // matching height and shrinking width.
        if (boxHeightFraction > 1.0)
        {
            boxHeightFraction = 1.0;
        }

        // Centre the box on the focus point, clamp inside the image.
        var halfW = boxWidthFraction / 2.0;
        var halfH = boxHeightFraction / 2.0;
        var leftFraction = Math.Clamp(_ogFocusX - halfW, 0.0, 1.0 - boxWidthFraction);
        var topFraction = Math.Clamp(_ogFocusY - halfH, 0.0, 1.0 - boxHeightFraction);

        return $"left:{leftFraction * 100:F2}%;" +
               $"top:{topFraction * 100:F2}%;" +
               $"width:{boxWidthFraction * 100:F2}%;" +
               $"height:{boxHeightFraction * 100:F2}%;";
    }

    private string OgDotStyle() =>
        $"left:{_ogFocusX * 100:F2}%; top:{_ogFocusY * 100:F2}%;";

    /// <summary>
    /// Translates a mouse click on the preview into a normalised focal
    /// point in [0, 1] x [0, 1] and re-renders the overlay. The actual
    /// crop is not regenerated until the operator presses "Save".
    /// </summary>
    private async Task OnOgFocusClick(MouseEventArgs args)
    {
        try
        {
            // Read the rendered image's bounding rect via JS interop so we
            // can convert the page-relative click coordinates into the
            // image-relative fractions the server expects.
            var rect = await Js.InvokeAsync<DomRectDto>(
                "myHomePage.getBoundingRect", _ogPreviewRef);
            if (rect.Width <= 0 || rect.Height <= 0) return;

            var fractionX = (args.ClientX - rect.Left) / rect.Width;
            var fractionY = (args.ClientY - rect.Top) / rect.Height;
            _ogFocusX = Math.Clamp(fractionX, 0.0, 1.0);
            _ogFocusY = Math.Clamp(fractionY, 0.0, 1.0);
            _ogStatusMessage = null;
        }
        catch (Exception ex)
        {
            _ogStatusError = true;
            _ogStatusMessage = $"Click failed: {ex.Message}";
        }
    }

    private void ResetOgFocus()
    {
        _ogFocusX = 0.5;
        _ogFocusY = 0.5;
        _ogStatusMessage = null;
    }

    /// <summary>
    /// Regenerates <c>og.jpg</c> from the first attached image using the
    /// operator-picked focus point. Runs server-side via ImageSharp; the
    /// cache buster query parameter forces every gallery viewer to pick
    /// up the new file on its next request.
    /// </summary>
    private async Task SaveOgCropAsync()
    {
        if (video is null || _ogBusy) return;
        var firstImage = video.GetAllMedia().FirstOrDefault(m => m.Type == MediaType.Image);
        if (firstImage is null)
        {
            _ogStatusError = true;
            _ogStatusMessage = "No image attached to crop.";
            return;
        }

        _ogBusy = true;
        _ogStatusMessage = "Generating Facebook preview…";
        _ogStatusError = false;
        StateHasChanged();

        try
        {
            var dir = FileStorage.GetVideoDirectoryPath(video.Id);
            var sourcePath = Path.Combine(dir, firstImage.FileName);
            var ogPath = Path.Combine(dir, "og.jpg");

            // Re-fetch the freshest video so any field the operator just
            // saved (title, location, training) is reflected in the
            // overlay payload. Falls back to the in-memory copy.
            var fresh = await VideoService.GetVideoByIdAsync(video.Id) ?? video;
            var overlay = fresh.ToOgOverlay();

            var size = await FileStorage.GenerateOgImageAsync(
                sourcePath, ogPath, (_ogFocusX, _ogFocusY), overlay);

            if (size > 0)
            {
                _ogJpgExists = true;
                _ogImageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
                _ogStatusError = false;
                _ogStatusMessage = $"✅ Saved — {size / 1024} KB.";
            }
            else
            {
                _ogStatusError = true;
                _ogStatusMessage = "Crop failed — see server logs.";
            }
        }
        catch (Exception ex)
        {
            _ogStatusError = true;
            _ogStatusMessage = $"Crop error: {ex.Message}";
        }
        finally
        {
            _ogBusy = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// DTO mirroring DOMRect properties returned by the inline
    /// <c>myHomePage.getBoundingRect</c> JS helper.
    /// </summary>
    private sealed record DomRectDto(double Left, double Top, double Width, double Height);

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(maximumFileCount: 50).ToList();
        uploadMessage = "";
    }

    private async Task AppendMedia()
    {
        if (selectedFiles.Count == 0) return;

        isAppending = true;
        uploadMessage = "Uploading & compressing…";
        StateHasChanged();

        try
        {
            // FileStorageService passes the per-file size limit to
            // IBrowserFile.OpenReadStream itself, so the raw IBrowserFile
            // instances from InputFileChangeEventArgs work as-is — no
            // wrapper needed.
            var result = await VideoService.AppendMediaAsync(VideoId, selectedFiles);
            isUploadSuccess = result.IsSuccess;
            uploadMessage = result.Message;

            if (result.IsSuccess)
            {
                selectedFiles = new List<IBrowserFile>();
                // Refresh the video reference so MediaCarousel re-renders
                // with the newly attached files.
                video = await VideoService.GetVideoByIdAsync(VideoId);
            }
        }
        catch (Exception ex)
        {
            isUploadSuccess = false;
            uploadMessage = $"Upload error: {ex.Message}";
        }
        finally
        {
            isAppending = false;
            StateHasChanged();
        }
    }

    private bool isRemovingMedia;
    private bool isDeleting;
    private string deleteMessage = "";

    private async Task RemoveMediaItem(string fileName)
    {
        if (video is null || string.IsNullOrWhiteSpace(fileName)) return;

        var confirmed = await Js.InvokeAsync<bool>("confirm",
            $"Remove '{fileName}' from this gallery item? The file will be deleted from disk.");
        if (!confirmed) return;

        isRemovingMedia = true;
        StateHasChanged();

        try
        {
            var result = await VideoService.RemoveMediaAsync(VideoId, fileName);
            uploadMessage = result.Message;
            isUploadSuccess = result.IsSuccess;
            if (result.IsSuccess)
                video = await VideoService.GetVideoByIdAsync(VideoId);
        }
        catch (Exception ex)
        {
            isUploadSuccess = false;
            uploadMessage = $"Remove error: {ex.Message}";
        }
        finally
        {
            isRemovingMedia = false;
            StateHasChanged();
        }
    }

    private async Task DeleteEntireItem()
    {
        if (video is null) return;

        var confirmed = await Js.InvokeAsync<bool>("confirm",
            $"Permanently delete gallery item #{video.Id} ('{video.Title}')? " +
            "Every photo and video attached to it will be removed. This cannot be undone.");
        if (!confirmed) return;

        isDeleting = true;
        deleteMessage = "";
        StateHasChanged();

        try
        {
            var category = video.Category;
            var result = await VideoService.DeleteVideoAsync(video.Id);
            if (result.IsSuccess)
            {
                Navigation.NavigateTo(VideoCategories.GetUrl(category), forceLoad: false);
                return;
            }
            deleteMessage = result.Message;
        }
        catch (Exception ex)
        {
            deleteMessage = $"Delete error: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
            StateHasChanged();
        }
    }

    private async Task GenerateWithAi()
    {
        if (string.IsNullOrWhiteSpace(aiKeywords) || video is null) return;

        isGenerating = true;
        aiMessage = "";
        StateHasChanged();

        try
        {
            var suggestion = await Ai.SuggestForUploadAsync(video.Category, aiKeywords);
            if (suggestion is null)
            {
                aiMessage = "Could not generate. Check the API key or try again.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editTitle)) editTitle = suggestion.Title;
            if (string.IsNullOrWhiteSpace(editDescription)) editDescription = suggestion.Description;
            if (string.IsNullOrWhiteSpace(editLocation) && !string.IsNullOrWhiteSpace(suggestion.Location))
                editLocation = suggestion.Location;
            if (editLatitude is null && suggestion.Latitude.HasValue) editLatitude = suggestion.Latitude;
            if (editLongitude is null && suggestion.Longitude.HasValue) editLongitude = suggestion.Longitude;

            aiMessage = "✓ Suggestions filled — review the form above and save.";
        }
        catch (Exception ex)
        {
            aiMessage = $"AI error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Total size in bytes used for the read-only "File Size" field.
    /// Prefers the stored aggregate, but falls back to summing the media
    /// list when the aggregate is stale or zero — Strava placeholders
    /// start with FileSizeBytes = 0 and we want the display to reflect
    /// what is actually on disk once media is appended.
    /// </summary>
    private long EffectiveSizeBytes
    {
        get
        {
            if (video is null) return 0;
            var fromMedia = video.Media.Sum(m => m.SizeBytes);
            return Math.Max(video.FileSizeBytes, fromMedia);
        }
    }

    private static bool IsImage(string fileName) =>
        Models.MediaItem.DetectType(fileName) == Models.MediaType.Image;

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return "—";
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / 1024.0 / 1024.0:F1} MB";
        return $"{bytes / 1024.0 / 1024.0 / 1024.0:F2} GB";
    }

    protected override async Task OnInitializedAsync()
    {
        video = await VideoService.GetVideoByIdAsync(VideoId);
        if (video != null)
        {
            editTitle = video.Title;
            editDescription = video.Description;
            editLocation = video.Location ?? "";
            editLatitude = video.Latitude;
            editLongitude = video.Longitude;

            // Mark whether og.jpg already exists so the editor can show
            // the "Current Facebook preview" thumbnail without flashing
            // a 404 on first render.
            var ogPath = Path.Combine(
                FileStorage.GetVideoDirectoryPath(VideoId), "og.jpg");
            _ogJpgExists = System.IO.File.Exists(ogPath);
        }
    }

    private bool _ogJsRegistered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ogJsRegistered) return;
        _ogJsRegistered = true;
        // Inline JS helper: returns DOMRect for a Blazor ElementReference
        // so the OG focus-click handler can map page coordinates to
        // image-relative fractions. Co-located here to avoid spinning up
        // a separate .js file for one function.
        try
        {
            await Js.InvokeVoidAsync("eval",
                "window.myHomePage = window.myHomePage || {};" +
                "window.myHomePage.getBoundingRect = function(el) {" +
                "  if (!el || !el.getBoundingClientRect) return { Left: 0, Top: 0, Width: 0, Height: 0 };" +
                "  var r = el.getBoundingClientRect();" +
                "  return { Left: r.left, Top: r.top, Width: r.width, Height: r.height };" +
                "};");
        }
        catch { /* best-effort during prerender / teardown */ }
    }

    private async Task SaveVideo()
    {
        isSaving = true;
        message = "";

        try
        {
            var result = await VideoService.UpdateVideoAsync(
                VideoId, editTitle, editDescription,
                string.IsNullOrWhiteSpace(editLocation) ? null : editLocation,
                editLatitude, editLongitude);

            isSaveSuccess = result.IsSuccess;
            message = result.Message;

            if (result.IsSuccess)
                video = await VideoService.GetVideoByIdAsync(VideoId);
        }
        catch (Exception ex)
        {
            isSaveSuccess = false;
            message = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack()
    {
        var url = video is not null
            ? VideoCategories.GetUrl(video.Category)
            : "/";
        Navigation.NavigateTo(url);
    }
}
