@namespace MyHomePage.Components
@implements IAsyncDisposable
@inject IVideoService VideoService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="gallery-container">
    <div class="gallery-header">
        <h1>🏔️ Gallery</h1>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-primary btn-upload" @onclick="ToggleUpload">
                    + Upload New Video
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (showUpload)
    {
        <VideoUpload OnUploadSuccess="RefreshVideos" />
    }

    @if (videos == null)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Loading videos...</p>
        </div>
    }
    else if (videos.Count == 0)
    {
        <div class="empty-state">
            <p>No videos yet. Check back soon!</p>
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var video in videos)
            {
                <div class="video-card" @key="video.Id">
                    <div class="card-image">
                        <MediaCarousel Item="video" />
                        @{ var mediaCount = video.GetAllMedia().Count; }
                        @if (mediaCount > 1)
                        {
                            <span class="card-badge">@mediaCount items</span>
                        }
                    </div>
                    <div class="card-content">
                        <a href="/item/@video.Id" class="card-title-link">
                            <h3>@video.Title</h3>
                        </a>
                        <p class="description">@video.Description</p>
                        <div class="meta">
                            @if (!string.IsNullOrEmpty(video.Location))
                            {
                                <span class="location">📍 @video.Location</span>
                            }
                            @if (video.HasCoordinates)
                            {
                                <a class="gps" href="/map" title="@video.Latitude, @video.Longitude">🗺️ on map</a>
                            }
                            <span class="date">@video.UploadedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="card-actions">
                            <a class="btn-small view" href="/item/@video.Id">View detail →</a>
                            <AuthorizeView>
                                <Authorized>
                                    <button class="btn-small edit" @onclick="() => EditVideo(video.Id)">Edit</button>
                                    <button class="btn-small delete" @onclick="() => DeleteVideo(video.Id)">Delete</button>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IReadOnlyList<Video>? videos;
    private bool showUpload = false;

    protected override async Task OnInitializedAsync()
    {
        videos = await VideoService.GetAllVideosAsync();
    }

    private async Task RefreshVideos()
    {
        videos = await VideoService.GetAllVideosAsync();
        showUpload = false;
    }

    private void ToggleUpload() => showUpload = !showUpload;

    private void EditVideo(int id) =>
        Navigation.NavigateTo($"/edit-video/{id}");

    private async Task DeleteVideo(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure?"))
        {
            await VideoService.DeleteVideoAsync(id);
            await RefreshVideos();
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
