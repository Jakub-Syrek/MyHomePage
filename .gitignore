# Media files (project runs locally - media stays on disk only)
# Video files
*.mp4
*.webm
*.mkv
*.avi
*.mov
*.flv
*.wmv
*.m4v

# Image files in wwwroot (large media), but keep SVG icons folder and small background JPGs
wwwroot/images/*
!wwwroot/images/icons/
!wwwroot/images/*-bg.jpg
# Ignore top-level files inside wwwroot/videos/ (user-uploaded media)
# but keep the header/ subfolder (ships with the app)
wwwroot/videos/*
!wwwroot/videos/header/
# Explicit override of the global *.mp4 rule for our looping header asset
!wwwroot/videos/header/header-bg.mp4

# Raw source assets (Midjourney exports, originals) — staged into wwwroot, not deployed
/Images/

# Audio files
*.mp3
*.wav
*.ogg
*.flac
*.aac
*.m4a

# FFmpeg binaries (auto-downloaded on first run)
ffmpeg/

# Logs
logs/

# Claude settings and local configuration
.claude/

# Diagnostic temp files
deploy-logs.txt
runtime-logs.txt

ai-logs.txt
