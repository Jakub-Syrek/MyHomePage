@inherits LayoutComponentBase

<PageTitle>My Home Page</PageTitle>

<div class="layout">
    <header class="app-header">
        <div class="header-content">
            <a href="/" class="logo">
                🏔️ My Mountain Adventures
            </a>
            <nav class="nav-menu">
                <a href="/">Home</a>
                <a href="/gory">Mountains</a>
                <a href="/wspinaczka-skalowa">Rock Climbing</a>
                <a href="/bouldering">Bouldering</a>
                <a href="/prowadzeni-hala">Indoor Climbing</a>
                <a href="/about">About</a>
                <AuthorizeView>
                    <Authorized>
                        <a href="/logout">Logout</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </nav>
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>

    <footer class="app-footer">
        <p>&copy; 2026 My Mountain Adventures. All videos captured with passion.</p>
    </footer>
</div>

<style>
    .layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .app-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .header-content {
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 40px;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        text-decoration: none;
        transition: transform 0.3s;
    }

    .logo:hover {
        transform: scale(1.05);
    }

    .nav-menu {
        display: flex;
        gap: 30px;
    }

    .nav-menu a {
        color: white;
        text-decoration: none;
        font-weight: 500;
        transition: opacity 0.3s;
    }

    .nav-menu a:hover {
        opacity: 0.8;
    }

    .app-main {
        flex: 1;
    }

    .app-footer {
        background: rgba(0, 0, 0, 0.8);
        color: white;
        text-align: center;
        padding: 30px 20px;
        margin-top: 60px;
    }

    .app-footer p {
        margin: 0;
    }
</style>

<script>
function closeOverlay() {
    const overlay = document.getElementById('video-overlay');
    if (overlay) {
        overlay.remove();
    }
}

document.addEventListener('mouseenter', function(e) {
    const card = e.target.closest('.video-card');
    if (card) {
        // Create overlay if it doesn't exist
        if (!document.getElementById('video-overlay')) {
            const overlay = document.createElement('div');
            overlay.id = 'video-overlay';
            overlay.style.position = 'fixed';
            overlay.style.top = '0';
            overlay.style.left = '0';
            overlay.style.right = '0';
            overlay.style.bottom = '0';
            overlay.style.zIndex = '999';
            overlay.style.display = 'flex';
            overlay.style.alignItems = 'center';
            overlay.style.justifyContent = 'center';
            overlay.style.background = 'rgba(0, 0, 0, 0.3)';
            overlay.style.cursor = 'pointer';

            // Close on background click
            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) {
                    closeOverlay();
                }
            });

            // Close on Escape key
            const closeOnEscape = function(e) {
                if (e.key === 'Escape') {
                    closeOverlay();
                    document.removeEventListener('keydown', closeOnEscape);
                }
            };
            document.addEventListener('keydown', closeOnEscape);

            const clone = card.cloneNode(true);
            clone.style.width = '700px';
            clone.style.maxWidth = '90vw';
            clone.style.maxHeight = '90vh';
            clone.style.position = 'relative';
            clone.style.zIndex = '1001';

            // Add close button
            const closeBtn = document.createElement('button');
            closeBtn.innerHTML = '×';
            closeBtn.style.position = 'absolute';
            closeBtn.style.top = '-30px';
            closeBtn.style.right = '0';
            closeBtn.style.background = 'none';
            closeBtn.style.border = 'none';
            closeBtn.style.color = 'white';
            closeBtn.style.fontSize = '40px';
            closeBtn.style.cursor = 'pointer';
            closeBtn.style.padding = '0';
            closeBtn.style.width = '40px';
            closeBtn.style.height = '40px';
            closeBtn.style.display = 'flex';
            closeBtn.style.alignItems = 'center';
            closeBtn.style.justifyContent = 'center';
            closeBtn.style.zIndex = '1002';
            closeBtn.onclick = function(e) {
                e.stopPropagation();
                closeOverlay();
            };

            const container = document.createElement('div');
            container.style.position = 'relative';
            container.appendChild(closeBtn);
            container.appendChild(clone);

            overlay.appendChild(container);
            document.body.appendChild(overlay);
        }
    }
}, true);

document.addEventListener('mouseleave', function(e) {
    const overlay = document.getElementById('video-overlay');
    if (overlay && !overlay.contains(e.relatedTarget)) {
        closeOverlay();
    }
}, true);
</script>
