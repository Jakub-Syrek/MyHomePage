@inherits LayoutComponentBase

<PageTitle>My Home Page</PageTitle>

<div class="layout">
    <header class="app-header">
        <video class="header-bg-video"
               autoplay muted loop playsinline preload="auto"
               poster="/videos/header/header-bg.jpg"
               aria-hidden="true">
            <source src="/videos/header/header-bg.mp4" type="video/mp4" />
        </video>

        <div class="header-content">
            <a href="/" class="logo">
                <img src="/images/icons/logo-mountain.svg" alt="" class="logo-icon" />
                <span>My Mountain Adventures</span>
            </a>
            <nav class="nav-menu">
                <a href="/">Home</a>
                <a href="/gory">Mountains</a>
                <a href="/wspinaczka-skalowa">Rock Climbing</a>
                <a href="/bouldering">Bouldering</a>
                <a href="/prowadzeni-hala">Indoor Climbing</a>
                <a href="/calisthenics">Calisthenics</a>
                <a href="/running">Running</a>
            </nav>
            <div class="pinned-controls">
                <a href="/map" class="pinned-globe" title="Adventures map" aria-label="Map">
                    <span class="pinned-globe-orb"></span>
                </a>
                <a href="/stats" class="pinned-stats" title="Training stats" aria-label="Stats">
                    <img src="/images/icons/stats-abacus.svg" alt="Stats" class="pinned-stats-icon" />
                </a>
                <AuthorizeView>
                    <Authorized>
                        <a href="/coach" title="Weekly coach reports" aria-label="Coach">🧠</a>
                        <a href="/admin/strava" class="admin-strava" title="Strava integration" aria-label="Strava">
                            <img src="/images/icons/strava.svg" alt="Strava" class="admin-strava-icon" />
                        </a>
                        <a href="/admin/logs">Logs</a>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="auth-controls">
                <AuthorizeView>
                    <Authorized>
                        <a href="/logout" class="auth-btn auth-btn-secondary">Logout</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="auth-btn auth-btn-primary">🔐 Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>

    <footer class="app-footer">
        <p>&copy; 2026 My Mountain Adventures. All videos captured with passion.</p>
    </footer>
</div>

<style>
    .layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .app-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background:
            linear-gradient(135deg, rgba(102, 126, 234, 0.65) 0%, rgba(118, 75, 162, 0.65) 100%);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        color: white;
        padding: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
        box-shadow:
            0 8px 32px rgba(60, 30, 120, 0.28),
            0 2px 6px rgba(60, 30, 120, 0.16),
            inset 0 1px 0 rgba(255, 255, 255, 0.55),
            inset 0 -1px 0 rgba(255, 255, 255, 0.08);
        overflow: hidden;
    }
    /* Top-light reflection */
    .app-header::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 60%;
        background: linear-gradient(180deg, rgba(255,255,255,0.32) 0%, rgba(255,255,255,0) 100%);
        pointer-events: none;
        z-index: 0;
    }
    /* Diagonal sheen highlight that animates on hover/load */
    .app-header::after {
        content: '';
        position: absolute;
        top: -50%; left: -15%;
        width: 35%; height: 220%;
        background: linear-gradient(120deg,
            rgba(255,255,255,0) 0%,
            rgba(255,255,255,0.22) 45%,
            rgba(255,255,255,0.45) 50%,
            rgba(255,255,255,0.22) 55%,
            rgba(255,255,255,0) 100%);
        transform: rotate(20deg);
        pointer-events: none;
        z-index: 0;
        animation: headerSheen 7s ease-in-out infinite;
        filter: blur(2px);
    }
    @@keyframes headerSheen {
        0%   { left: -25%; opacity: 0.6; }
        45%  { left: 110%; opacity: 0.6; }
        50%  { left: 110%; opacity: 0; }
        100% { left: 110%; opacity: 0; }
    }
    .app-header > * { position: relative; z-index: 1; }

    /* Looping video as the bottom-most layer of the header.
       File ships the full Midjourney frame; CSS cover-crops to the
       header bar and biases the visible slice toward the mountains
       (which sit slightly below the centre of the original frame). */
    .header-bg-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 60%;
        z-index: 0;
        opacity: 0.75;
        pointer-events: none;
        filter: saturate(115%) contrast(95%);
    }

    .header-content {
        max-width: none;
        margin: 0 auto;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 40px;
        gap: 20px;
        min-width: 0;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        text-decoration: none;
        transition: transform 0.3s ease, filter 0.3s ease;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
        text-shadow:
            0 1px 0 rgba(255,255,255,0.18),
            0 2px 10px rgba(0,0,0,0.25);
    }

    .logo-icon {
        width: 42px;
        height: 42px;
        filter:
            drop-shadow(0 2px 6px rgba(0,0,0,0.35))
            drop-shadow(0 0 1px rgba(255,255,255,0.6));
        transition: filter 0.3s ease;
    }

    .logo:hover {
        transform: scale(1.04);
        filter: brightness(1.08);
    }
    .logo:hover .logo-icon {
        filter:
            drop-shadow(0 4px 10px rgba(0,0,0,0.4))
            drop-shadow(0 0 4px rgba(255,255,255,0.65));
    }

    .nav-menu {
        display: flex;
        gap: 20px;
        min-width: 0;
        flex: 1;
        flex-wrap: nowrap;
        /* When the link list does not fit on one line, scroll horizontally
           rather than wrapping or pushing into the logo. Visible at any
           viewport width — the mobile branch below tweaks padding only. */
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        -webkit-mask-image: linear-gradient(90deg, transparent 0, black 14px, black calc(100% - 14px), transparent 100%);
                mask-image: linear-gradient(90deg, transparent 0, black 14px, black calc(100% - 14px), transparent 100%);
    }
    /* Nav items flow left-to-right starting right after the logo. The
       auth pill sits at the far right via the parent's space-between,
       so removing the previous margin-left:auto on the first nav item
       leaves the maximum horizontal room for the link list. */
    .nav-menu::-webkit-scrollbar { display: none; }

    @@media (max-width: 1280px) {
        .nav-menu { gap: 14px; font-size: 0.95rem; }
    }

    .nav-menu a {
        color: white;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.92rem;
        letter-spacing: 0.01em;
        transition: opacity 0.3s;
        white-space: nowrap;
    }

    .nav-menu a:hover {
        opacity: 0.8;
    }

    /* Always-visible pinned controls — globe goes to /map (public),
       Strava + Logs (admin-only) appear behind AuthorizeView. Sits
       between the scrollable nav-menu and the auth pill. */
    .pinned-controls {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-shrink: 0;
        margin-left: 18px;
    }
    .pinned-controls a {
        color: white;
        text-decoration: none;
        font-weight: 500;
        white-space: nowrap;
        transition: opacity 0.18s;
    }
    .pinned-controls a:hover { opacity: 0.85; }

    /* Blue Earth orb that deep-links to /map. Pure CSS — no extra
       network round-trip for an icon file. */
    .pinned-globe {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 0;
    }
    .pinned-globe-orb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background:
            radial-gradient(circle at 30% 28%, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0) 35%),
            radial-gradient(circle at 70% 75%, rgba(20, 100, 200, 0.65) 0%, rgba(20, 100, 200, 0) 40%),
            linear-gradient(135deg, #1d4ed8 0%, #2563eb 45%, #0ea5e9 100%);
        box-shadow:
            0 2px 6px rgba(0, 0, 0, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.45);
        transition: transform 0.18s, box-shadow 0.18s;
    }
    .pinned-globe:hover .pinned-globe-orb {
        transform: scale(1.12) rotate(8deg);
        box-shadow:
            0 4px 12px rgba(29, 78, 216, 0.55),
            inset 0 1px 0 rgba(255, 255, 255, 0.6);
    }

    .pinned-stats {
        display: inline-flex;
        align-items: center;
        line-height: 0;
    }
    .pinned-stats-icon {
        width: 22px;
        height: 22px;
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
        transition: transform 0.18s, filter 0.18s;
    }
    .pinned-stats:hover .pinned-stats-icon {
        transform: scale(1.12) rotate(-4deg);
        filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.45));
    }

    .admin-strava {
        display: inline-flex;
        align-items: center;
        line-height: 0;
    }
    .admin-strava-icon {
        width: 22px;
        height: 22px;
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
        transition: transform 0.18s, filter 0.18s;
    }
    .admin-strava:hover .admin-strava-icon {
        transform: scale(1.12);
        filter: drop-shadow(0 2px 6px rgba(252, 76, 2, 0.65));
    }

    /* Auth controls pinned to the far right, OUTSIDE the scrollable
       nav-menu so the Login / Logout button is always visible even
       when the category links overflow horizontally. */
    .auth-controls {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-left: 18px;
    }
    .auth-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.92rem;
        font-family: inherit;
        line-height: 1;
        white-space: nowrap;
        border: 1px solid transparent;
        transition: transform 0.18s, background 0.18s, box-shadow 0.18s, color 0.18s;
    }
    .auth-btn-primary {
        background: white;
        color: #4338ca;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
    }
    .auth-btn-primary:hover {
        background: #f1f5f9;
        transform: translateY(-1px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.24);
    }
    .auth-btn-secondary {
        background: rgba(255, 255, 255, 0.18);
        color: white;
        border-color: rgba(255, 255, 255, 0.35);
    }
    .auth-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.32);
        color: white;
    }

    /* Tablet / narrower desktop: horizontally scrollable nav */
    @@media (max-width: 1100px) {
        .header-content {
            padding: 14px 16px;
            gap: 14px;
            /* allow children (nav-menu) to overflow & scroll */
            overflow: hidden;
        }
        .logo {
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .logo-icon {
            width: 32px;
            height: 32px;
        }
        .nav-menu {
            gap: 18px;
            /* Critical: start items at the LEFT so the first ones are reachable
               by default; user swipes RIGHT to see later ones. */
            justify-content: flex-start;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            scroll-behavior: smooth;
            scrollbar-width: none;
            -ms-overflow-style: none;
            padding-bottom: 2px;
            /* Tells the browser this element wants horizontal pan gestures.
               Without this, iOS Safari can hijack swipes for browser-back. */
            touch-action: pan-x;
            /* Force a separate compositor layer — fixes sticky + scroll
               interaction quirk on iOS Safari. */
            -webkit-transform: translateZ(0);
            transform: translateZ(0);
            /* Hard floor so the scrollable list always has a touch surface
               even when the pinned + auth controls eat most of the row. */
            min-width: 120px;
            /* Subtle edge fade to hint scrollability */
            -webkit-mask-image: linear-gradient(90deg, transparent 0, black 14px, black calc(100% - 14px), transparent 100%);
                    mask-image: linear-gradient(90deg, transparent 0, black 14px, black calc(100% - 14px), transparent 100%);
        }
        .nav-menu::-webkit-scrollbar { display: none; }
        .nav-menu a {
            font-size: 0.88rem;
            padding: 4px 2px;
            /* Bigger touch target without changing visual size */
            min-height: 36px;
            display: inline-flex;
            align-items: center;
        }
        /* Tighter pinned-controls so they don't crowd the scrollable nav. */
        .pinned-controls {
            gap: 10px;
            margin-left: 10px;
        }
        .auth-controls {
            margin-left: 10px;
        }
    }

    /* Phone-sized viewports: keep the scrollable nav as the primary
       interaction and reduce the right-side icon stack so it gets room. */
    @@media (max-width: 700px) {
        .pinned-controls { gap: 8px; margin-left: 6px; }
        /* Coach / Logs are admin-only AND not navigation — hide on phones
           to give the gallery links the horizontal scroll surface back. */
        .pinned-controls a[href="/coach"],
        .pinned-controls a[href="/admin/logs"] {
            display: none;
        }
        .pinned-globe-orb,
        .pinned-stats-icon,
        .admin-strava-icon {
            width: 20px;
            height: 20px;
        }
        .auth-controls { margin-left: 6px; }
        .auth-btn { padding: 6px 10px; font-size: 0.85rem; }
    }

    @@media (max-width: 500px) {
        .logo span { display: none; } /* keep only the icon to save space */
        .header-content { padding: 12px 10px; gap: 10px; }
        /* On the very narrowest viewports, drop the Strava admin chevron
           too — admin uses /admin/strava deep-link or desktop. */
        .pinned-controls a[href="/admin/strava"] { display: none; }
    }

    .app-main {
        flex: 1;
    }

    .app-footer {
        background: rgba(0, 0, 0, 0.8);
        color: white;
        text-align: center;
        padding: 30px 20px;
        margin-top: 60px;
    }

    .app-footer p {
        margin: 0;
    }
</style>

<script>
function closeOverlay() {
    const overlay = document.getElementById('video-overlay');
    if (overlay) {
        overlay.remove();
    }
}

function getElementTarget(e) {
    // mouseenter/mouseleave can fire on text nodes - get the parent element
    if (!e.target) return null;
    if (e.target.nodeType === 1) return e.target; // ELEMENT_NODE
    if (e.target.parentElement) return e.target.parentElement;
    return null;
}

document.addEventListener('mouseenter', function(e) {
    const target = getElementTarget(e);
    if (!target || typeof target.closest !== 'function') return;

    const card = target.closest('.video-card');
    if (!card) return;

    // Only expand when hovering over the video (top part of card)
    // - the bottom part (title, description, Edit/Delete) stays interactive
    if (!target.closest('.card-image')) return;

    // Create overlay if it doesn't exist
    if (!document.getElementById('video-overlay')) {
        const overlay = document.createElement('div');
        overlay.id = 'video-overlay';
        overlay.style.position = 'fixed';
        overlay.style.top = '0';
        overlay.style.left = '0';
        overlay.style.right = '0';
        overlay.style.bottom = '0';
        overlay.style.zIndex = '999';
        overlay.style.display = 'flex';
        overlay.style.alignItems = 'center';
        overlay.style.justifyContent = 'center';
        overlay.style.background = 'rgba(0, 0, 0, 0.3)';
        overlay.style.cursor = 'pointer';

        // Close on background click
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) {
                closeOverlay();
            }
        });

        // Close on Escape key
        const closeOnEscape = function(e) {
            if (e.key === 'Escape') {
                closeOverlay();
                document.removeEventListener('keydown', closeOnEscape);
            }
        };
        document.addEventListener('keydown', closeOnEscape);

        const clone = card.cloneNode(true);
        clone.style.width = '700px';
        clone.style.maxWidth = '90vw';
        clone.style.maxHeight = '90vh';
        clone.style.position = 'relative';
        clone.style.zIndex = '1001';

        // Remove action buttons from clone - they are DOM clones and don't have
        // working Blazor event handlers. User must close overlay to access them.
        const clonedActions = clone.querySelector('.card-actions');
        if (clonedActions) clonedActions.remove();

        // Add close button
        const closeBtn = document.createElement('button');
        closeBtn.innerHTML = '×';
        closeBtn.style.position = 'absolute';
        closeBtn.style.top = '-30px';
        closeBtn.style.right = '0';
        closeBtn.style.background = 'none';
        closeBtn.style.border = 'none';
        closeBtn.style.color = 'white';
        closeBtn.style.fontSize = '40px';
        closeBtn.style.cursor = 'pointer';
        closeBtn.style.padding = '0';
        closeBtn.style.width = '40px';
        closeBtn.style.height = '40px';
        closeBtn.style.display = 'flex';
        closeBtn.style.alignItems = 'center';
        closeBtn.style.justifyContent = 'center';
        closeBtn.style.zIndex = '1002';
        closeBtn.onclick = function(e) {
            e.stopPropagation();
            closeOverlay();
        };

        const container = document.createElement('div');
        container.style.position = 'relative';
        container.appendChild(closeBtn);
        container.appendChild(clone);

        overlay.appendChild(container);
        document.body.appendChild(overlay);
    }
}, true);

document.addEventListener('mouseleave', function(e) {
    const overlay = document.getElementById('video-overlay');
    if (!overlay) return;

    // Only close if leaving to a target outside the overlay
    const related = e.relatedTarget;
    if (related && related.nodeType === 1 && overlay.contains(related)) return;

    closeOverlay();
}, true);
</script>
